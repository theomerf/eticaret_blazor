{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "FileStorage": {
    "PublicBaseUrl": ""
  },
  "ApiBaseUrl": "",
  "Hangfire": {
    "Enabled": true,
    "ConnectionStringName": "postgresqlconnection",
    "SchemaName": "hangfire",
    "WorkerCount": 8,
    "QueueNames": [ "critical", "default", "low" ],
    "ServerNamePrefix": "ETicaret"
  }
}

