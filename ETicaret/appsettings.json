{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "FileStorage": {
    "PublicBaseUrl": ""
  },
  "ApiBaseUrl": "",
  "Hangfire": {
    "Enabled": true,
    "ConnectionStringName": "postgresqlconnection",
    "SchemaName": "hangfire",
    "WorkerCount": 8,
    "QueueNames": [ "critical", "orders", "notifications", "outbox", "default", "maintenance", "low" ],
    "ServerNamePrefix": "ETicaret",
    "SoftDeleteCleanup": {
      "Enabled": true,
      "BatchSize": 500,
      "MaxBatchesPerEntity": 20,
      "NotificationRetentionDays": 90,
      "AddressRetentionDays": 365,
      "UserReviewRetentionDays": 730,
      "CampaignRetentionDays": 730,
      "CouponRetentionDays": 730,
      "CategoryVariantAttributeRetentionDays": 365,
      "ActivityRetentionDays": 180,
      "AuditLogRetentionDays": 3650,
      "SecurityLogRetentionDays": 1825
    }
  }
}

