    private bool CanRefundOrder(OrderDto order)
    {
        // Teslim edilmiş ve ödeme tamamlanmış olmalı
        if (order.OrderStatus != OrderStatus.Delivered || order.PaymentStatus != PaymentStatus.Completed)
        {
            return false;
        }

        // Teslimattan sonra 7 gün geçmemiş olmalı
        if (order.DeliveredAt.HasValue)
        {
            var daysSinceDelivery = (DateTime.UtcNow - order.DeliveredAt.Value).TotalDays;
            return daysSinceDelivery <= 7;
        }

        return false;
    }

    private bool CanCancelOrder(OrderDto order)
    {
        // Sadece beklemede veya işleniyor durumundaki siparişler iptal edilebilir
        return order.OrderStatus == OrderStatus.Pending || order.OrderStatus == OrderStatus.Processing;
    }

    private async Task RefundOrder(int orderId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Bu siparişi iade etmek istediğinizden emin misiniz? İade işlemi geri alınamaz."))
        {
            return;
        }

        var result = await OrderService.RefundAsync(orderId);

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", "Sipariş iadesi başarıyla tamamlandı. İade tutarı hesabınıza yansıtılacaktır.", "success");

            // Refresh orders
            if (!string.IsNullOrEmpty(userId))
            {
                orders = await OrderService.GetByUserIdAsync(userId);

                // Clear cache for this order
                orderDetailsCache.Remove(orderId);
                expandedOrderIds.Remove(orderId);
            }

            StateHasChanged();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private async Task CancelOrder(int orderId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Bu siparişi iptal etmek istediğinizden emin misiniz?"))
        {
            return;
        }

        var reason = await JSRuntime.InvokeAsync<string>("prompt", "Lütfen iptal sebebinizi giriniz:", "Müşteri talebi");
        var result = await OrderService.CancelAsync(orderId, reason);

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", "Sipariş başarıyla iptal edildi.", "success");

            // Refresh orders
            if (!string.IsNullOrEmpty(userId))
            {
                orders = await OrderService.GetByUserIdAsync(userId);

                // Clear cache for this order
                orderDetailsCache.Remove(orderId);
                expandedOrderIds.Remove(orderId);
            }

            StateHasChanged();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }
}
