                        İptal
                    </button>
                    <button type="submit" disabled="@(JsonSerializer.Serialize(addressDtoForUpdate) == _initialAddressJson)" title="@(JsonSerializer.Serialize(addressDtoForUpdate) == _initialAddressJson ? "Kaydetmek için değişiklik yapın" : "")" class="px-6 py-2.5 rounded-xl bg-button text-white font-semibold shadow-lg transition-all transform disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none hover:bg-button-hover hover:shadow-xl hover:-translate-y-0.5">
                        Onayla
                    </button>
                </div>
            </EditForm>
