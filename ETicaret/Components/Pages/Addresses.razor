@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private IEnumerable<AddressDto> addresses = new List<AddressDto>();
    private AddressDtoForCreation addressDtoForCreation = new();
    private AddressDtoForUpdate addressDtoForUpdate = new();
    private bool showAddModal = false;
    private bool showEditModal = false;
    private bool isLoading = true;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            }
        }

        if (!string.IsNullOrEmpty(userId))
        {
            addresses = await AddressService.GetAllAddressesOfOneUserAsync(userId);
        }

        isLoading = false;
    }

    private void OpenAddModal()
    {
        showAddModal = true;
        addressDtoForCreation = new();
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
    }

    private void CloseAddModal()
    {
        showAddModal = false;
        addressDtoForCreation = new();
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'auto'");
    }

    private async Task HandleCreateAddress(EditContext editContext)
    {
        var addressDto = (AddressDtoForCreation)editContext.Model;
        if (addresses.Count() <= 1)
        {
            addressDto.IsDefault = true;
        }

        var result = await AddressService.CreateAddressAsync(addressDto);

        if (result.IsSuccess)
        {
            CloseAddModal();
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
            if (!string.IsNullOrEmpty(userId))
            {
                addresses = await AddressService.GetAllAddressesOfOneUserAsync(userId);
            }
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private async Task HandleUpdateAddress(EditContext editContext)
    {
        var addressDto = (AddressDtoForUpdate)editContext.Model;
        if (addresses.Count() <= 1)
        {
            addressDto.IsDefault = true;
        }

        var result = await AddressService.UpdateAddressAsync(addressDto);

        if (result.IsSuccess)
        {
            CloseEditModal();
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
            if (!string.IsNullOrEmpty(userId))
            {
                addresses = await AddressService.GetAllAddressesOfOneUserAsync(userId);
            }
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private string _initialAddressJson = string.Empty;

    private void OpenEditModal(AddressDto address)
    {
        addressDtoForUpdate = new AddressDtoForUpdate
            {
                AddressId = address.AddressId,
                Title = address.Title,
                FirstName = address.FirstName,
                LastName = address.LastName,
                Phone = address.Phone,
                City = address.City,
                District = address.District,
                PostalCode = address.PostalCode,
                AddressLine = address.AddressLine,
                IsDefault = address.IsDefault
            };

        _initialAddressJson = JsonSerializer.Serialize(addressDtoForUpdate);
        showEditModal = true;
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
    }

    private void CloseEditModal()
    {
        showEditModal = false;
        addressDtoForUpdate = new();
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'auto'");
    }

