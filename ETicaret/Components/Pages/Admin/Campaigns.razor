                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tip</label>
                        <InputSelect @bind-Value="editModel.Type" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                            <option value="@CampaignType.Percentage">Yüzde</option>
                            <option value="@CampaignType.FixedAmount">Sabit</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kapsam</label>
                        <InputSelect @bind-Value="editModel.Scope" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                            <option value="@CampaignScope.OrderTotal">Sipariş</option>
                            <option value="@CampaignScope.Product">Ürün</option>
                            <option value="@CampaignScope.Category">Kategori</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Değer</label>
                        <InputNumber @bind-Value="editModel.Value" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Min Sipariş</label>
                        <InputNumber @bind-Value="editModel.MinOrderAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Maks. İndirim</label>
                        <InputNumber @bind-Value="editModel.MaxDiscountAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Başlangıç</label>
                        <InputDate @bind-Value="editModel.StartsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bitiş</label>
                        <InputDate @bind-Value="editModel.EndsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div class="flex items-center gap-2 pt-6">
                        <InputCheckbox @bind-Value="editModel.IsStackable" />
                        <label class="text-sm text-gray-700">Diğer kampanyalarla birleştirilebilir</label>
                    </div>
                </div>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm">Vazgeç</button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm disabled:opacity-50">Güncelle</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showUsageModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-5xl max-h-[85vh] flex flex-col" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Kullanım Listesi - @selectedCampaignName</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90"><i class="fas fa-times"></i></button>
            </div>
            <div class="p-6 overflow-y-auto">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">E-posta</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Sipariş</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">İndirim</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Sipariş Tutarı</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase">Tarih</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @if (campaignUsages.Any())
                            {
                                @foreach (var usage in campaignUsages)
                                {
                                    <tr>
                                        <td class="px-4 py-3 text-sm text-gray-700">@usage.UserEmail</td>
                                        <td class="px-4 py-3 text-sm text-gray-700">#@usage.OrderId</td>
                                        <td class="px-4 py-3 text-sm text-gray-700">@usage.DiscountAmount.ToString("N2") ₺</td>
                                        <td class="px-4 py-3 text-sm text-gray-700">@usage.OrderTotalAmount.ToString("N2") ₺</td>
                                        <td class="px-4 py-3 text-sm text-gray-700">@usage.OrderedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="5" class="px-4 py-8 text-center text-gray-500">Kullanım kaydı bulunamadı.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@if (showAnalyticsModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[85vh] flex flex-col" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Kampanya Analizi - @selectedCampaignName</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90"><i class="fas fa-times"></i></button>
            </div>
            <div class="p-6 overflow-y-auto">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100"><p class="text-xs text-gray-500">Toplam Kullanım</p><p class="text-xl font-bold text-gray-800">@analyticsTotalUsage</p></div>
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100"><p class="text-xs text-gray-500">Benzersiz Kullanıcı</p><p class="text-xl font-bold text-gray-800">@analyticsUniqueUsers</p></div>
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100"><p class="text-xs text-gray-500">Toplam İndirim</p><p class="text-xl font-bold text-gray-800">@analyticsTotalDiscount.ToString("N2") ₺</p></div>
                </div>
                <div class="border border-gray-100 rounded-xl p-4 bg-white h-[320px]"><canvas id="campaignUsageChart" class="w-full h-full"></canvas></div>
            </div>
        </div>
    </div>
}

@code {
    private CampaignListViewModelAdmin model = new();
    private CampaignRequestParametersAdmin _lastParams = new();
    private Timer? _debounceTimer;
    private CancellationTokenSource? _cts;

    private bool isLoading = true;
    private bool isSaving = false;
    private int activeCampaignCount;
    private int? openDropdownId;
    private string searchTerm = string.Empty;

    private bool showCreateModal;
    private bool showEditModal;
    private bool showUsageModal;
    private bool showAnalyticsModal;
    private bool shouldRenderChart;
    private string? editFormError;
    private CampaignDto? selectedCampaign;
    private CampaignDtoForCreation createModel = BuildCreateModel();
    private CampaignDtoForUpdate editModel = BuildEditModel();

    private List<CampaignUsageDto> campaignUsages = [];
    private List<string> analyticsLabels = [];
    private List<int> analyticsData = [];
    private int analyticsTotalUsage;
    private int analyticsUniqueUsers;
    private decimal analyticsTotalDiscount;

    private string selectedCampaignName => selectedCampaign?.Name ?? "";

    protected override async Task OnInitializedAsync()
    {
        model.FilterParams = Navigation.BindFromQuery<CampaignRequestParametersAdmin>();
        if (string.IsNullOrWhiteSpace(model.FilterParams.SortBy))
            model.FilterParams.SortBy = "date_desc";
        searchTerm = model.FilterParams.SearchTerm ?? "";

        _cts = new CancellationTokenSource();
        await LoadCampaigns(_cts.Token);

        isLoading = false;
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!shouldRenderChart || !showAnalyticsModal)
            return;

        shouldRenderChart = false;
        await JSRuntime.InvokeVoidAsync("couponAnalytics.renderUsageChart", "campaignUsageChart", analyticsLabels, analyticsData);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var newParams = Navigation.BindFromQuery<CampaignRequestParametersAdmin>();
        if (_lastParams.Equals(newParams))
            return;
        _lastParams = newParams with { };

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();

        await InvokeAsync(async () =>
        {
            model.FilterParams = newParams;
            if (string.IsNullOrWhiteSpace(model.FilterParams.SortBy))
                model.FilterParams.SortBy = "date_desc";
            searchTerm = model.FilterParams.SearchTerm ?? "";
            await LoadCampaigns(_cts.Token);
            await JSRuntime.InvokeVoidAsync("scrollToElement", "campaigns-list-top");
            StateHasChanged();
        });
    }

    private async Task LoadCampaigns(CancellationToken ct)
    {
        if (model.FilterParams.PageSize == 0) model.FilterParams.PageSize = 10;

        var result = await Service.GetAllAdminAsync(model.FilterParams, ct);
        if (ct.IsCancellationRequested) return;

        var pagination = new Pagination
        {
            CurrentPage = model.FilterParams.PageNumber,
            ItemsPerPage = model.FilterParams.PageSize,
            TotalItems = result.count
        };

        model = new CampaignListViewModelAdmin()
        {
            Campaigns = result.campaigns,
            Pagination = pagination,
            TotalCount = result.count,
            FilterParams = model.FilterParams
        };

        activeCampaignCount = result.activeCount;
    }

    private void UpdateUrl()
    {
        var url = model.FilterParams.ToQueryString("/admin/coupons");
        Navigation.NavigateTo(url!);
    }

    private async Task ApplyFilters()
    {
        model.FilterParams = model.FilterParams with { PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        model.FilterParams = new CampaignRequestParametersAdmin { SortBy = "date_desc" };
        searchTerm = "";
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandleSortChange(ChangeEventArgs e)
    {
        model.FilterParams = model.FilterParams with { SortBy = e.Value?.ToString(), PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandlePageChange(int page)
    {
        model.FilterParams = model.FilterParams with { PageNumber = page };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandlePageSizeChange(int size)
    {
        model.FilterParams = model.FilterParams with { PageSize = size, PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                model.FilterParams = model.FilterParams with { SearchTerm = searchTerm, PageNumber = 1 };
                UpdateUrl();
            });
        }, null, 500, Timeout.Infinite);
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter") return;
        model.FilterParams = model.FilterParams with { PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private string GetIsActiveFilterValue() => model.FilterParams.IsActive.HasValue ? model.FilterParams.IsActive.Value.ToString().ToLower() : "";
    private void OnIsActiveFilterChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        model.FilterParams = model.FilterParams with { IsActive = string.IsNullOrWhiteSpace(value) ? null : bool.Parse(value) };
    }

    private async Task ToggleActive(CampaignDto campaign)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm", $"{campaign.Name} kampanyasını {(campaign.IsActive ? "deaktif" : "aktif")} yapmak istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = campaign.IsActive ? await Service.DeactivateAsync(campaign.CampaignId) : await Service.ActivateAsync(campaign.CampaignId);
        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess) await ReloadList();
    }

    private async Task DeleteCampaign(CampaignDto campaign)
    {
        CloseDropdown(campaign.CampaignId);
        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm", $"{campaign.Name} kampanyasını silmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await Service.DeleteAsync(campaign.CampaignId);
        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess) await ReloadList();
    }

    private void OpenCreateModal()
    {
        createModel = BuildCreateModel();
        showCreateModal = true;
    }

    private async Task SaveCreate()
    {
        isSaving = true;
        var result = await Service.CreateAsync(createModel);
        isSaving = false;
        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess) { await CloseModals(); await ReloadList(); }
    }

    private void OpenEditModal(CampaignDto campaign)
    {
        CloseDropdown(campaign.CampaignId);
        selectedCampaign = campaign;
        editFormError = null;
        editModel = new CampaignDtoForUpdate
        {
            CampaignId = campaign.CampaignId,
            Name = campaign.Name,
            Description = campaign.Description,
            Type = campaign.Type,
            Value = campaign.Value,
            Scope = campaign.Scope,
            MinOrderAmount = campaign.MinOrderAmount,
            MaxDiscountAmount = campaign.MaxDiscountAmount,
            StartsAt = campaign.StartsAt,
            EndsAt = campaign.EndsAt,
            IsActive = campaign.IsActive,
            Priority = campaign.Priority,
            IsStackable = campaign.IsStackable
        };
        showEditModal = true;
    }

    private async Task SaveEdit()
    {
        isSaving = true;
        var result = await Service.UpdateAsync(editModel);
        isSaving = false;
        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess) { await CloseModals(); await ReloadList(); } else { editFormError = result.Message; }
    }

    private async Task OpenUsageModal(CampaignDto campaign)
    {
        CloseDropdown(campaign.CampaignId);
        selectedCampaign = campaign;
        campaignUsages = (await Service.GetCampaignUsagesAsync(campaign.CampaignId, 500)).ToList();
        showUsageModal = true;
    }

    private async Task OpenAnalyticsModal(CampaignDto campaign)
    {
        CloseDropdown(campaign.CampaignId);
        selectedCampaign = campaign;
        campaignUsages = (await Service.GetCampaignUsagesAsync(campaign.CampaignId, 1000)).ToList();

        analyticsTotalUsage = campaignUsages.Count;
        analyticsUniqueUsers = campaignUsages.Select(x => x.UserId).Distinct().Count();
        analyticsTotalDiscount = campaignUsages.Sum(x => x.DiscountAmount);

        var grouped = campaignUsages.GroupBy(x => x.OrderedAt.Date).ToDictionary(g => g.Key, g => g.Count());
        analyticsLabels = [];
        analyticsData = [];
        for (var i = 13; i >= 0; i--)
        {
            var date = DateTime.UtcNow.Date.AddDays(-i);
            analyticsLabels.Add(date.ToString("dd.MM"));
            analyticsData.Add(grouped.TryGetValue(date, out var count) ? count : 0);
        }

        showAnalyticsModal = true;
        shouldRenderChart = true;
        StateHasChanged();
    }

    private async Task ReloadList()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        await LoadCampaigns(_cts.Token);
        StateHasChanged();
    }

    private void ToggleDropdown(int id) => openDropdownId = openDropdownId == id ? null : id;
    private void CloseDropdown(int id) { if (openDropdownId == id) openDropdownId = null; }

    private async Task CloseModals()
    {
        showCreateModal = false;
        showEditModal = false;
        showUsageModal = false;
        showAnalyticsModal = false;
        selectedCampaign = null;
        editFormError = null;
        await JSRuntime.InvokeVoidAsync("couponAnalytics.destroyUsageChart", "campaignUsageChart");
    }

    private static CampaignDtoForCreation BuildCreateModel() => new() { Name = string.Empty, Description = string.Empty, Type = CampaignType.Percentage, Scope = CampaignScope.OrderTotal, StartsAt = DateTime.UtcNow, EndsAt = DateTime.UtcNow.AddDays(7), Priority = 0, IsActive = true, IsStackable = false };
    private static CampaignDtoForUpdate BuildEditModel() => new() { CampaignId = 0, Name = string.Empty, Description = string.Empty, Type = CampaignType.Percentage, Scope = CampaignScope.OrderTotal, StartsAt = DateTime.UtcNow, EndsAt = DateTime.UtcNow.AddDays(7), Priority = 0, IsActive = true, IsStackable = false };

    private static string GetCampaignScopeText(CampaignScope scope) => scope switch { CampaignScope.OrderTotal => "Sipariş", CampaignScope.Product => "Ürün", CampaignScope.Category => "Kategori", _ => "Diğer" };
    private static string GetCampaignTypeText(CampaignType type) => type switch { CampaignType.Percentage => "Yüzde", CampaignType.FixedAmount => "Sabit", _ => "-" };
    private static string GetCampaignValueText(CampaignDto campaign) => campaign.Type == CampaignType.Percentage ? $"%{campaign.Value}" : $"{campaign.Value:N2} ₺";

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _debounceTimer?.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
        _ = JSRuntime.InvokeVoidAsync("couponAnalytics.destroyUsageChart", "campaignUsageChart");
    }
}
