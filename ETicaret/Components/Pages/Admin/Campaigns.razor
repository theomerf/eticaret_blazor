@page "/admin/campaigns"
@attribute [Authorize(Roles = "Admin")]
@using Application.DTOs
@using Application.Queries.RequestParameters
@using ETicaret.Extensions
@using ETicaret.Models
@using Domain.Entities
@using Microsoft.AspNetCore.Components.Web
@inherits OwningComponentBase<ICampaignService>
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@layout AdminLayout
@implements IDisposable

<div class="flex flex-col">
    <div class="hidden lg:grid lg:grid-cols-5 gap-x-2">
        <div class="col-span-1 grid grid-cols-2 gap-3 mb-6">
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center mb-2">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <div class="text-xs text-gray-500 font-medium">Toplam</div>
                @if (isLoading)
                {
                    <div class="flex items-center mt-2">
                        <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                }
                else
                {
                    <div class="text-lg font-bold text-gray-800">@model.TotalCount</div>
                }
            </div>
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-green-50 text-green-600 flex items-center justify-center mb-2">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="text-xs text-gray-500 font-medium">Aktif</div>
                @if (isLoading)
                {
                    <div class="flex items-center mt-2">
                        <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                }
                else
                {
                    <div class="text-lg font-bold text-gray-800">@activeCampaignCount</div>
                }
            </div>
        </div>

        <div class="lg:col-span-4 lg:flex justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
            <div>
                <div id="coupons-list-top"></div>
                <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-secondary flex items-center justify-center text-lg">
                        <i class="fas fa-tags"></i>
                    </div>
                    Kampanya Yönetimi
                </h1>
                <p class="text-gray-500 text-sm mt-1 ml-[52px]">Kuponları görüntüleyin, filtreleyin ve yönetin.</p>
            </div>
            <div class="flex items-center gap-3">
                @if (!isLoading)
                {
                    <button @onclick="OpenCreateModal" class="bg-button hover:bg-button-hover text-white px-5 py-2.5 rounded-xl font-semibold shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5 flex items-center gap-2">
                        <i class="fas fa-plus"></i> Yeni Kampanya
                    </button>
                }
            </div>
        </div>
    </div>

    @if (!isLoading)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 p-5">
            <div class="flex flex-col md:flex-row gap-4 items-end justify-between">
                <div class="flex flex-col md:flex-row gap-4 flex-1">
                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Tip</label>
                        <select @bind="model.FilterParams.Type" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="@CampaignType.Percentage">Yüzde</option>
                            <option value="@CampaignType.FixedAmount">Sabit Tutar</option>
                        </select>
                    </div>
                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Kapsam</label>
                        <select @bind="model.FilterParams.Scope" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="@CampaignScope.OrderTotal">Sipariş</option>
                            <option value="@CampaignScope.Product">Ürün</option>
                            <option value="@CampaignScope.Category">Kategori</option>
                        </select>
                    </div>
                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Durum</label>
                        <select value="@GetIsActiveFilterValue()" @onchange="OnIsActiveFilterChange" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="true">Aktif</option>
                            <option value="false">Pasif</option>
                        </select>
                    </div>
                </div>

                <div class="flex gap-2 w-full md:w-auto">
                    <button @onclick="ApplyFilters" class="flex-1 md:flex-none h-11 bg-button text-white font-medium px-6 rounded-lg text-sm"><i class="fas fa-filter"></i> Filtrele</button>
                    <button @onclick="ClearFilters" class="flex-1 md:flex-none h-11 bg-gray-100 text-gray-700 font-medium px-6 rounded-lg text-sm"><i class="fas fa-times"></i> Temizle</button>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="flex flex-col items-center gap-3">
                <div class="w-10 h-10 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                <span class="text-gray-500 font-medium">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <AdminTable TItem="CampaignDto" Items="model.Campaigns" Pagination="model.Pagination" OnPageChange="HandlePageChange" PageSize="@(model.FilterParams.PageSize)" OnPageSizeChange="HandlePageSizeChange">
            <ToolbarContent>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div class="relative flex-1 sm:max-w-md">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none"><i class="fas fa-search text-gray-400"></i></div>
                        <input type="text" class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg bg-white placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 sm:text-sm" placeholder="Kampanya adı veya açıklama ara..." value="@searchTerm" @oninput="OnSearchInput" @onkeydown="HandleSearchKeyDown">
                    </div>

                    <div class="hidden lg:flex items-center gap-2">
                        <label class="text-sm font-medium text-gray-700 whitespace-nowrap"><i class="fa-solid fa-sort mr-1 text-gray-400"></i>Sırala:</label>
                        <select class="block w-auto pl-3 pr-10 py-2 text-base border border-gray-300 sm:text-sm rounded-md" value="@model.FilterParams.SortBy" @onchange="HandleSortChange">
                            <option value="date_desc">En Yeni</option>
                            <option value="date_asc">En Eski</option>
                            <option value="name_asc">İsim (A-Z)</option>
                            <option value="name_desc">İsim (Z-A)</option>
                            <option value="priority_asc">Öncelik (Artan)</option>
                            <option value="priority_desc">Öncelik (Azalan)</option>
                            <option value="end_asc">Bitiş Tarihi Yakın</option>
                        </select>
                    </div>

                </div>
            </ToolbarContent>

            <HeaderTemplate>
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kampanya</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Tip / Değer</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Kapsam</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Öncelik</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden xl:table-cell">Tarih Aralığı</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Durum</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">İşlemler</th>
                </tr>
            </HeaderTemplate>

            <RowTemplate Context="campaign">
                <td class="px-4 py-3">
                    <p class="text-sm font-semibold text-gray-800 truncate">@campaign.Name</p>
                    @if (!string.IsNullOrWhiteSpace(campaign.Description))
                    {
                        <p class="text-xs text-gray-500 truncate max-w-[220px]">@campaign.Description</p>
                    }
                </td>
                <td class="px-4 py-3 hidden md:table-cell"><span class="text-sm text-gray-700">@GetCampaignTypeText(campaign.Type) - @GetCampaignValueText(campaign)</span></td>
                <td class="px-4 py-3 hidden lg:table-cell"><span class="text-sm text-gray-700">@GetCampaignScopeText(campaign.Scope)</span></td>
                <td class="px-4 py-3"><span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">@campaign.Priority</span> @if (campaign.IsStackable){<span class="ml-1 inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">Stackable</span>}</td>
                <td class="px-4 py-3 hidden xl:table-cell text-sm text-gray-600">@campaign.StartsAt.ToString("dd.MM.yyyy") - @campaign.EndsAt.ToString("dd.MM.yyyy")</td>
                <td class="px-4 py-3 text-center">
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" class="sr-only peer" checked="@campaign.IsActive" @onclick="() => ToggleActive(campaign)">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary peer-checked:after:translate-x-full"></div>
                    </label>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="relative inline-block text-left">
                        <button @onclick="() => ToggleDropdown(campaign.CampaignId)" @onblur="@(async () => { await Task.Delay(100); CloseDropdown(campaign.CampaignId); })" class="p-2 rounded-lg hover:bg-gray-100 transition-colors text-gray-500 focus:outline-none"><i class="fas fa-ellipsis-v"></i></button>
                        @if (openDropdownId == campaign.CampaignId)
                        {
                            <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-200 z-[1000] py-1 origin-top-right animate-fade-in">
                                <button @onclick="() => OpenEditModal(campaign)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-pen text-blue-500 w-4 text-center"></i> Düzenle
                                </button>
                                <button @onclick="() => OpenAnalyticsModal(campaign)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-chart-line text-indigo-500 w-4 text-center"></i> Analiz
                                </button>
                                <button @onclick="() => OpenUsageModal(campaign)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-users text-teal-500 w-4 text-center"></i> Kullanım Listesi
                                </button>
                                <div class="border-t border-gray-100 my-1"></div>
                                <button @onclick="() => DeleteCampaign(campaign)" class="w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-trash text-red-500 w-4 text-center"></i> Sil
                                </button>
                            </div>
                        }
                    </div>
                </td>
            </RowTemplate>
        </AdminTable>
    }
</div>

@if (showCreateModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between sticky top-0">
                <h3 class="text-lg font-bold text-white">Yeni Kampanya</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90"><i class="fas fa-times"></i></button>
            </div>
            <EditForm Model="createModel" OnValidSubmit="SaveCreate" class="p-6 space-y-4">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-red-500 text-xs" />
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kampanya Adı</label>
                        <InputText @bind-Value="createModel.Name" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                        <ValidationMessage For="@(() => createModel.Name)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Öncelik</label>
                        <InputNumber @bind-Value="createModel.Priority" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Açıklama</label>
                        <InputTextArea @bind-Value="createModel.Description" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tip</label>
                        <InputSelect @bind-Value="createModel.Type" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                            <option value="@CampaignType.Percentage">Yüzde</option>
                            <option value="@CampaignType.FixedAmount">Sabit</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kapsam</label>
                        <InputSelect @bind-Value="createModel.Scope" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                            <option value="@CampaignScope.OrderTotal">Sipariş</option>
                            <option value="@CampaignScope.Product">Ürün</option>
                            <option value="@CampaignScope.Category">Kategori</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Değer</label>
                        <InputNumber @bind-Value="createModel.Value" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Min Sipariş</label>
                        <InputNumber @bind-Value="createModel.MinOrderAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Maks. İndirim</label>
                        <InputNumber @bind-Value="createModel.MaxDiscountAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Başlangıç</label>
                        <InputDate @bind-Value="createModel.StartsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bitiş</label>
                        <InputDate @bind-Value="createModel.EndsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div class="flex items-center gap-2 pt-6">
                        <InputCheckbox @bind-Value="createModel.IsStackable" />
                        <label class="text-sm text-gray-700">Diğer kampanyalarla birleştirilebilir</label>
                    </div>
                </div>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm">Vazgeç</button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm disabled:opacity-50">Kaydet</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showEditModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between sticky top-0">
                <h3 class="text-lg font-bold text-white">Kampanya Düzenle</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90"><i class="fas fa-times"></i></button>
            </div>
            <EditForm Model="editModel" OnValidSubmit="SaveEdit" class="p-6 space-y-4">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-red-500 text-xs" />
                @if (!string.IsNullOrWhiteSpace(editFormError))
                {
                    <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">@editFormError</div>
                }
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kampanya Adı</label>
                        <InputText @bind-Value="editModel.Name" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                        <ValidationMessage For="@(() => editModel.Name)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Öncelik</label>
                        <InputNumber @bind-Value="editModel.Priority" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
                    </div>
                    <div class="md:col-span-2">
