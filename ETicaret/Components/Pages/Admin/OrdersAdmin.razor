@page "/admin/orders"
@attribute [Authorize(Roles = "Admin")]
@using Application.DTOs
@using Application.Queries.RequestParameters
@using ETicaret.Models
@using ETicaret.Extensions
@using Domain.Entities
@using System.Globalization
@inherits OwningComponentBase<IOrderService>
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@layout AdminLayout
@rendermode RenderMode.InteractiveServer
@implements IDisposable
@using System.Threading

<div class="min-h-screen bg-gray-50 flex flex-col font-sans">
    
    <!-- Mobil Header / Toolbar -->
    <div class="lg:hidden bg-white shadow-sm border-b border-gray-200 sticky top-0 z-30 px-4 py-3 flex justify-between items-center">
        <h1 class="text-lg font-bold text-gray-800 flex items-center gap-2">
            <i class="fas fa-shopping-cart text-blue-600"></i> Siparişler
        </h1>
    </div>

    <div class="flex-1 max-w-full">
        <div class="flex flex-col">
            
            <!-- Top Section: Stats & Header (Matching Categories.razor layout) -->
            <div class="hidden lg:grid lg:grid-cols-5 gap-x-2">
                
                <!-- Stats Column -->
                <div class="col-span-1 grid grid-cols-2 gap-3 mb-6">
                    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                        <div class="w-10 h-10 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center mb-2">
                            <i class="fas fa-clipboard-list"></i>
                        </div>
                        <div class="text-xs text-gray-500 font-medium">Toplam</div>
                        @if (isLoading)
                        {
                            <div class="flex items-center mt-2">
                                <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                            </div>
                        }
                        else
                        {
                            <div class="text-lg font-bold text-gray-800">@model.TotalCount</div>
                        }
                    </div>
                    <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                        <div class="w-10 h-10 rounded-full bg-orange-50 text-orange-600 flex items-center justify-center mb-2">
                            <i class="fas fa-clock"></i>
                        </div>
                        <div class="text-xs text-gray-500 font-medium">İşleniyor</div>
                        @if (isLoading)
                        {
                            <div class="flex items-center mt-2">
                                <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                            </div>
                        }
                        else
                        {
                            <div class="text-lg font-bold text-gray-800">@processingCount</div>
                        }
                    </div>
                </div>

                <!-- Page Header Column -->
                <div class="lg:col-span-4 lg:flex justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center text-lg">
                                <i class="fas fa-shopping-cart"></i>
                            </div>
                            Sipariş Yönetimi
                        </h1>
                        <p class="text-gray-500 text-sm mt-1 ml-[52px]">Siparişleri görüntüleyin, filtreleyin ve yönetin.</p>
                    </div>
                </div>
            </div>

            <!-- Filter Row -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 p-5">
                <div class="flex flex-col md:flex-row gap-4 items-end justify-between">
                    
                    <!-- Left: Filters Group -->
                    <div class="flex flex-col md:flex-row gap-4 flex-1">
                        <!-- Status Filter -->
                        <div class="w-full md:w-56"> 
                            <label class="block text-xs font-medium text-gray-700 mb-1">Durum</label>
                            <select @bind="model.FilterParams.Status" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                                <option value="">Tüm Durumlar</option>
                                @foreach (var status in Enum.GetValues<OrderStatus>())
                                {
                                    <option value="@status">@GetStatusLabel(status)</option>
                                }
                            </select>
                        </div>

                        <!-- Date Range -->
                        <div class="w-full md:w-44">
                            <label class="block text-xs font-medium text-gray-700 mb-1">Başlangıç Tarihi</label>
                            <input type="date" @bind="model.FilterParams.StartDate" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        </div>
                        <div class="w-full md:w-44">
                            <label class="block text-xs font-medium text-gray-700 mb-1">Bitiş Tarihi</label>
                            <input type="date" @bind="model.FilterParams.EndDate" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                        </div>
                    </div>

                    <!-- Right: Buttons Group -->
                    <div class="flex gap-2 w-full md:w-auto">
                        <button @onclick="ApplyFilters" class="flex-1 md:flex-none h-11 bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 rounded-lg transition-colors text-sm flex items-center justify-center gap-2">
                            <i class="fas fa-filter"></i> Uygula
                        </button>
                        <button @onclick="ClearFilters" class="flex-1 md:flex-none h-11 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-6 rounded-lg transition-colors text-sm flex items-center justify-center gap-2">
                            <i class="fas fa-times"></i> Temizle
                        </button>
                    </div>
                </div>
            </div>

            <!-- Content Area -->
            <div>
                 @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6 rounded shadow-sm">
                        <div class="flex">
                            <div class="flex-shrink-0">
                                <i class="fas fa-exclamation-circle text-red-500"></i>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-red-700">@errorMessage</p>
                            </div>
                        </div>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="flex justify-center items-center h-64 bg-white rounded-2xl shadow-sm border border-gray-100">
                        <div class="flex flex-col items-center gap-3">
                            <div class="w-10 h-10 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                            <span class="text-gray-500 font-medium">Yükleniyor...</span>
                        </div>
                    </div>
                }
                else
                {
                    <div id="orders-list-top"></div>
                    <AdminTable Items="model.Orders" Pagination="model.Pagination" OnPageChange="HandlePageChange" PageSize="@(model.FilterParams.PageSize)" OnPageSizeChange="HandlePageSizeChange">
                        <ToolbarContent>
                            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                                <div class="relative flex-1 sm:max-w-md">
                                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                        <i class="fas fa-search text-gray-400"></i>
                                    </div>
                                    <input type="text" 
                                            class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 sm:text-sm transition duration-150 ease-in-out"
                                            placeholder="Sipariş No veya Müşteri ara..."
                                            value="@searchTerm"
                                            @oninput="OnSearchInput">
                                </div>

                                <div class="hidden lg:flex items-center gap-2">
                                    <label for="orderSortOptions" class="text-sm font-medium text-gray-700 whitespace-nowrap">
                                        <i class="fa-solid fa-sort mr-1 text-gray-400"></i>Sırala:
                                    </label>
                                    <select id="orderSortOptions" 
                                            class="block w-auto pl-3 pr-10 py-2 text-base border border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md"
                                            value="@model.FilterParams.SortBy"
                                            @onchange="OnSortChange">
                                        <option value="date_desc">Tarih: Yeniden Eskiye</option>
                                        <option value="date_asc">Tarih: Eskiden Yeniye</option>
                                        <option value="amount_desc">Tutar: Yüksekten Düşüğe</option>
                                        <option value="amount_asc">Tutar: Düşükten Yükseğe</option>
                                    </select>
                                </div>
                            </div>
                        </ToolbarContent>
                        <HeaderTemplate>
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Sipariş No</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Müşteri</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Tarih</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Durum</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ödeme</th>
                                <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Tutar</th>
                                <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">İşlemler</th>
                            </tr>
                        </HeaderTemplate>
                        <RowTemplate Context="order">
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                @order.OrderNumber
                            </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <div class="flex items-center">
                                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold mr-3">
                                        @(order.FirstName.FirstOrDefault())@(order.LastName.FirstOrDefault())
                                    </div>
                                    <div>
                                        <div class="font-medium text-gray-900">@order.FirstName @order.LastName</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @order.OrderedAt.ToLocalTime().ToString("g")
                            </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full @GetStatusBadgeClass(order.OrderStatus)">
                                    @GetStatusLabel(order.OrderStatus)
                                </span>
                            </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full @GetPaymentStatusBadgeClass(order.PaymentStatus)">
                                    @GetPaymentStatusLabel(order.PaymentStatus)
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm text-gray-900 font-medium">
                                @order.TotalAmount.ToString("C2", new CultureInfo("tr-TR"))
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="/admin/orders/details/@order.OrderId" class="text-blue-600 hover:text-blue-900 font-medium transition-colors duration-200">
                                        <i class="fas fa-eye mr-1"></i> Detaylar
                                </a>
                            </td>
                        </RowTemplate>
                    </AdminTable>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private OrderListViewModelAdmin model = new();
    private bool isLoading = true;
    private string? errorMessage;
    private string searchTerm = "";
    private Timer? _debounceTimer;
    private int processingCount = 0;

    protected override async Task OnInitializedAsync()
    {
         model.FilterParams = Navigation.BindFromQuery<OrderFilterParametersAdmin>();
         if (model.FilterParams.PageSize == 0) model.FilterParams.PageSize = 10;
         searchTerm = model.FilterParams.SearchTerm ?? "";
         if (string.IsNullOrEmpty(model.FilterParams.SortBy)) model.FilterParams.SortBy = "date_desc";
         
         await LoadOrders();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        
        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                model.FilterParams.SearchTerm = searchTerm;
                await ApplyFilters();
            });
        }, null, 500, Timeout.Infinite);
    }

    private void OnSortChange(ChangeEventArgs e)
    {
        model.FilterParams.SortBy = e.Value?.ToString();
        ApplyFilters();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var result = await Service.GetAllAdminAsync(model.FilterParams);
            
            try {
                processingCount = await Service.CountOfInProcessAsync();
            } catch {}

            if (result.IsSuccess)
            {
                model.Orders = result.Data.orders.ToList();
                model.TotalCount = result.Data.count;
                model.Pagination = new Pagination
                {
                    CurrentPage = model.FilterParams.PageNumber,
                    ItemsPerPage = model.FilterParams.PageSize,
                    TotalItems = model.TotalCount
                };
            }
            else
            {
                errorMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Bir hata oluştu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ApplyFilters()
    {
        model.FilterParams.PageNumber = 1;
        UpdateUrl();
        await LoadOrders();
    }

    private async Task ClearFilters()
    {
        model.FilterParams = new OrderFilterParametersAdmin();
        model.FilterParams.SortBy = "date_desc"; 
        searchTerm = "";
        UpdateUrl();
        await LoadOrders();
    }

    private async Task HandlePageChange(int newPage)
    {
        model.FilterParams.PageNumber = newPage;
        UpdateUrl();
        await LoadOrders();
    }

    private async Task HandlePageSizeChange(int newSize)
    {
        model.FilterParams.PageSize = newSize;
        model.FilterParams.PageNumber = 1;
        UpdateUrl();
        await LoadOrders();
    }

    private void UpdateUrl()
    {
        var url = model.FilterParams.ToQueryString("/admin/orders");
        Navigation.NavigateTo(url!);
    }

    private string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Beklemede",
        OrderStatus.Processing => "İşleniyor",
        OrderStatus.Shipped => "Kargoya Verildi",
        OrderStatus.Delivered => "Teslim Edildi",
        OrderStatus.Cancelled => "İptal Edildi",
        OrderStatus.Returned => "İade Edildi",
        OrderStatus.Failed => "Başarısız",
        _ => status.ToString()
    };

    private string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-yellow-100 text-yellow-800",
        OrderStatus.Processing => "bg-blue-100 text-blue-800",
        OrderStatus.Shipped => "bg-purple-100 text-purple-800",
        OrderStatus.Delivered => "bg-green-100 text-green-800",
        OrderStatus.Cancelled => "bg-red-100 text-red-800",
        OrderStatus.Returned => "bg-orange-100 text-orange-800",
        OrderStatus.Failed => "bg-gray-100 text-gray-800",
        _ => "bg-gray-100 text-gray-800"
    };

    private string GetPaymentStatusLabel(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "Bekleniyor",
        PaymentStatus.Completed => "Ödendi",
        PaymentStatus.Failed => "Başarısız",
        PaymentStatus.Refunded => "İade",
        _ => status.ToString()
    };

    private string GetPaymentStatusBadgeClass(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "bg-yellow-100 text-yellow-800",
        PaymentStatus.Completed => "bg-green-100 text-green-800",
        PaymentStatus.Failed => "bg-red-100 text-red-800",
        PaymentStatus.Refunded => "bg-orange-100 text-orange-800",
        _ => "bg-gray-100 text-gray-800"
    };

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
