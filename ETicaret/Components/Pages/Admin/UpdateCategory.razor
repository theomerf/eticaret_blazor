@page "/admin/categories/update/{CategoryId:int}"
@using Application.DTOs
@using Domain.Entities
@using Application.Common.Helpers
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager
@inherits OwningComponentBase
@inject IJSRuntime JSRuntime

<HeadContent>
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.7/quill.js"></script>
    <script src="/js/quill-editor.js"></script>
</HeadContent>

@if (isLoading)
{
    <div class="flex items-center justify-center min-h-screen">
        <div class="text-center">
            <div class="w-16 h-16 border-4 border-blue-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
            <p class="text-gray-600">Kategori yükleniyor...</p>
        </div>
    </div>
}
else if (model == null)
{
    <div class="flex items-center justify-center min-h-screen">
        <div class="text-center bg-red-50 p-8 rounded-2xl border border-red-200">
            <i class="fas fa-exclamation-triangle text-red-500 text-5xl mb-4"></i>
            <h2 class="text-xl font-bold text-red-700 mb-2">Kategori Bulunamadı</h2>
            <p class="text-red-600 mb-4">Belirtilen kategori bulunamadı.</p>
            <a href="/admin/categories" class="inline-block px-6 py-3 bg-red-500 text-white rounded-xl font-semibold hover:bg-red-600 transition-all">
                <i class="fas fa-arrow-left mr-2"></i>Kategori Listesine Dön
            </a>
        </div>
    </div>
}
else
{
    <div class="container-fluid px-4 py-6">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-3">
                    <i class="fas fa-edit text-blue-500"></i>
                    Kategori Güncelle
                </h1>
                <p class="text-gray-500 mt-1">@model.CategoryName</p>
            </div>
            <a href="/admin/categories" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition-all">
                <i class="fas fa-arrow-left mr-2"></i>Geri Dön
            </a>
        </div>

        <EditForm Model="@model" OnValidSubmit="HandleUpdateCategory">
            <DataAnnotationsValidator />

            <!-- Validation Summary -->
            <ValidationSummary class="mt-6 mb-6 p-4 bg-red-50 rounded-xl border border-red-200 text-red-700" />

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Left Column - Main Content -->
                <div class="lg:col-span-2 space-y-6">

                    <!-- Basic Information -->
                    <AdminFormSection Title="Temel Bilgiler" Icon="fas fa-info-circle">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">
                                    Kategori Adı <span class="text-red-500">*</span>
                                </label>
                                <InputText @bind-Value="model.CategoryName"
                                           class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all"
                                           placeholder="Kategori adını girin..." />
                                <ValidationMessage For="@(() => model.CategoryName)" class="text-red-500 text-sm mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">
                                    Açıklama
                                </label>
                                <RichTextEditor @bind-Value="model.Description"
                                                Placeholder="Kategori hakkında detaylı bilgi yazın..."
                                                Height="200px" />
                            </div>
                            
                             <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">
                                    Simge URL (FontAwesome vb.)
                                </label>
                                <InputText @bind-Value="model.IconUrl"
                                           class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all"
                                           placeholder="Örn: fas fa-tshirt" />
                            </div>
                        </div>
                    </AdminFormSection>
                    
                    <!-- Category Attributes -->
                    <AdminFormSection Title="Kategori Özellikleri (Varyant & Teknik)" Icon="fas fa-sliders-h">
                        <div class="mb-6 bg-blue-50/50 p-4 rounded-xl border border-blue-100">
                            <label class="block text-sm font-bold text-gray-700 mb-2">Özellik Yönetimi</label>
                            <p class="text-xs text-gray-500 mb-3">Bu kategoriye ait ürünlerin sahip olabileceği varyant (renk, beden vb.) ve teknik özellikleri (işlemci, materyal vb.) buradan tanımlayabilirsiniz.</p>

                            <!-- Added Attributes List -->
                            @if (model.Attributes.Any())
                            {
                                <div class="mb-4 space-y-2">
                                    @foreach (var attr in model.Attributes)
                                    {
                                        <div class="flex items-center justify-between p-3 bg-white rounded-lg border border-gray-200 shadow-sm">
                                            <div class="flex items-center gap-3">
                                                 <div class="p-2 bg-gray-100 rounded text-gray-500">
                                                    <i class="fas @(attr.IsVariantDefiner ? "fa-tags" : "fa-info")"></i>
                                                </div>
                                                <div>
                                                    <h4 class="text-sm font-bold text-gray-800">@attr.DisplayName</h4>
                                                    <div class="flex gap-2 text-xs text-gray-500">
                                                        <span class="bg-gray-100 px-2 py-0.5 rounded">@attr.Key</span>
                                                        <span>•</span>
                                                        <span>@GetTypeName(attr.Type)</span>
                                                        @if(attr.IsVariantDefiner) { <span class="text-blue-600 font-medium">• Varyant Belirleyici</span> }
                                                        @if(attr.IsRequired) { <span class="text-red-500 font-medium">• Zorunlu</span> }
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <div class="flex items-center gap-2">
                                                <button type="button" @onclick="() => EditAttribute(attr)" class="text-blue-400 hover:text-blue-600 transition-colors p-2" title="Düzenle">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <button type="button" @onclick="() => RemoveAttribute(attr)" class="text-gray-400 hover:text-red-500 transition-colors p-2" title="Sil">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center p-4 text-gray-400 text-sm italic">
                                    Henüz özellik eklenmedi.
                                </div>
                            }

                            <!-- Add Attribute Form -->
                            <div class="mt-4 p-4 bg-white rounded-xl border border-gray-200 shadow-sm" id="attrForm">
                                <h4 class="text-sm font-bold text-gray-800 mb-3 border-b pb-2">
                                    @(editingAttribute != null ? "Özellik Düzenle" : "Yeni Özellik Ekle")
                                </h4>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    
                                    <div>
                                        <label class="block text-xs font-semibold text-gray-700 mb-1">Görünen Ad <span class="text-red-500">*</span></label>
                                        <InputText @bind-Value="tempAttribute.DisplayName" class="w-full px-3 py-2 border rounded-lg text-sm" placeholder="Örn: Materyal" />
                                    </div>
                                    
                                    @* Key is same as DisplayName *@
                                    <input type="hidden" @bind="tempAttribute.Key" />
                                    
                                    <div>
                                        <label class="block text-xs font-semibold text-gray-700 mb-1">Veri Tipi</label>
                                        <InputSelect @bind-Value="tempAttribute.Type" class="w-full px-3 py-2 border rounded-lg text-sm">
                                            <option value="@VariantAttributeType.Select">Seçim (Select)</option>
                                            <option value="@VariantAttributeType.String">Metin (String)</option>
                                            <option value="@VariantAttributeType.Number">Sayı (Number)</option>
                                            <option value="@VariantAttributeType.Color">Renk (Color)</option>
                                            <option value="@VariantAttributeType.Boolean">Mantıksal (Var/Yok)</option>
                                        </InputSelect>
                                    </div>

                                    <div class="flex flex-col justify-center gap-2">
                                         <label class="flex items-center gap-2 cursor-pointer">
                                            <input type="checkbox" @bind="tempAttribute.IsVariantDefiner" class="rounded text-blue-600 focus:ring-blue-500" />
                                            <span class="text-sm text-gray-700 font-medium">Varyant Belirleyici</span>
                                        </label>
                                        
                                         <label class="flex items-center gap-2 cursor-pointer mt-2">
                                            <input type="checkbox" @bind="tempAttribute.IsTechnicalSpec" class="rounded text-blue-600 focus:ring-blue-500" />
                                            <span class="text-sm text-gray-700 font-medium">Teknik Özellik</span>
                                        </label>
                                        
                                         <label class="flex items-center gap-2 cursor-pointer mt-2">
                                            <input type="checkbox" @bind="tempAttribute.IsRequired" class="rounded text-blue-600 focus:ring-blue-500" />
                                            <span class="text-sm text-gray-700 font-medium">Zorunlu Alan</span>
                                        </label>
                                    </div>

                                    <div class="md:col-span-2 pt-2 flex gap-2">
                                        <button type="button" @onclick="SaveAttribute" class="flex-1 py-2 bg-gray-800 hover:bg-gray-700 text-white rounded-lg text-sm font-medium transition-colors">
                                            <i class="fas fa-save mr-1"></i> @(editingAttribute != null ? "Güncelle" : "Listeye Ekle")
                                        </button>
                                        @if(editingAttribute != null)
                                        {
                                            <button type="button" @onclick="CancelEdit" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-lg text-sm font-medium transition-colors">
                                                İptal
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>

                        </div>
                    </AdminFormSection>

                    <!-- SEO Settings -->
                    <AdminFormSection Title="SEO Ayarları" Icon="fas fa-search">
                        <div class="space-y-4">
                            <div>
                                <SlugInput @bind-Value="model.Slug" SourceName="@model.CategoryName" Placeholder="ornek-kategori-adi" />
                            </div>

                            <div>
                                <SeoInput Label="Meta Başlık (Title)"
                                          Placeholder="Örn: Erkek Giyim Modelleri"
                                          @bind-Value="model.MetaTitle"
                                          AutoGeneratedValue="@model.CategoryName"
                                          MaxLength="60" />
                            </div>

                            <div>
                                <SeoInput Label="Meta Açıklama (Description)"
                                          Placeholder="Kategori açıklaması..."
                                          @bind-Value="model.MetaDescription"
                                          MaxLength="160"
                                          Rows="3" />
                            </div>
                        </div>
                    </AdminFormSection>
                </div>

                <!-- Right Column - Sidebar -->
                <div class="space-y-6">
                    <!-- Parent Category Selection -->
                    <AdminFormSection Title="Üst Kategori" Icon="fas fa-level-up-alt">
                         @if (rootCategories != null)
                         {
                             <div class="space-y-3">
                                 <InputSelect @bind-Value="model.ParentId" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all bg-white">
                                     <option value="">-- Yok (Ana Kategori) --</option>
                                     @foreach (var cat in rootCategories)
                                     {
                                         <option value="@cat.CategoryId">@cat.CategoryName</option>
                                     }
                                 </InputSelect>
                                 <p class="text-xs text-gray-500">
                                     <i class="fas fa-info-circle mr-1"></i>
                                     Sadece üst kategorisi olmayan (kök) kategoriler, ebeveyn olarak seçilebilir.
                                 </p>
                             </div>
                         }
                    </AdminFormSection>

                    <!-- Options -->
                    <AdminFormSection Title="Ayarlar" Icon="fas fa-cog">
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl border border-gray-200">
                                <label class="text-sm font-medium text-gray-700 cursor-pointer" for="isVisible">Görünürlük</label>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" @bind="model.IsVisible" id="isVisible" class="sr-only peer">
                                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                                </label>
                            </div>
                            
                            <div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl border border-gray-200">
                                 <label class="text-sm font-medium text-gray-700 cursor-pointer" for="isFeatured">Öne Çıkar</label>
                                <label class="relative inline-flex items-center cursor-pointer">
                                    <input type="checkbox" @bind="model.IsFeatured" id="isFeatured" class="sr-only peer">
                                    <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-yellow-500"></div>
                                </label>
                            </div>

                             <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Sıralama (Display Order)</label>
                                <InputNumber @bind-Value="model.DisplayOrder" class="w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all" />
                            </div>
                        </div>
                    </AdminFormSection>

                    <!-- Action Buttons -->
                    <div class="sticky bottom-0 bg-white rounded-2xl shadow-lg border border-gray-200 p-6 space-y-3">
                        <button type="submit"
                                disabled="@isSubmitting"
                                class="w-full bg-gradient-to-r from-green-500 to-emerald-500 text-white py-4 rounded-xl font-bold hover:from-green-600 hover:to-emerald-600 transition-all shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed">
                            @if (isSubmitting)
                            {
                                <span class="flex items-center justify-center gap-2">
                                    <span class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
                                    Güncelleniyor...
                                </span>
                            }
                            else
                            {
                                <span>
                                    <i class="fas fa-save mr-2"></i>Değişiklikleri Kaydet
                                </span>
                            }
                        </button>
                        <a href="/admin/categories"
                           class="block w-full text-center px-6 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition-all">
                            <i class="fas fa-times mr-2"></i>İptal
                        </a>
                    </div>
                </div>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter]
    public int CategoryId { get; set; }

    private CategoryDtoForUpdate model = null!;
    private CategoryVariantAttributeDtoForUpdate tempAttribute = new();
    private CategoryVariantAttributeDtoForUpdate? editingAttribute; 
    
    private List<CategoryDto> rootCategories = new();
    private ICategoryService _categoryService = null!;
    private bool isLoading = true;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        _categoryService = ScopedServices.GetRequiredService<ICategoryService>();
        
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            // Load Category
            var category = await _categoryService.GetByIdAsync(CategoryId);
            
            model = new CategoryDtoForUpdate
            {
                CategoryId = category.CategoryId,
                CategoryName = category.CategoryName,
                Slug = category.Slug,
                MetaTitle = category.MetaTitle,
                MetaDescription = category.MetaDescription,
                Description = category.Description,
                IconUrl = category.IconUrl,
                ParentId = category.ParentId,
                DisplayOrder = category.DisplayOrder,
                IsVisible = category.IsVisible,
                IsFeatured = category.IsFeatured,
                Attributes = new List<CategoryVariantAttributeDtoForUpdate>()
            };

            // Load Attributes
            var attributes = await _categoryService.GetAttributesAsync(CategoryId);
            foreach(var attr in attributes)
            {
                model.Attributes.Add(new CategoryVariantAttributeDtoForUpdate
                {
                    VariantAttributeId = attr.VariantAttributeId,
                    CategoryId = attr.CategoryId,
                    Key = attr.Key,
                    DisplayName = attr.DisplayName,
                    Type = attr.Type,
                    IsVariantDefiner = attr.IsVariantDefiner,
                    IsTechnicalSpec = attr.IsTechnicalSpec,
                    IsRequired = attr.IsRequired,
                    SortOrder = attr.SortOrder
                });
            }

            // Load Parent Categories (Roots only, exclude self)
            var allCategories = await _categoryService.GetAllAsync();
            rootCategories = allCategories.Where(c => c.ParentId == null && c.CategoryId != CategoryId).ToList();

            ResetTempAttribute();
        }
        catch(Exception)
        {
             // Handle error
             model = null!;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SaveAttribute()
    {
        if (string.IsNullOrWhiteSpace(tempAttribute.DisplayName)) return;

        // Key is same as DisplayName
        if (editingAttribute == null || editingAttribute.VariantAttributeId == 0)
        {
            tempAttribute.Key = tempAttribute.DisplayName;
        }

        // Check for duplicate key (excluding self)
        if(model.Attributes.Any(a => a.Key == tempAttribute.Key && a != editingAttribute))
        {
             // Warn duplicate
             return;
        }

        if (editingAttribute != null)
        {
            // Update existing in list
             editingAttribute.DisplayName = tempAttribute.DisplayName;
             // Key is usually read-only for existing attributes to prevent breaking variants, but if it's new (ID=0) we can change it.
             if(editingAttribute.VariantAttributeId == 0) editingAttribute.Key = tempAttribute.Key;
             
             editingAttribute.Type = tempAttribute.Type;
             editingAttribute.IsVariantDefiner = tempAttribute.IsVariantDefiner;
             editingAttribute.IsTechnicalSpec = tempAttribute.IsTechnicalSpec;
             editingAttribute.IsRequired = tempAttribute.IsRequired;
             
             editingAttribute = null;
        }
        else
        {
            // Add new
            model.Attributes.Add(new CategoryVariantAttributeDtoForUpdate
            {
                 DisplayName = tempAttribute.DisplayName,
                 Key = tempAttribute.Key,
                 Type = tempAttribute.Type,
                 IsRequired = tempAttribute.IsRequired,
                 IsVariantDefiner = tempAttribute.IsVariantDefiner,
                 IsTechnicalSpec = tempAttribute.IsTechnicalSpec,
                 SortOrder = model.Attributes.Count + 1,
                 VariantAttributeId = 0 // New
            });
        }

        ResetTempAttribute();
    }
    
    private void EditAttribute(CategoryVariantAttributeDtoForUpdate attr)
    {
        editingAttribute = attr;
        tempAttribute = new CategoryVariantAttributeDtoForUpdate
        {
             DisplayName = attr.DisplayName,
             Key = attr.Key,
             Type = attr.Type,
             IsRequired = attr.IsRequired,
             IsVariantDefiner = attr.IsVariantDefiner,
             IsTechnicalSpec = attr.IsTechnicalSpec,
             VariantAttributeId = attr.VariantAttributeId
        };
        // Scroll to form?
    }

    private void CancelEdit()
    {
        editingAttribute = null;
        ResetTempAttribute();
    }

    private void RemoveAttribute(CategoryVariantAttributeDtoForUpdate attr)
    {
        model.Attributes.Remove(attr);
    }
    
    private void ResetTempAttribute()
    {
        tempAttribute = new CategoryVariantAttributeDtoForUpdate
        {
            Type = VariantAttributeType.Select,
            IsVariantDefiner = true,
            IsRequired = true
        };
    }
    
    private string GetTypeName(VariantAttributeType type)
    {
        return type switch
        {
            VariantAttributeType.Select => "Seçim Listesi",
            VariantAttributeType.String => "Metin",
            VariantAttributeType.Number => "Sayı",
            VariantAttributeType.Color => "Renk",
            VariantAttributeType.Boolean => "Mantıksal",
            _ => type.ToString()
        };
    }

    private async Task HandleUpdateCategory()
    {
        isSubmitting = true;
        StateHasChanged();

        var result = await _categoryService.UpdateAsync(model);

        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo("/admin/categories");
            await JSRuntime.InvokeVoidAsync("showToast", "Kategori başarıyla güncellendi.", "success");
        }
        else
        {
             await JSRuntime.InvokeVoidAsync("showToast", $"Hata: {result.Message}", "error");
        }

        isSubmitting = false;
    }
}
