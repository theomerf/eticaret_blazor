@page "/admin"
@page "/admin/dashboard"
@using Application.DTOs
@using Microsoft.AspNetCore.Authorization
@inject ETicaret.Services.INotificationService NotificationService
@inherits OwningComponentBase
@inject IJSRuntime JSRuntime
@implements IDisposable
@attribute [Authorize(Roles = "Admin")]

<div class="bg-primary text-white rounded-3xl p-6 md:p-8 shadow-[0_20px_50px_rgba(0,0,0,0.15)] mb-8 relative overflow-hidden animate-slideDown">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-80 h-80 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-60 h-60 bg-black/10 rounded-full blur-2xl pointer-events-none"></div>

    <div class="flex flex-col md:flex-row justify-between items-center relative z-10 gap-6">
        <div>
            <h1 class="text-3xl md:text-4xl font-bold flex items-center gap-3">
                <span class="bg-white/20 p-2 rounded-xl backdrop-blur-sm shadow-inner">
                    <i class="fas fa-gauge"></i>
                </span>
                Admin Gösterge Paneli
            </h1>
            <p class="opacity-90 text-lg mt-3 font-medium max-w-2xl text-blue-50">Hoş geldiniz! İşletmenizin genel durumunu, siparişleri ve analizleri buradan takip edebilirsiniz.</p>
        </div>
        <div class="text-right">
            <div class="bg-white/10 backdrop-blur-md text-white rounded-2xl p-4 text-center border border-white/20 shadow-lg hover:bg-white/20 transition-all duration-300 cursor-default">
                <i class="fas fa-sun text-4xl mb-2 text-yellow-300 drop-shadow-md animate-pulse"></i>
                <div class="text-2xl font-bold">24°C</div>
                <small class="text-blue-100 font-semibold tracking-wide">Bursa, Türkiye</small>
            </div>
        </div>
    </div>
</div>

<DashboardPanels IsLoading="isLoading" 
                 CategoriesCount="categoriesCount" 
                 ProductsCount="productsCount" 
                 OrdersInProcessCount="ordersInProcessCount" 
                 UsersCount="usersCount" 
                 ReviewsCount="reviewsCount" 
                 RolesCount="rolesCount"
                 RecentActivities="recentActivities"
                 TopSellingProducts="topSellingProducts"
                 SystemStatus="systemStatus"/>

<Showcase Products="showcaseProducts" IsLoading="isLoading"/>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private IProductService? _productService;
    private ICategoryService? _categoryService;
    private IAuthService? _authService;
    private IOrderService? _orderService;
    private IUserReviewService? _userReviewService;
    private IActivityService? _activityService;
    private ISystemService? _systemService;

    private CancellationTokenSource? _cts;

    private string? firstName;
    private string? lastName;
    private bool isLoading = false;

    private int? productsCount;
    private int? categoriesCount;
    private int? usersCount;
    private int? ordersInProcessCount;
    private int? reviewsCount;
    private int? rolesCount;
    private IEnumerable<ActivityDto> recentActivities = new List<ActivityDto>();
    private IEnumerable<ProductDto> showcaseProducts = new List<ProductDto>();
    private IEnumerable<ProductSalesDto> topSellingProducts = new List<ProductSalesDto>();
    private SystemStatusDto? systemStatus;

    protected override async Task OnInitializedAsync()
    {
        _productService = ScopedServices.GetRequiredService<IProductService>();
        _categoryService = ScopedServices.GetRequiredService<ICategoryService>();
        _authService = ScopedServices.GetRequiredService<IAuthService>();
        _orderService = ScopedServices.GetRequiredService<IOrderService>();
        _userReviewService = ScopedServices.GetRequiredService<IUserReviewService>();
        _activityService = ScopedServices.GetRequiredService<IActivityService>();
        _systemService = ScopedServices.GetRequiredService<ISystemService>();

        NotificationService.Clear();
        isLoading = true;

        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                firstName = user.FindFirst("first_name")?.Value;
                lastName = user.FindFirst("last_name")?.Value;
            }
        }

        var welcomeShown = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "dashboardWelcomeShown");

        if (string.IsNullOrEmpty(welcomeShown))
        {
            await JSRuntime.InvokeVoidAsync("showToast", $"Tekrar Hoşgeldiniz {firstName} {lastName}, Saat: {DateTime.Now.ToShortTimeString()}", "info");
            await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "dashboardWelcomeShown", "true");
        }

        _cts = new CancellationTokenSource();

        try
        {
            await LoadDashboardDatasAsync(_cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        isLoading = false;
    }

    private async Task LoadDashboardDatasAsync(CancellationToken ct)
    {
        if (_productService != null) productsCount = await _productService.CountAsync(ct);
        if (ct.IsCancellationRequested) return;
        
        if (_categoryService != null) categoriesCount = await _categoryService.CountAsync(ct);
        if (ct.IsCancellationRequested) return;

        if (_authService != null) usersCount = await _authService.GetUsersCountAsync(ct);
        if (ct.IsCancellationRequested) return;

        if (_orderService != null) ordersInProcessCount = await _orderService.CountOfInProcessAsync(ct);
        if (ct.IsCancellationRequested) return;

        if (_userReviewService != null) reviewsCount = await _userReviewService.CountAsync(ct);
        if (ct.IsCancellationRequested) return;

        if (_authService != null) rolesCount = await _authService.GetRolesCountAsync(ct);
        if (ct.IsCancellationRequested) return;

        if (_activityService != null) recentActivities = await _activityService.GetRecentAsync(5, ct);
        if (ct.IsCancellationRequested) return;

        if (_productService != null) showcaseProducts = await _productService.GetShowcaseListAsync(ct);
        if (ct.IsCancellationRequested) return;

        if (_orderService != null) topSellingProducts = await _orderService.GetTopSellingProductsAsync(4, ct);
        if (ct.IsCancellationRequested) return;

        if (_systemService != null) systemStatus = await _systemService.GetSystemStatusAsync(ct);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }
}
