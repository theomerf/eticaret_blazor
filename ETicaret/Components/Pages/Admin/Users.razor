@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@using Application.DTOs
@using Application.Queries.RequestParameters
@using ETicaret.Models
@using ETicaret.Extensions
@using Domain.Entities
@using Microsoft.AspNetCore.Identity
@inherits OwningComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@layout AdminLayout
@implements IDisposable

<div class="flex flex-col">
    <div class="hidden lg:grid lg:grid-cols-5 gap-x-2">
        <div class="col-span-1 grid grid-cols-2 gap-3 mb-6">
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center mb-2">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <div class="text-xs text-gray-500 font-medium">Toplam</div>
                @if (isLoading)
                {
                    <div class="flex items-center mt-2">
                        <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                }
                else
                {
                    <div class="text-lg font-bold text-gray-800">@model.TotalCount</div>
                }
            </div>
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-green-50 text-green-600 flex items-center justify-center mb-2">
                    <i class="fas fa-user-check"></i>
                </div>
                <div class="text-xs text-gray-500 font-medium">Aktif</div>
                @if (isLoading)
                {
                    <div class="flex items-center mt-2">
                        <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                }
                else
                {
                    <div class="text-lg font-bold text-gray-800">@activeUserCount</div>
                }
            </div>
        </div>

        <div class="lg:col-span-4 lg:flex justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
            <div>
                <div id="users-list-top"></div>
                <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-secondary flex items-center justify-center text-lg">
                        <i class="fas fa-users-cog"></i>
                    </div>
                    Kullanıcı Yönetimi
                </h1>
                <p class="text-gray-500 text-sm mt-1 ml-[52px]">Sistemdeki kullanıcıları görüntüleyin, filtreleyin ve yönetin.</p>
            </div>
        </div>
    </div>

    @if (!isLoading)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 p-5">
            <div class="flex flex-col md:flex-row gap-4 items-end justify-between">
                <div class="flex flex-col md:flex-row gap-4 flex-1">
                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Rol</label>
                        <select @bind="model.FilterParams.Role" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="">Tümü</option>
                            @if (roles != null)
                            {
                                @foreach (var role in roles)
                                {
                                    <option value="@role.Name">@role.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Durum</label>
                        <select value="@GetIsActiveFilterValue()" @onchange="OnIsActiveFilterChange" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="true">Aktif</option>
                            <option value="false">Pasif</option>
                        </select>
                    </div>
                </div>

                <div class="flex gap-2 w-full md:w-auto">
                    <button @onclick="ApplyFilters" class="flex-1 md:flex-none h-11 bg-button hover:bg-button-hover text-white font-medium px-6 rounded-lg transition-all hover:-translate-y-0.5 text-sm flex items-center justify-center gap-2">
                        <i class="fas fa-filter"></i> Filtrele
                    </button>
                    <button @onclick="ClearFilters" class="flex-1 md:flex-none h-11 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-6 rounded-lg transition-all hover:-translate-y-0.5 text-sm flex items-center justify-center gap-2">
                        <i class="fas fa-times"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="flex flex-col items-center gap-3">
                <div class="w-10 h-10 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                <span class="text-gray-500 font-medium">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <AdminTable TItem="UserDto"
                    Items="model.Users"
                    Pagination="model.Pagination"
                    OnPageChange="HandlePageChange"
                    PageSize="@(model.FilterParams.PageSize)"
                    OnPageSizeChange="HandlePageSizeChange">
            <ToolbarContent>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div class="relative flex-1 sm:max-w-md">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-400"></i>
                        </div>
                        <input type="text"
                               class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 sm:text-sm transition duration-150 ease-in-out"
                               placeholder="İsim, e-posta veya telefon ara..."
                               value="@searchTerm"
                               @oninput="OnSearchInput"
                               @onkeydown="HandleSearchKeyDown">
                    </div>

                    <div class="hidden lg:flex items-center gap-2">
                        <label for="userSortOptions" class="text-sm font-medium text-gray-700 whitespace-nowrap">
                            <i class="fa-solid fa-sort mr-1 text-gray-400"></i>Sırala:
                        </label>
                        <select id="userSortOptions"
                                class="block w-auto pl-3 pr-10 py-2 text-base border border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md"
                                value="@model.FilterParams.SortBy"
                                @onchange="HandleSortChange">
                            <option value="date_desc">En Yeni</option>
                            <option value="date_asc">En Eski</option>
                            <option value="name_asc">İsim (A-Z)</option>
                            <option value="name_desc">İsim (Z-A)</option>
                            <option value="login_desc">Son Giriş</option>
                        </select>
                    </div>
                </div>
            </ToolbarContent>

            <HeaderTemplate>
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kullanıcı</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">E-posta</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Roller</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Durum</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden xl:table-cell">Son Giriş</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">İşlemler</th>
                </tr>
            </HeaderTemplate>

            <RowTemplate Context="user">
                <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                        <div class="rounded-full overflow-hidden transition-all duration-400 hover:scale-110 shadow-lg border-2 border-white/20 w-8 h-8 sm:w-9 sm:h-9 flex items-center justify-center bg-cyan-500 text-white font-bold text-sm flex-shrink-0">
                            @(user.FirstName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                        </div>
                        <div class="min-w-0">
                            <p class="text-sm font-semibold text-gray-800 truncate">@user.FirstName @user.LastName</p>
                            <p class="text-xs text-gray-400 truncate md:hidden">@user.Email</p>
                        </div>
                    </div>
                </td>

                <td class="px-4 py-3 hidden md:table-cell">
                    <div class="flex items-center gap-1.5">
                        <span class="text-sm text-gray-700 truncate max-w-[200px]">@user.Email</span>
                        @if (user.EmailConfirmed)
                        {
                            <i class="fas fa-check-circle text-green-500 text-xs tooltip" data-tooltip="Doğrulanmış"></i>
                        }
                        else
                        {
                            <i class="fas fa-exclamation-circle text-amber-500 text-xs tooltip" data-tooltip="Doğrulanmamış"></i>
                        }
                    </div>
                </td>

                <td class="px-4 py-3 hidden lg:table-cell">
                    <div class="flex flex-wrap gap-1">
                        @foreach (var role in user.Roles)
                        {
                            <span class="px-3 py-1.5 inline-flex text-xs leading-5 font-semibold rounded-full @GetRoleBadgeClass(role)">
                                @role
                            </span>
                        }
                    </div>
                </td>

                <td class="px-4 py-3 text-center">
                    <label data-tooltip="@(user.IsActive ? "Pasif Yap" : "Aktif Yap")" class="tooltip relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" class="sr-only peer" checked="@user.IsActive"
                               @onclick="() => ToggleActive(user)">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </td>

                <td class="px-4 py-3 hidden xl:table-cell">
                    <span class="text-sm text-gray-600">
                        @if (user.LastLoginDate.HasValue)
                        {
                            @user.LastLoginDate.Value.ToString("dd.MM.yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-gray-400">—</span>
                        }
                    </span>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="relative inline-block text-left">
                        <button @onclick="() => ToggleDropdown(user.Id)"
                                @onblur="@(async () => { await Task.Delay(100); CloseDropdown(user.Id); })"
                                class="p-2 rounded-lg hover:bg-gray-100 transition-colors text-gray-500 focus:outline-none">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>

                        @if (openDropdownId == user.Id)
                        {
                            <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-200 z-[1000] py-1 animate-fade-in origin-top-right">
                                <button @onclick="() => OpenEditModal(user)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Kullanıcı bilgilerini düzenle">
                                    <i class="fas fa-pen text-blue-500 w-4 text-center"></i> Düzenle
                                </button>
                                <button @onclick="() => OpenRoleModal(user)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Kullanıcı rollerini yönet">
                                    <i class="fas fa-user-shield text-purple-500 w-4 text-center"></i> Rol Değiştir
                                </button>
                                @if (!user.EmailConfirmed)
                                {
                                    <button @onclick="() => VerifyEmail(user)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="E-posta adresini manuel doğrula">
                                        <i class="fas fa-envelope-circle-check text-green-500 w-4 text-center"></i> E-posta Doğrula
                                    </button>
                                }
                                <button @onclick="() => GenerateResetLink(user)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Şifre sıfırlama bağlantısı oluştur">
                                    <i class="fas fa-key text-amber-500 w-4 text-center"></i> Şifre Sıfırlama Linki
                                </button>
                                <button @onclick="() => OpenNoteModal(user)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Yönetici notlarını görüntüle/düzenle">
                                    <i class="fas fa-sticky-note text-teal-500 w-4 text-center"></i> Admin Notu
                                </button>
                                <button @onclick="() => NavigateToDetails(user.Id)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Kullanıcı detaylarını görüntüle">
                                    <i class="fas fa-eye text-indigo-500 w-4 text-center"></i> Detaylar
                                </button>
                                <button @onclick="() => ImpersonateUser(user)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Kullanıcı hesabına giriş yap">
                                    <i class="fas fa-user-secret text-amber-500 w-4 text-center"></i> Oturum Aç
                                </button>
                                <div class="border-t border-gray-100 my-1"></div>
                                <button @onclick="() => DeleteUser(user)" class="w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2.5 transition-colors tooltip" data-tooltip="Kullanıcıyı kalıcı olarak sil">
                                    <i class="fas fa-trash text-red-500 w-4 text-center"></i> Sil
                                </button>
                            </div>
                        }
                    </div>
                </td>
            </RowTemplate>
        </AdminTable>
    }
</div>

@* Edit User Modal *@
@if (showEditModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Kullanıcı Düzenle</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <EditForm Model="editModel" OnValidSubmit="SaveEdit" class="p-6 space-y-4">
                <DataAnnotationsValidator />
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">İsim</label>
                    <InputText @bind-Value="editModel.FirstName" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    <ValidationMessage For="@(() => editModel.FirstName)" class="text-red-500 text-xs mt-1" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Soyisim</label>
                    <InputText @bind-Value="editModel.LastName" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    <ValidationMessage For="@(() => editModel.LastName)" class="text-red-500 text-xs mt-1" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Telefon</label>
                    <InputText @bind-Value="editModel.PhoneNumber" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    <ValidationMessage For="@(() => editModel.PhoneNumber)" class="text-red-500 text-xs mt-1" />
                </div>
                <div class="flex justify-end gap-3 pt-3">
                    <button type="button" @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">Vazgeç</button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm hover:bg-button-hover disabled:opacity-50">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin mr-1"></i>
                        }
     Kaydet
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@* Role Change Modal *@
@if (showRoleModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Rol Değiştir</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-600 mb-4">
                    <span class="font-semibold">@selectedUser?.FirstName @selectedUser?.LastName</span> kullanıcısı için rolleri seçin:
                </p>
                <div class="space-y-2">
                    @if (roles != null)
                    {
                        @foreach (var role in roles)
                        {
                            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer transition-colors">
                                <input type="checkbox"
                                       checked="@selectedRoles.Contains(role.Name!)"
                                       @onchange="(e) => ToggleRole(role.Name!, (bool)e.Value!)"
                                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                                <span class="text-sm font-medium text-gray-700">@role.Name</span>
                            </label>
                        }
                    }
                </div>
                <div class="flex justify-end gap-3 pt-5">
                    <button @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">Vazgeç</button>
                    <button @onclick="SaveRoles" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm hover:bg-button-hover disabled:opacity-50">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin mr-1"></i>
                        }
     Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Admin Note Modal *@
@if (showNoteModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Admin Notu</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-600 mb-3">
                    <span class="font-semibold">@selectedUser?.FirstName @selectedUser?.LastName</span> için admin notu:
                </p>
                <textarea @bind="adminNoteText" rows="4" maxlength="1000"
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-none"
                          placeholder="Bu kullanıcı hakkında not ekleyin..."></textarea>
                <p class="text-xs text-gray-400 mt-1 text-right">@(adminNoteText?.Length ?? 0)/1000</p>
                <div class="flex justify-end gap-3 pt-3">
                    <button @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">Vazgeç</button>
                    <button @onclick="SaveNote" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm hover:bg-button-hover disabled:opacity-50">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin mr-1"></i>
                        }
     Kaydet
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Password Reset Link Modal *@
@if (showResetLinkModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Şifre Sıfırlama Linki</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6">
                <p class="text-sm text-gray-600 mb-3">Oluşturulan şifre sıfırlama linki:</p>
                <div class="flex items-center gap-2">
                    <input type="text" readonly value="@resetLink" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-xs bg-gray-50 text-gray-600" />
                    <button @onclick="CopyResetLink" class="px-3 py-2 rounded-lg bg-blue-500 text-white text-sm hover:bg-blue-600 flex-shrink-0">
                        <i class="fas fa-copy"></i>
                    </button>
                </div>
                <div class="flex justify-end pt-4">
                    <button @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

<div id="loadingOverlay"
     class="fixed inset-0 bg-black/30 z-[9999] flex justify-center items-center backdrop-blur-sm transition-opacity duration-300 @(showLoadingOverlay ? "opacity-100 pointer-events-auto" : "opacity-0 pointer-events-none")">
    <div class="bg-white rounded-2xl p-6 text-center shadow-2xl transform transition-transform duration-300 @(showLoadingOverlay ? "scale-100" : "scale-95")">
        <div class="w-12 h-12 border-4 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <div class="text-gray-800 font-semibold">Filtreler uygulanıyor...</div>
    </div>
</div>

<form method="post" action="/account/impersonate" id="impersonateForm" class="hidden">
    <input type="hidden" name="userId" value="@impersonateUserId" />
</form>

@code {
    private IAuthService? _authService;
    private IUserService? _userService;

    private UserListViewModelAdmin model = new();
    private UserRequestParametersAdmin _lastParams = new();
    private IEnumerable<Role>? roles;
    private bool isLoading = true;
    private bool showLoadingOverlay = false;
    private bool isSaving = false;
    private int activeUserCount;
    private string? openDropdownId;
    private string searchTerm = "";
    private Timer? _debounceTimer;

    private CancellationTokenSource? _cts;

    private bool showEditModal = false;
    private UserDtoForAdminEdit editModel = new();

    private bool showRoleModal = false;
    private HashSet<string> selectedRoles = new();

    private bool showNoteModal = false;
    private string? adminNoteText;

    private bool showResetLinkModal = false;
    private string? resetLink;

    private UserDto? selectedUser;

    protected override async Task OnInitializedAsync()
    {
        _authService = ScopedServices.GetRequiredService<IAuthService>();
        _userService = ScopedServices.GetRequiredService<IUserService>();

        isLoading = true;
        model.FilterParams = Navigation.BindFromQuery<UserRequestParametersAdmin>();
        if (string.IsNullOrWhiteSpace(model.FilterParams.SortBy))
            model.FilterParams.SortBy = "date_desc";

        _cts = new CancellationTokenSource();
        await LoadUsers(_cts.Token);

        _cts = new CancellationTokenSource();
        if (_userService != null) roles = await _userService.GetRolesAsync(_cts.Token);

        isLoading = false;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var newParams = Navigation.BindFromQuery<UserRequestParametersAdmin>();

        if (_lastParams != null && _lastParams.Equals(newParams))
            return;

        _lastParams = newParams with { };

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        await InvokeAsync(async () =>
        {
            showLoadingOverlay = true;
            StateHasChanged();

            model.FilterParams = newParams;
            if (string.IsNullOrWhiteSpace(model.FilterParams.SortBy))
                model.FilterParams.SortBy = "date_desc";

            await LoadUsers(token);

            if (token.IsCancellationRequested) return;

            showLoadingOverlay = false;
            StateHasChanged();

            await JSRuntime.InvokeVoidAsync("scrollToElement", "users-list-top");
        });
    }

    private async Task LoadUsers(CancellationToken ct)
    {
        if (_userService == null) return;

        try
        {
            if (model.FilterParams.PageSize == 0) model.FilterParams.PageSize = 10;

            var result = await _userService.GetAllUsersAdminAsync(model.FilterParams, ct);

            if (ct.IsCancellationRequested) return;

            var pagination = new Pagination
            {
                CurrentPage = model.FilterParams.PageNumber,
                ItemsPerPage = model.FilterParams.PageSize,
                TotalItems = result.count
            };

            model = new UserListViewModelAdmin()
            {
                Users = result.users,
                Pagination = pagination,
                TotalCount = result.count,
                FilterParams = model.FilterParams
            };

            activeUserCount = result.activeCount;
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void UpdateUrl()
    {
        var url = model.FilterParams.ToQueryString("/admin/users");
        Navigation.NavigateTo(url!);
    }

    private async Task ApplyFilters()
    {
        model.FilterParams = model.FilterParams with { PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        model.FilterParams = new UserRequestParametersAdmin { SortBy = "date_desc" };
        searchTerm = "";
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandleSortChange(ChangeEventArgs e)
    {
        model.FilterParams = model.FilterParams with { SortBy = e.Value?.ToString(), PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";

        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                model.FilterParams = model.FilterParams with { SearchTerm = searchTerm, PageNumber = 1 };
                UpdateUrl();
            });
        }, null, 500, Timeout.Infinite);
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            model.FilterParams = model.FilterParams with { PageNumber = 1 };
            UpdateUrl();
            await Task.CompletedTask;
        }
    }

    private async Task HandlePageChange(int newPage)
    {
        model.FilterParams = model.FilterParams with { PageNumber = newPage };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandlePageSizeChange(int newSize)
    {
        model.FilterParams = model.FilterParams with { PageSize = newSize, PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private string GetIsActiveFilterValue()
    {
        return model.FilterParams.IsActive.HasValue
            ? model.FilterParams.IsActive.Value.ToString().ToLower()
            : "";
    }

    private void OnIsActiveFilterChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        model.FilterParams = model.FilterParams with
        {
            IsActive = string.IsNullOrWhiteSpace(value) ? null : bool.Parse(value)
        };
    }

    // Actions

    private async Task ToggleActive(UserDto user)
    {
        if (_userService == null) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm",
            $"{user.FirstName} {user.LastName} kullanıcısını {(user.IsActive ? "pasif" : "aktif")} yapmak istediğinize emin misiniz?");

        if (!confirmed) return;

        var result = await _userService.ToggleUserActiveAsync(user.Id);

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            await LoadUsers(_cts.Token);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private async Task VerifyEmail(UserDto user)
    {
        if (_authService == null) return;
        CloseDropdown(null);

        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm",
            $"{user.Email} adresini doğrulamak istediğinize emin misiniz?");

        if (!confirmed) return;

        var result = await _authService.VerifyEmailAsync(user.Id);
        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            await LoadUsers(_cts.Token);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private async Task GenerateResetLink(UserDto user)
    {
        if (_authService == null) return;
        CloseDropdown(null);

        var result = await _authService.GeneratePasswordResetLinkAsync(user.Id);
        if (result.IsSuccess)
        {
            resetLink = result.Data;
            showResetLinkModal = true;
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private async Task DeleteUser(UserDto user)
    {
        if (_userService == null) return;
        CloseDropdown(null);

        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm",
            $"{user.FirstName} {user.LastName} kullanıcısını silmek istediğinize emin misiniz? Bu işlem geri alınamaz.");

        if (!confirmed) return;

        var result = await _userService.DeleteUserAsync(user.Id);

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            await LoadUsers(_cts.Token);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    // Modals

    private void OpenEditModal(UserDto user)
    {
        CloseDropdown(null);
        selectedUser = user;
        editModel = new UserDtoForAdminEdit
        {
            Id = user.Id,
            FirstName = user.FirstName,
            LastName = user.LastName,
            PhoneNumber = user.PhoneNumber ?? ""
        };
        showEditModal = true;
    }

    private async Task SaveEdit()
    {
        if (_userService == null) return;

        isSaving = true;
        var result = await _userService.EditUserInfoAsync(editModel);
        isSaving = false;

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
            CloseModals();

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            await LoadUsers(_cts.Token);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private void OpenRoleModal(UserDto user)
    {
        CloseDropdown(null);
        selectedUser = user;
        selectedRoles = new HashSet<string>(user.Roles);
        showRoleModal = true;
    }

    private void ToggleRole(string roleName, bool isChecked)
    {
        if (isChecked) selectedRoles.Add(roleName);
        else selectedRoles.Remove(roleName);
    }

    private async Task SaveRoles()
    {
        if (_userService == null) return;
        if (selectedUser == null) return;

        isSaving = true;
        var result = await _userService.ChangeUserRolesAsync(selectedUser.Id, selectedRoles);
        isSaving = false;

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
            CloseModals();

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            await LoadUsers(_cts.Token);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private void OpenNoteModal(UserDto user)
    {
        CloseDropdown(null);
        selectedUser = user;
        adminNoteText = user.AdminNotes ?? "";
        showNoteModal = true;
    }

    private async Task SaveNote()
    {
        if (_userService == null) return;
        if (selectedUser == null) return;

        isSaving = true;
        var result = await _userService.UpdateAdminNotesAsync(selectedUser.Id, adminNoteText ?? "");
        isSaving = false;

        if (result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
            CloseModals();

            _cts?.Cancel();
            _cts?.Dispose();
            _cts = new CancellationTokenSource();
            await LoadUsers(_cts.Token);
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private async Task CopyResetLink()
    {
        if (!string.IsNullOrEmpty(resetLink))
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", resetLink);
            await JSRuntime.InvokeVoidAsync("showToast", "Link panoya kopyalandı!", "success");
        }
    }

    // Helpers

    private void NavigateToDetails(string userId) => Navigation.NavigateTo($"/admin/users/details/{userId}");
    private string? impersonateUserId;

    private async Task ImpersonateUser(UserDto user)
    {
        CloseDropdown(null);

        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm",
            $"{user.FirstName} {user.LastName} kullanıcısı olarak oturum açmak istediğinize emin misiniz?");

        if (!confirmed) return;

        impersonateUserId = user.Id;
        StateHasChanged();
        await Task.Delay(50);

        await JSRuntime.InvokeVoidAsync("eval", @"
            var token = document.getElementById('__GlobalRequestVerificationToken').value;
            var form = document.getElementById('impersonateForm');
            var tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            form.appendChild(tokenInput);
            form.submit();
        ");
    }

    private void ToggleDropdown(string userId)
    {
        openDropdownId = openDropdownId == userId ? null : userId;
    }

    private void CloseDropdown(string? _)
    {
        openDropdownId = null;
    }

    private void CloseModals()
    {
        showEditModal = false;
        showRoleModal = false;
        showNoteModal = false;
        showResetLinkModal = false;
        selectedUser = null;
    }

    private string GetRoleBadgeClass(string role)
    {
        return role switch
        {
            "Admin" => "bg-red-50 text-red-700 border border-red-200",
            "User" => "bg-blue-50 text-blue-700 border border-blue-200",
            "Editor" => "bg-purple-50 text-purple-700 border border-purple-200",
            _ => "bg-gray-50 text-gray-700 border border-gray-200"
        };
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;

        _debounceTimer?.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }
}
