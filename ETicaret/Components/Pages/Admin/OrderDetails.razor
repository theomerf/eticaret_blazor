@code {
    [Parameter]
    public int OrderId { get; set; }

    private ICouponService? _couponService;
    private IOrderService? _orderService;

    private OrderWithDetailsDto? order;
    private CouponDto? couponDetails;
    private bool isLoading = true;
    private bool isShipModalOpen = false;
    private bool isCancelModalOpen = false;
    private bool isAdminNoteModalOpen = false;
    private bool isReturnModalOpen = false;

    private ShipModel shipModel = new();
    private string cancelReason = "";
    private string adminNote = "";
    private string returnReason = "";

    private class ShipModel
    {
        public string CompanyName { get; set; } = "";
        public string TrackingNumber { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        _couponService = ScopedServices.GetRequiredService<ICouponService>();
        _orderService = ScopedServices.GetRequiredService<IOrderService>();

        await LoadOrder();
    }

    private async Task LoadOrder()
    {
        isLoading = true;
        try
        {
            if (_orderService != null)
            {
                var result = await _orderService.GetByIdAsync(OrderId);
                order = result;
            }

            if (order != null && !string.IsNullOrEmpty(order.CouponCode))
            {
                try
                {
                    if (_couponService != null)
                    {
                        var couponResult = await _couponService.GetByCodeAsync(order.CouponCode);
                        if (couponResult.IsSuccess)
                        {
                            couponDetails = couponResult.Data;
                        }
                    }
                }
                catch {}
            }
        }
        catch (Exception)
        {
            order = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenShipModal()
    {
        shipModel = new ShipModel();
        isShipModalOpen = true;
    }

    private void CloseShipModal()
    {
        isShipModalOpen = false;
    }

    private async Task SubmitShip()
    {
        if (string.IsNullOrWhiteSpace(shipModel.TrackingNumber)) return;

        if (_orderService != null)
        {
            var result = await _orderService.MarkAsShippedAsync(OrderId, shipModel.TrackingNumber, shipModel.CompanyName, null);
            if (result.IsSuccess)
            {
                await JSRuntime.InvokeVoidAsync("showToast", "Sipariş kargoya verildi.", "success");
                CloseShipModal();
                await LoadOrder();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
            }
        }
    }

    private void OpenCancelModal()
    {
        cancelReason = "";
        isCancelModalOpen = true;
    }

    private void CloseCancelModal()
    {
        isCancelModalOpen = false;
    }

    private async Task SubmitCancel()
    {
        if (string.IsNullOrWhiteSpace(cancelReason)) return;

        if (_orderService != null)
        {
            var result = await _orderService.CancelAsync(OrderId, cancelReason);
            if (result.IsSuccess)
            {
                await JSRuntime.InvokeVoidAsync("showToast", "Sipariş iptal edildi.", "success");
                CloseCancelModal();
                await LoadOrder();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
            }  
        }
    }

    private async Task MarkAsDelivered()
    {
        if (!await JSRuntime.InvokeAsync<bool>("showConfirm", "Siparişi teslim edildi olarak işaretlemek istiyor musunuz?")) return;

        if (_orderService != null)
        {
            var result = await _orderService.MarkAsDeliveredAsync(OrderId);
            if (result.IsSuccess)
            {
                await JSRuntime.InvokeVoidAsync("showToast", "Sipariş teslim edildi.", "success");
                await LoadOrder();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
            }
        }
    }

    private void OpenAdminNoteModal()
    {
        adminNote = "";
        isAdminNoteModalOpen = true;
    }

    private void CloseAdminNoteModal()
    {
        isAdminNoteModalOpen = false;
    }

    private async Task SubmitAdminNote()
    {
        if (string.IsNullOrWhiteSpace(adminNote)) return;

        if (_orderService != null)
        {
            var result = await _orderService.AddAdminNoteAsync(OrderId, adminNote);
            if (result.IsSuccess)
            {
                await JSRuntime.InvokeVoidAsync("showToast", "Admin notu eklendi.", "success");
                CloseAdminNoteModal();
                await LoadOrder();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
            }
        } 
    }

    private void OpenReturnModal()
    {
        returnReason = "";
        isReturnModalOpen = true;
    }

    private void CloseReturnModal()
    {
        isReturnModalOpen = false;
    }

    private async Task SubmitReturn()
    {
        if (string.IsNullOrWhiteSpace(returnReason)) return;

        if (_orderService != null)
        {
            var result = await _orderService.InitiateReturnAsync(OrderId, returnReason);
            if (result.IsSuccess)
            {
                await JSRuntime.InvokeVoidAsync("showToast", "İade işlemi başlatıldı.", "success");
                CloseReturnModal();
                await LoadOrder();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
            }
        }
    }

    private string GetStatusLabel(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "Beklemede",
        OrderStatus.Processing => "İşleniyor",
        OrderStatus.Shipped => "Kargoya Verildi",
        OrderStatus.Delivered => "Teslim Edildi",
        OrderStatus.Cancelled => "İptal Edildi",
        OrderStatus.Returned => "İade Edildi",
        OrderStatus.Failed => "Başarısız",
        _ => status.ToString()
    };

    private string GetStatusBadgeClass(OrderStatus status) => status switch
    {
        OrderStatus.Pending => "bg-yellow-50 text-yellow-700 border border-yellow-200",
        OrderStatus.Processing => "bg-blue-50 text-blue-700 border border-blue-200",
        OrderStatus.Shipped => "bg-purple-50 text-purple-700 border border-purple-200",
        OrderStatus.Delivered => "bg-green-50 text-green-700 border border-green-200",
        OrderStatus.Cancelled => "bg-red-50 text-red-700 border border-red-200",
        OrderStatus.Returned => "bg-orange-50 text-orange-700 border border-orange-200",
        OrderStatus.Failed => "bg-gray-50 text-gray-700 border border-gray-200",
        _ => "bg-gray-50 text-gray-700 border border-gray-200"
    };

    private string GetPaymentStatusLabel(PaymentStatus status) => status switch
    {
        PaymentStatus.Pending => "Bekleniyor",
        PaymentStatus.Completed => "Ödendi",
        PaymentStatus.Failed => "Başarısız",
        PaymentStatus.Refunded => "İade",
