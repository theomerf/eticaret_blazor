@page "/admin/orders/details/{OrderId:int}"
@attribute [Authorize(Roles = "Admin")]
@using Application.DTOs
@using Application.Common.Models
@using Domain.Entities
@using System.Globalization
@layout AdminLayout
@inherits OwningComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="min-h-screen bg-gray-50 flex flex-col font-sans">
    <div class="flex-1 max-w-full">
        <div class="flex flex-col">
            <div class="mb-6 flex items-center justify-between">
                <a href="/admin/orders" class="px-6 py-3 bg-gray-100 text-gray-700 rounded-xl font-semibold hover:bg-gray-200 transition-all">
                    <i class="fas fa-arrow-left mr-2"></i>Geri Dön
                </a>
                <div class="flex gap-2">
                    @if (order != null)
                    {
                        <button @onclick="OpenAdminNoteModal" class="bg-purple-600 hover:bg-purple-700 text-white px-5 py-2.5 rounded-xl transition-all shadow-md hover:shadow-lg flex items-center gap-2 font-semibold">
                            <i class="fas fa-sticky-note"></i> Not Ekle
                        </button>

                        if (order.OrderStatus == OrderStatus.Processing || order.OrderStatus == OrderStatus.Pending)
                        {
                            <button @onclick="OpenShipModal" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl transition-all shadow-md hover:shadow-lg flex items-center gap-2 font-semibold">
                                <i class="fas fa-shipping-fast"></i> Kargoya Ver
                            </button>
                            <button @onclick="OpenCancelModal" class="bg-red-50 hover:bg-red-100 text-red-600 px-5 py-2.5 rounded-xl transition-all border-2 border-red-200 hover:border-red-300 flex items-center gap-2 font-semibold">
                                <i class="fas fa-times-circle"></i> İptal Et
                            </button>
                        }
                        else if (order.OrderStatus == OrderStatus.Shipped)
                        {
                            <button @onclick="MarkAsDelivered" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-xl transition-all shadow-md hover:shadow-lg flex items-center gap-2 font-semibold">
                                <i class="fas fa-check-circle"></i> Teslim Edildi İşaretle
                            </button>
                        }
                        else if (order.OrderStatus == OrderStatus.Delivered)
                        {
                            <button @onclick="OpenReturnModal" class="bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-xl transition-all shadow-md hover:shadow-lg flex items-center gap-2 font-semibold">
                                <i class="fas fa-undo"></i> İade Başlat
                            </button>
                        }
                    }
                </div>
            </div>

            @if (isLoading)
            {
                <div class="flex flex-col items-center justify-center py-12 bg-white rounded-2xl shadow-sm border border-gray-100">
                    <div class="w-12 h-12 border-4 border-gray-200 border-t-blue-600 rounded-full animate-spin mb-4"></div>
                    <p class="text-gray-500 font-medium">Sipariş detayları yükleniyor...</p>
                </div>
            }
            else if (order == null)
            {
                <div class="bg-yellow-50 border-l-4 border-yellow-500 p-6 rounded-xl shadow-sm">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-exclamation-triangle text-yellow-600 text-2xl"></i>
                        <p class="text-yellow-700 font-medium">Sipariş bulunamadı.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 mb-2">
                                <h1 class="text-3xl font-bold text-gray-900">Sipariş #@order.OrderNumber</h1>
                                <span class="px-3 py-1.5 rounded-full text-sm font-semibold @GetStatusBadgeClass(order.OrderStatus)">
                                    @GetStatusLabel(order.OrderStatus)
                                </span>
                                 <span class="px-3 py-1.5 rounded-full text-sm font-semibold @GetPaymentStatusBadgeClass(order.PaymentStatus)">
                                    @GetPaymentStatusLabel(order.PaymentStatus)
                                </span>
                            </div>
                            <p class="text-gray-500 text-sm flex items-center gap-2">
                                <i class="far fa-calendar-alt"></i> @order.OrderedAt.ToLocalTime().ToString("dd MMMM yyyy HH:mm")
                            </p>
                        </div>
                        <div class="text-right bg-gradient-to-br from-blue-50 to-indigo-50 px-6 py-4 rounded-xl border border-blue-100">
                            <p class="text-sm text-gray-600 font-medium mb-1">Toplam Tutar</p>
                            <p class="text-3xl font-black text-secondary">@order.TotalAmount.ToString("C2", new CultureInfo("tr-TR"))</p>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Left Column: Items & Summary -->
                    <div class="lg:col-span-2 space-y-6">
                        <!-- Order Items -->
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                            <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
                                <h2 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                                    <i class="fas fa-box text-secondary"></i> Ürünler (@order.Lines.Count)
                                </h2>
                            </div>
                            <div class="divide-y divide-gray-100 max-h-[600px] overflow-y-auto">
                                @foreach (var item in order.Lines)
                                {
                                    <div class="p-5 hover:bg-gray-50 transition-colors">
                                        <div class="flex items-start gap-4">
                                            <div class="h-24 w-24 flex-shrink-0 bg-gray-100 rounded-xl overflow-hidden border border-gray-200 shadow-sm">
                                                <img src="@(item.ImageUrl ?? "placeholder.png")" alt="@item.ProductName" class="h-full w-full object-cover" />
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <h3 class="text-base font-bold text-gray-900 mb-1">@item.ProductName</h3>
                                                <p class="text-xs text-gray-500 mb-2">@item.CategoryName @(string.IsNullOrEmpty(item.SubCategoryName) ? "" : $" > {item.SubCategoryName}")</p>
                                                
                                                @if (!string.IsNullOrEmpty(item.VariantColor) || !string.IsNullOrEmpty(item.VariantSize) || (item.VariantSpecifications != null && item.VariantSpecifications.Any()))
                                                {
                                                    <div class="flex flex-wrap gap-2 mt-2">
                                                        @if (!string.IsNullOrEmpty(item.VariantColor))
                                                        {
                                                            <span class="px-2.5 py-1 rounded-lg text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-200">
                                                                Renk: @item.VariantColor
                                                            </span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.VariantSize))
                                                        {
                                                            <span class="px-2.5 py-1 rounded-lg text-xs font-semibold bg-purple-50 text-purple-700 border border-purple-200">
                                                                Beden: @item.VariantSize
                                                            </span>
                                                        }
                                                        @if (item.VariantSpecifications != null)
                                                        {
                                                            @foreach (var spec in item.VariantSpecifications)
                                                            {
                                                                <span class="px-2.5 py-1 rounded-lg text-xs font-semibold bg-gray-50 text-gray-700 border border-gray-200">
                                                                    @spec.Key: @spec.Value
                                                                </span>
                                                            }
                                                        }
                                                    </div>
                                                }
                                            </div>
                                            <div class="text-right flex-shrink-0">
                                                <p class="text-sm font-bold text-gray-900">@item.FinalPrice.ToString("C2", new CultureInfo("tr-TR"))</p>
                                                <p class="text-xs text-gray-500 mt-1">x @item.Quantity</p>
                                                <p class="text-base font-black text-secondary mt-2">@item.LineTotal.ToString("C2", new CultureInfo("tr-TR"))</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Order Summary -->
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                <i class="fas fa-calculator text-secondary"></i> Sipariş Özeti
                            </h2>
                            <div class="space-y-3 text-sm">
                                <div class="flex justify-between text-gray-600">
                                    <span>Ara Toplam</span>
                                    <span class="font-semibold">@order.SubTotal.ToString("C2", new CultureInfo("tr-TR"))</span>
                                </div>
                                
                                @if (order.CouponDiscountAmount.HasValue && order.CouponDiscountAmount.Value > 0)
                                {
                                    <div class="flex justify-between text-emerald-600">
                                        <span class="font-medium flex items-center gap-2">
                                            <i class="fas fa-ticket-alt"></i> Kupon İndirimi
                                            @if (!string.IsNullOrEmpty(order.CouponCode))
                                            {
                                                <span class="text-xs bg-emerald-100 px-2 py-0.5 rounded font-bold">@order.CouponCode</span>
                                            }
                                        </span>
                                        <span class="font-bold">-@order.CouponDiscountAmount.Value.ToString("C2", new CultureInfo("tr-TR"))</span>
                                    </div>
                                }
                                
                                @if (order.CampaignDiscountTotal.HasValue && order.CampaignDiscountTotal.Value > 0)
                                {
                                    <div class="flex justify-between text-orange-600">
                                        <span class="font-medium flex items-center gap-2">
                                            <i class="fas fa-tags"></i> Kampanya İndirimi
                                        </span>
                                        <span class="font-bold">-@order.CampaignDiscountTotal.Value.ToString("C2", new CultureInfo("tr-TR"))</span>
                                    </div>
                                }
                                
                                @if (order.TotalDiscountAmount.HasValue && order.TotalDiscountAmount.Value > 0)
                                {
                                    <div class="flex justify-between text-emerald-600 pt-2 border-t border-gray-200">
                                        <span class="font-bold">Toplam İndirim</span>
                                        <span class="font-bold">-@order.TotalDiscountAmount.Value.ToString("C2", new CultureInfo("tr-TR"))</span>
                                    </div>
                                }
                                
                                 <div class="flex justify-between text-gray-600">
                                    <span>Kargo</span>
                                    <span class="font-semibold">@order.ShippingCost.ToString("C2", new CultureInfo("tr-TR"))</span>
                                </div>
                                <div class="flex justify-between text-gray-600">
                                    <span>Vergi (%18 KDV)</span>
                                     <span class="font-semibold">@order.TaxAmount.ToString("C2", new CultureInfo("tr-TR"))</span>
                                </div>
                                <div class="border-t-2 border-gray-200 pt-3 mt-3 flex justify-between items-center">
                                    <span class="text-lg font-bold text-gray-900">Genel Toplam</span>
                                    <span class="text-2xl font-black text-secondary">@order.TotalAmount.ToString("C2", new CultureInfo("tr-TR"))</span>
                                </div>
                            </div>
                        </div>

                        <!-- Coupon Details (if applied) -->
                        @if (!string.IsNullOrEmpty(order.CouponCode) && couponDetails != null)
                        {
                            <div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-2xl shadow-sm border border-emerald-200 p-6">
                                <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                    <i class="fas fa-ticket-alt text-emerald-600"></i> Uygulanan Kupon
                                </h2>
                                <div class="space-y-3">
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-gray-600">Kupon Kodu:</span>
                                        <span class="font-bold text-emerald-700 text-lg">@couponDetails.Code</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-gray-600">Tip:</span>
                                        <span class="font-semibold text-gray-900">@GetCouponTypeLabel(couponDetails.Type)</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-gray-600">Değer:</span>
                                        <span class="font-semibold text-gray-900">@GetCouponValueDisplay(couponDetails)</span>
                                    </div>
                                    <div class="flex justify-between items-center">
                                        <span class="text-sm text-gray-600">İndirim Tutarı:</span>
                                        <span class="font-bold text-emerald-700 text-lg">@order.CouponDiscountAmount?.ToString("C2", new CultureInfo("tr-TR"))</span>
                                    </div>
                                    @if (couponDetails.MinOrderAmount.HasValue)
                                    {
                                        <div class="flex justify-between items-center text-xs text-gray-500">
                                            <span>Min. Sipariş:</span>
                                            <span>@couponDetails.MinOrderAmount.Value.ToString("C2", new CultureInfo("tr-TR"))</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Campaign Details (if applied) -->
                        @if (order.AppliedCampaigns != null && order.AppliedCampaigns.Any())
                        {
                            <div class="bg-gradient-to-br from-orange-50 to-amber-50 rounded-2xl shadow-sm border border-orange-200 p-6">
                                <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                    <i class="fas fa-tags text-orange-600"></i> Uygulanan Kampanyalar (@order.AppliedCampaigns.Count)
                                </h2>
                                <div class="space-y-4">
                                    @foreach (var campaign in order.AppliedCampaigns.OrderBy(c => c.Priority))
                                    {
                                        <div class="bg-white rounded-xl p-4 border border-orange-200">
                                            <div class="flex justify-between items-start mb-2">
                                                <h3 class="font-bold text-gray-900">@campaign.CampaignName</h3>
                                                <span class="text-xs bg-orange-100 text-orange-700 px-2 py-1 rounded font-semibold">Öncelik: @campaign.Priority</span>
                                            </div>
                                            <div class="grid grid-cols-2 gap-2 text-sm">
                                                <div>
                                                    <span class="text-gray-600">Tip:</span>
                                                    <span class="ml-2 font-semibold text-gray-900">@GetCampaignTypeLabel(campaign.CampaignType)</span>
                                                </div>
                                                <div>
                                                    <span class="text-gray-600">Kapsam:</span>
                                                    <span class="ml-2 font-semibold text-gray-900">@GetCampaignScopeLabel(campaign.CampaignScope)</span>
                                                </div>
                                                <div>
                                                    <span class="text-gray-600">Değer:</span>
                                                    <span class="ml-2 font-semibold text-gray-900">@GetCampaignValueDisplay(campaign)</span>
                                                </div>
                                                <div>
                                                    <span class="text-gray-600">İndirim:</span>
                                                    <span class="ml-2 font-bold text-orange-700">@campaign.DiscountAmount.ToString("C2", new CultureInfo("tr-TR"))</span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Right Column: Customer & Details -->
                    <div class="space-y-6">
                        <!-- Customer Info -->
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                 <i class="far fa-user text-secondary"></i> Müşteri Bilgileri
                            </h2>
                            <div class="flex items-center gap-3 mb-4 p-3 bg-blue-50 rounded-xl border border-blue-100">
                                <div class="h-12 w-12 rounded-full bg-cyan-500 flex items-center justify-center text-white font-bold text-lg shadow-md">
                                     @(order.FirstName.FirstOrDefault())
                                </div>
                                <div>
                                    <p class="font-bold text-gray-900">@order.FirstName @order.LastName</p>
                                    <p class="text-xs text-gray-500">Müşteri</p>
                                </div>
                            </div>
                            <div class="space-y-3 text-sm text-gray-600">
                                <div class="flex items-center gap-3 p-2 hover:bg-gray-50 rounded-lg transition-colors">
                                     <i class="fas fa-phone w-5 text-secondary"></i> 
                                     <span class="font-medium">@order.Phone</span>
                                </div>
                            </div>
                        </div>

                        <!-- Shipping Address -->
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                <i class="fas fa-map-marker-alt text-secondary"></i> Teslimat Adresi
                            </h2>
                            <address class="not-italic text-sm text-gray-700 leading-relaxed p-4 bg-gray-50 rounded-xl border border-gray-100">
                                <p class="font-semibold text-gray-900 mb-2">@order.AddressLine</p>
                                <p>@order.District / @order.City</p>
                                @if (!string.IsNullOrEmpty(order.PostalCode))
                                {
                                    <p class="mt-1 text-gray-600">Posta Kodu: @order.PostalCode</p>
                                }
                            </address>
                        </div>

                        <!-- Shipping Info -->
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                 <i class="fas fa-truck text-secondary"></i> Kargo Bilgileri
                            </h2>
                            <div class="space-y-3 text-sm">
                                <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                    <span class="text-gray-600">Kargo Tipi:</span>
                                    <span class="font-bold text-gray-900">@GetShippingMethodLabel(order.ShippingMethod)</span>
                                </div>
                                @if (!string.IsNullOrEmpty(order.ShippingCompanyName))
                                {
                                    <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                        <span class="text-gray-600">Kargo Firması:</span>
                                        <span class="font-bold text-gray-900">@order.ShippingCompanyName</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(order.TrackingNumber))
                                {
                                    <div class="flex justify-between items-center p-3 bg-blue-50 rounded-lg border border-blue-100">
                                        <span class="text-gray-600">Takip No:</span>
                                        <span class="font-bold text-secondary">@order.TrackingNumber</span>
                                    </div>
                                }
                                @if (order.GiftWrap)
                                {
                                    <div class="flex items-center gap-2 p-3 bg-pink-50 rounded-lg border border-pink-200">
                                        <i class="fas fa-gift text-pink-600"></i>
                                        <span class="font-semibold text-pink-700">Hediye Paketi İstendi</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Payment Info -->
                        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                                 <i class="far fa-credit-card text-secondary"></i> Ödeme Bilgileri
                            </h2>
                            <div class="space-y-3 text-sm">
                                <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                    <span class="text-gray-600">Yöntem:</span>
                                    <span class="font-bold text-gray-900">@GetPaymentMethodLabel(order.PaymentMethod)</span>
                                </div>
                                @if (order.PaymentMethod == PaymentMethod.CreditCard)
                                {
                                    @if (!string.IsNullOrEmpty(order.CardAssociation))
                                    {
                                        <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                            <span class="text-gray-600">Kart:</span>
                                            <span class="font-bold text-gray-900">@order.CardAssociation @order.CardFamily</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(order.LastFourDigits))
                                    {
                                        <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                            <span class="text-gray-600">Numara:</span>
                                            <span class="font-mono font-bold text-gray-900">**** @order.LastFourDigits</span>
                                        </div>
                                    }
                                    @if (order.InstallmentCount.HasValue)
                                    {
                                        <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                            <span class="text-gray-600">Taksit:</span>
                                            <span class="font-bold text-gray-900">@order.InstallmentCount</span>
                                        </div>
                                    }
                                }
                                <div class="flex justify-between items-center p-3 bg-green-50 rounded-lg border border-green-200">
                                    <span class="text-gray-600">Durum:</span>
                                    <span class="px-3 py-1 rounded-full text-xs font-bold @GetPaymentStatusBadgeClass(order.PaymentStatus)">
                                        @GetPaymentStatusLabel(order.PaymentStatus)
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Customer Notes (if any) -->
                        @if (!string.IsNullOrEmpty(order.CustomerNotes))
                        {
                            <div class="bg-blue-50 rounded-2xl shadow-sm border border-blue-200 p-6">
                                <h2 class="text-lg font-bold text-gray-800 mb-3 flex items-center gap-2">
                                    <i class="fas fa-comment-dots text-secondary"></i> Müşteri Notu
                                </h2>
                                <p class="text-sm text-gray-700 italic">@order.CustomerNotes</p>
                            </div>
                        }

                        <!-- Admin Notes (if any) -->
                        @if (!string.IsNullOrEmpty(order.AdminNotes))
                        {
                            <div class="bg-purple-50 rounded-2xl shadow-sm border border-purple-200 p-6">
                                <h2 class="text-lg font-bold text-gray-800 mb-3 flex items-center gap-2">
                                    <i class="fas fa-user-shield text-purple-600"></i> Admin Notları
                                </h2>
                                <p class="text-sm text-gray-700 whitespace-pre-line">@order.AdminNotes</p>
                            </div>
                        }
                    </div>
                     <!-- Order History Timeline (Bottom Full Width) -->
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 lg:col-span-3">
                         <h2 class="text-lg font-bold text-gray-800 mb-6 flex items-center gap-2">
                            <i class="fas fa-history text-secondary"></i> Sipariş Geçmişi
                         </h2>
                         <div class="relative pl-6 border-l-2 border-gray-200 space-y-6">
                             @foreach (var eventItem in order.History.OrderByDescending(h => h.CreatedAt))
                            {
                                <div class="relative">
                                    <span class="absolute -left-[27px] top-0.5 h-4 w-4 rounded-full border-2 border-white @GetEventTypeColor(eventItem.EventType) shadow-md"></span>
                                    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1">
                                        <h3 class="text-sm font-bold text-gray-900">@eventItem.Description</h3>
                                        <time class="text-xs text-gray-500 font-medium">@eventItem.CreatedAt.ToLocalTime().ToString("g")</time>
                                    </div>
                                    <p class="text-xs text-gray-500">
                                        İşlem Yapan: @(string.IsNullOrEmpty(eventItem.CreatedByUserName) ? "Sistem" : eventItem.CreatedByUserName)
                                    </p>
                                </div>
                            }
                         </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Ship Modal -->
@if (isShipModalOpen)
{
    <div class="fixed inset-0 z-[2000] flex items-end sm:items-center justify-center p-0 sm:p-4" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" @onclick="CloseShipModal"></div>

        <div class="relative bg-white rounded-t-3xl sm:rounded-3xl text-left shadow-2xl transform transition-all w-full sm:max-w-lg max-h-[90vh] sm:max-h-[85vh] flex flex-col animate-fadeIn">
            <div class="bg-blue-600 px-6 py-5 border-b border-blue-700 flex-shrink-0 rounded-t-3xl sm:rounded-t-3xl">
                <div class="flex justify-between items-center">
                    <h3 class="text-xl font-bold text-white flex items-center gap-2" id="modal-title">
                        <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                            <i class="fas fa-shipping-fast text-secondary text-sm"></i>
                        </div>
                        Siparişi Kargoya Ver
                    </h3>
                    <button type="button" @onclick="CloseShipModal" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white/20 hover:bg-white/30 text-white transition-colors">
                        <i class="fas fa-times"></i>
                    </button>
