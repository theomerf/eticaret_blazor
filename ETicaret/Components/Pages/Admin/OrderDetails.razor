     private string GetPaymentMethodLabel(PaymentMethod method) => method switch
    {
        PaymentMethod.CreditCard => "Kredi Kartı",
        PaymentMethod.CashOnDelivery => "Kapıda Ödeme",
        PaymentMethod.BankTransfer => "Havale / EFT",
        _ => method.ToString()
    };

    private string GetShippingMethodLabel(ShippingMethod method) => method switch
    {
        ShippingMethod.Standard => "Standart Kargo",
        ShippingMethod.Express => "Hızlı Kargo",
        ShippingMethod.HandlingOnly => "Mağazadan Teslim",
        _ => method.ToString()
    };

    private string GetEventTypeColor(OrderEventType type) => type switch
    {
        OrderEventType.OrderCreated => "bg-blue-500",
        OrderEventType.PaymentCompleted => "bg-green-500",
        OrderEventType.OrderProcessing => "bg-indigo-500",
        OrderEventType.Shipped => "bg-purple-500",
        OrderEventType.Delivered => "bg-emerald-500",
        OrderEventType.Cancelled => "bg-red-500",
        OrderEventType.Returned => "bg-orange-500",
        _ => "bg-gray-500"
    };

    private string GetCouponTypeLabel(CouponType type) => type switch
    {
        CouponType.Percentage => "Yüzde İndirim",
        CouponType.FixedAmount => "Sabit Tutar",
        _ => type.ToString()
    };

    private string GetCouponValueDisplay(CouponDto coupon)
    {
        if (coupon.Type == CouponType.Percentage)
            return $"%{coupon.Value}";
        else
            return coupon.Value.ToString("C2", new CultureInfo("tr-TR"));
    }

    private string GetCampaignTypeLabel(CampaignType type) => type switch
    {
        CampaignType.Percentage => "Yüzde",
        CampaignType.FixedAmount => "Sabit Tutar",
        _ => type.ToString()
    };

    private string GetCampaignScopeLabel(CampaignScope scope) => scope switch
    {
        CampaignScope.OrderTotal => "Sipariş Toplamı",
        CampaignScope.Product => "Ürün",
        CampaignScope.Category => "Kategori",
        _ => scope.ToString()
    };

    private string GetCampaignValueDisplay(OrderCampaignDto campaign)
    {
        if (campaign.CampaignType == CampaignType.Percentage)
            return $"%{campaign.CampaignValue}";
        else
            return campaign.CampaignValue.ToString("C2", new CultureInfo("tr-TR"));
    }
}
