        PaymentStatus.Failed => "bg-red-50 text-red-700 border border-red-200",
        PaymentStatus.Refunded => "bg-orange-50 text-orange-700 border border-orange-200",
        _ => "bg-gray-50 text-gray-700 border border-gray-200"
