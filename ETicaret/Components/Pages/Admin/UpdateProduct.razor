@page "/admin/products/update/{ProductId:int}"
@using Application.DTOs
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IProductService ProductService
@inject ICategoryService CategoryService
@inject IFileService FileService

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-lg">
                <div class="card-header bg-primary bg-gradient text-white">
                    <h4 class="my-2 text-center">
                        <i class="fa fa-edit me-2"></i>Ürün Güncelleme
                    </h4>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="@model" OnValidSubmit="HandleUpdateProduct">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <ValidationMessage For="@(() => model.ProductName)" />

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="admin-form-group">
                                    <label for="ProductName" class="admin-form-label">Ürün Adı <span class="text-danger">*</span></label>
                                    <InputText id="ProductName" @bind-Value="model.ProductName" class="form-control admin-form-control" placeholder="Ürün adını giriniz..." />
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="admin-form-group">
                                    <label for="Summary" class="admin-form-label">Ürün Açıklaması <span class="text-danger">*</span></label>
                                    <InputTextArea id="Summary" @bind-Value="model.Summary" class="form-control admin-form-control admin-textarea" placeholder="Ürün açıklamasını giriniz..."></InputTextArea>
                                </div>
                            </div>
                        </div>

                        <div class="admin-section-title mb-2">
                            <i class="fas fa-tags me-2"></i> Kategori Bilgileri
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="admin-form-group">
                                    <label asp-for="MainCategoryId" class="admin-form-label">Ana Kategori <span class="text-danger">*</span></label>
                                    <InputSelect @bind-Value="model.CategoryId" class="form-select admin-form-select">
                                        <option value="">-- Ana Kategori Seçiniz --</option>
                                        @foreach (var category in categories.Where(c => c.ParentId == null))
                                        {
                                            <option value="@category.CategoryId">@category.CategoryName</option>
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            @if (model.CategoryId != 0)
                            {
                                <div class="col-md-6">
                                    <div class="admin-form-group">
                                        <label asp-for="SubCategoryId" class="admin-form-label">Alt Kategori <span class="text-danger">*</span></label>
                                        <InputSelect @bind-Value="model.CategoryId" class="form-select admin-form-select">
                                            <option value="">-- Alt Kategori Seçiniz --</option>
                                            @foreach (var category in categories.Where(sc => sc.ParentId == model.CategoryId))
                                            {
                                                <option value="@category.CategoryId">@category.CategoryName</option>
                                            }
                                        </InputSelect>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="admin-section-title mb-2">
                            <i class="fas fa-tag me-2"></i> Fiyat Bilgileri
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="admin-form-group">
                                    <label for="ActualPrice" class="admin-form-label">Satış Fiyatı <span class="text-danger">*</span></label>
                                    <div class="admin-price-input">
                                        <InputNumber id="ActualPrice" @bind-Value="model.ActualPrice" class="form-control admin-form-control" placeholder="0.00" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="admin-form-group">
                                    <label for="DiscountPrice" class="admin-form-label">İndirimli Fiyat <small class="text-muted">(varsa)</small></label>
                                    <div class="admin-price-input">
                                        <InputNumber id="DiscountPrice" @bind-Value="model.DiscountPrice" class="form-control admin-form-control" placeholder="0.00" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <InputCheckbox @bind-Value="model.ShowCase" class="form-check-input" id="showcaseSwitch" />
                            <label class="form-check-label" for="showcaseSwitch">Öne Çıkar</label>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Ürün Görseli</label>
                            <div class="admin-image-preview" id="imagePreview">
                                @if (!string.IsNullOrEmpty(model.Images?.First().ImageUrl))
                                {
                                    <img src="/images/@model.Images?.First().ImageUrl" style="object-fit: cover; width: 180px; height: 180px;" alt="Ürün görseli" id="currentImage" />
                                }
                                else
                                {
                                    <i class="fas fa-image admin-image-preview-icon" id="placeholderIcon"></i>
                                }
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label">Yeni Fotoğraf</label>
                            <div class="admin-file-input-container">
                                <label for="imageInput" class="admin-file-input-label">
                                    <i class="fas fa-upload me-2"></i> Yeni Görsel Seçin
                                    <InputFile @bind-Value="files" class="admin-file-input" id="imageInput" accept="image/*" />
                                </label>
                            </div>
                            <div class="form-text">Yeni bir resim seçmezseniz mevcut resim korunacaktır.</div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="/admin/products" class="btn btn-outline-secondary">
                                <i class="fa fa-arrow-left me-1"></i>
                                Listeye Dön
                            </a>
                            <button class="btn btn-primary" type="submit">
                                <i class="fa fa-save me-1"></i>
                                Güncelle
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    [Parameter]
    public int ProductId { get; set; }

    private ProductWithDetailsDto model = new();
    private IEnumerable<ProductImageDtoForCreation> imagesModel = new List<ProductImageDtoForCreation>();
    private IEnumerable<CategoryDto> categories = new List<CategoryDto>();

    private List<IBrowserFile>? files;

    protected override async Task OnInitializedAsync()
    {
        model = await ProductService.GetOneProductAsync(ProductId);
        await GetAllCategories();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initializeImagePreview", "imageInput", "imagePreview");
        }
    }

    public async Task GetAllCategories()
    {
        var categories = await CategoryService.GetAllCategoriesAsync(false);
    }

    public async Task HandleUpdateProduct(EditContext editContext)
    {
        var productDto = (ProductDtoForUpdate)editContext.Model;
        productDto.ProductId = ProductId;

        if (files != null && files.Count > 0)
        {
            var fileNames = new List<string>();

            foreach (var file in files)
            {
                using var fileReadStream = file.OpenReadStream(maxAllowedSize: 20_000_000);

                var uploadResult = await FileService.UploadAsync(fileReadStream, file.Name, file.ContentType, "products");

                if (uploadResult.IsSuccess)
                {
                    fileNames.Add(uploadResult.Data!);
                }
                else
                {
                    await JSRuntime.InvokeVoidAsync("showToast", uploadResult.Message, "error");
                    return;
                }
            }

            int i = 0;

            foreach (var image in imagesModel)
            {
                image.ImageUrl = fileNames[i];
                i++;
            }

            var imageResult = await ProductService.UpdateProductImagesAsync(imagesModel);

            if (!imageResult.IsSuccess)
            {
                await JSRuntime.InvokeVoidAsync("showToast", imageResult.Message, "error");
                return;
            }

        }

        var result = await ProductService.UpdateProductAsync(productDto);
        if (!result.IsSuccess)
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
            return;
        }

        NavigationManager.NavigateTo("/admin/products");
        await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
    }
}
