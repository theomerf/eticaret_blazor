@page "/admin/coupons"
@attribute [Authorize(Roles = "Admin")]
@using Application.DTOs
@using Application.Queries.RequestParameters
@using ETicaret.Extensions
@using ETicaret.Models
@using Domain.Entities
@using Microsoft.AspNetCore.Components.Web
@inherits OwningComponentBase<ICouponService>
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@layout AdminLayout
@implements IDisposable

<div class="flex flex-col">
    <div class="hidden lg:grid lg:grid-cols-5 gap-x-2">
        <div class="col-span-1 grid grid-cols-2 gap-3 mb-6">
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-blue-50 text-secondary flex items-center justify-center mb-2">
                    <i class="fas fa-ticket-alt"></i>
                </div>
                <div class="text-xs text-gray-500 font-medium">Toplam Kupon</div>
                @if (isLoading)
                {
                    <div class="flex items-center mt-2">
                        <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                }
                else
                {
                    <div class="text-lg font-bold text-gray-800">@model.TotalCount</div>
                }
            </div>
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex flex-col items-center justify-center text-center">
                <div class="w-10 h-10 rounded-full bg-green-50 text-green-600 flex items-center justify-center mb-2">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="text-xs text-gray-500 font-medium">Aktif Kupon</div>
                @if (isLoading)
                {
                    <div class="flex items-center mt-2">
                        <div class="w-5 h-5 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                    </div>
                }
                else
                {
                    <div class="text-lg font-bold text-gray-800">@activeCouponCount</div>
                }
            </div>
        </div>

        <div class="lg:col-span-4 lg:flex justify-between items-center mb-6 bg-white p-5 rounded-2xl shadow-sm border border-gray-100">
            <div>
                <div id="coupons-list-top"></div>
                <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-secondary flex items-center justify-center text-lg">
                        <i class="fas fa-tags"></i>
                    </div>
                    Kupon Yönetimi
                </h1>
                <p class="text-gray-500 text-sm mt-1 ml-[52px]">Kuponları görüntüleyin, filtreleyin ve yönetin.</p>
            </div>
            <div class="flex items-center gap-3">
                @if (!isLoading)
                {
                    <button @onclick="OpenCreateModal" class="bg-button hover:bg-button-hover text-white px-5 py-2.5 rounded-xl font-semibold shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5 flex items-center gap-2">
                        <i class="fas fa-plus"></i> Yeni Kupon
                    </button>
                }
            </div>
        </div>
    </div>

    @if (!isLoading)
    {
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-6 p-5">
            <div class="flex flex-col md:flex-row gap-4 items-end justify-between">
                <div class="flex flex-col md:flex-row gap-4 flex-1">
                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Tip</label>
                        <select @bind="model.FilterParams.Type" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="@CouponType.Percentage">Yüzde</option>
                            <option value="@CouponType.FixedAmount">Sabit Tutar</option>
                        </select>
                    </div>

                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Kapsam</label>
                        <select @bind="model.FilterParams.Scope" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="@CouponScope.OrderTotal">Sipariş</option>
                            <option value="@CouponScope.Product">Ürün</option>
                            <option value="@CouponScope.Category">Kategori</option>
                        </select>
                    </div>

                    <div class="w-full md:w-56">
                        <label class="block text-xs font-medium text-gray-700 mb-1">Durum</label>
                        <select value="@GetIsActiveFilterValue()" @onchange="OnIsActiveFilterChange" class="block w-full h-11 rounded-lg border-gray-300 bg-gray-50 text-gray-900 focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                            <option value="">Tümü</option>
                            <option value="true">Aktif</option>
                            <option value="false">Pasif</option>
                        </select>
                    </div>
                </div>

                <div class="flex gap-2 w-full md:w-auto">
                    <button @onclick="ApplyFilters" class="flex-1 md:flex-none h-11 bg-button hover:bg-button-hover text-white font-medium px-6 rounded-lg transition-all hover:-translate-y-0.5 text-sm flex items-center justify-center gap-2">
                        <i class="fas fa-filter"></i> Filtrele
                    </button>
                    <button @onclick="ClearFilters" class="flex-1 md:flex-none h-11 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-6 rounded-lg transition-all hover:-translate-y-0.5 text-sm flex items-center justify-center gap-2">
                        <i class="fas fa-times"></i> Temizle
                    </button>
                </div>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="flex justify-center items-center h-64 bg-white rounded-2xl shadow-sm border border-gray-100">
            <div class="flex flex-col items-center gap-3">
                <div class="w-10 h-10 border-4 border-gray-200 border-t-transparent rounded-full animate-spin"></div>
                <span class="text-gray-500 font-medium">Yükleniyor...</span>
            </div>
        </div>
    }
    else
    {
        <AdminTable TItem="CouponDto"
                    Items="model.Coupons"
                    Pagination="model.Pagination"
                    OnPageChange="HandlePageChange"
                    PageSize="@(model.FilterParams.PageSize)"
                    OnPageSizeChange="HandlePageSizeChange">
            <ToolbarContent>
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                    <div class="relative flex-1 sm:max-w-md">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-400"></i>
                        </div>
                        <input type="text"
                               class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 sm:text-sm transition duration-150 ease-in-out"
                               placeholder="Kupon kodu ara..."
                               value="@searchTerm"
                               @oninput="OnSearchInput"
                               @onkeydown="HandleSearchKeyDown">
                    </div>

                    <div class="hidden lg:flex items-center gap-2">
                        <label for="couponSortOptions" class="text-sm font-medium text-gray-700 whitespace-nowrap">
                            <i class="fa-solid fa-sort mr-1 text-gray-400"></i>Sırala:
                        </label>
                        <select id="couponSortOptions"
                                class="block w-auto pl-3 pr-10 py-2 text-base border border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md"
                                value="@model.FilterParams.SortBy"
                                @onchange="HandleSortChange">
                            <option value="date_desc">En Yeni</option>
                            <option value="date_asc">En Eski</option>
                            <option value="code_asc">Kod (A-Z)</option>
                            <option value="code_desc">Kod (Z-A)</option>
                            <option value="usage_desc">En Çok Kullanılan</option>
                            <option value="end_asc">Bitiş Tarihi Yakın</option>
                        </select>
                    </div>

                </div>
            </ToolbarContent>

            <HeaderTemplate>
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kupon</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Tip</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Kapsam</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kullanım</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden xl:table-cell">Tarih Aralığı</th>
                    <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Durum</th>
                    <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">İşlemler</th>
                </tr>
            </HeaderTemplate>

            <RowTemplate Context="coupon">
                <td class="px-4 py-3">
                    <div class="min-w-0">
                        <p class="text-sm font-semibold text-gray-800 truncate">@coupon.Code</p>
                        <p class="text-xs text-gray-500 md:hidden">@GetCouponTypeLabel(coupon)</p>
                    </div>
                </td>

                <td class="px-4 py-3 hidden md:table-cell">
                    <span class="px-3 py-1.5 inline-flex text-xs leading-5 font-semibold rounded-full @GetCouponTypeBadgeClass(coupon.Type)">
                        @GetCouponTypeLabel(coupon)
                    </span>
                </td>

                <td class="px-4 py-3 hidden lg:table-cell">
                    <span class="text-sm text-gray-700">@GetCouponScopeText(coupon.Scope)</span>
                </td>

                <td class="px-4 py-3">
                    <div class="text-sm text-gray-700 font-medium">@coupon.UsedCount / @(coupon.UsageLimit == 0 ? "Sınırsız" : coupon.UsageLimit)</div>
                </td>

                <td class="px-4 py-3 hidden xl:table-cell">
                    <span class="text-sm text-gray-600">@coupon.StartsAt.ToString("dd.MM.yyyy") - @coupon.EndsAt.ToString("dd.MM.yyyy")</span>
                </td>

                <td class="px-4 py-3 text-center">
                    <label data-tooltip="@(coupon.IsActive ? "Deaktif Yap" : "Aktif Yap")" class="tooltip relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" class="sr-only peer" checked="@coupon.IsActive"
                               @onclick="() => ToggleActive(coupon)">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                    </label>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="relative inline-block text-left">
                        <button @onclick="() => ToggleDropdown(coupon.CouponId)"
                                @onblur="@(async () => { await Task.Delay(100); CloseDropdown(coupon.CouponId); })"
                                class="p-2 rounded-lg hover:bg-gray-100 transition-colors text-gray-500 focus:outline-none">
                            <i class="fas fa-ellipsis-v"></i>
                        </button>

                        @if (openDropdownId == coupon.CouponId)
                        {
                            <div class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-200 z-[1000] py-1 animate-fade-in origin-top-right">
                                <button @onclick="() => OpenEditModal(coupon)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-pen text-blue-500 w-4 text-center"></i> Düzenle
                                </button>
                                <button @onclick="() => OpenAnalyticsModal(coupon)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-chart-line text-indigo-500 w-4 text-center"></i> Analiz
                                </button>
                                <button @onclick="() => OpenUsageModal(coupon)" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-users text-teal-500 w-4 text-center"></i> Kullanım Listesi
                                </button>
                                <div class="border-t border-gray-100 my-1"></div>
                                <button @onclick="() => DeleteCoupon(coupon)" class="w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2.5 transition-colors">
                                    <i class="fas fa-trash text-red-500 w-4 text-center"></i> Sil
                                </button>
                            </div>
                        }
                    </div>
                </td>
            </RowTemplate>
        </AdminTable>
    }
</div>

@if (showCreateModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between sticky top-0">
                <h3 class="text-lg font-bold text-white">Yeni Kupon Oluştur</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <EditForm Model="createModel" OnValidSubmit="SaveCreate" class="p-6 space-y-4">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-red-500 text-xs" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kupon Kodu</label>
                        <InputText @bind-Value="createModel.Code" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm uppercase focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <ValidationMessage For="@(() => createModel.Code)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">İndirim Tipi</label>
                        <InputSelect @bind-Value="createModel.Type" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="@CouponType.Percentage">Yüzde</option>
                            <option value="@CouponType.FixedAmount">Sabit Tutar</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kapsam</label>
                        <InputSelect @bind-Value="createModel.Scope" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="@CouponScope.OrderTotal">Sipariş</option>
                            <option value="@CouponScope.Product">Ürün</option>
                            <option value="@CouponScope.Category">Kategori</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">İndirim Değeri</label>
                        <InputNumber @bind-Value="createModel.Value" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <ValidationMessage For="@(() => createModel.Value)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Minimum Sipariş Tutarı</label>
                        <InputNumber @bind-Value="createModel.MinOrderAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Maksimum İndirim Tutarı</label>
                        <InputNumber @bind-Value="createModel.MaxDiscountAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Başlangıç Tarihi</label>
                        <InputDate @bind-Value="createModel.StartsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bitiş Tarihi</label>
                        <InputDate @bind-Value="createModel.EndsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Toplam Kullanım Limiti</label>
                        <InputNumber @bind-Value="createModel.UsageLimit" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <ValidationMessage For="@(() => createModel.UsageLimit)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div class="flex items-center gap-2 pt-7">
                        <InputCheckbox @bind-Value="createModel.IsSingleUsePerUser" />
                        <label class="text-sm text-gray-700">Kullanıcı başı tek kullanım</label>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-3">
                    <button type="button" @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">Vazgeç</button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm hover:bg-button-hover disabled:opacity-50">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin mr-1"></i>
                        }
                        Kaydet
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showEditModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between sticky top-0">
                <h3 class="text-lg font-bold text-white">Kupon Düzenle</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <EditForm Model="editModel" OnValidSubmit="SaveEdit" class="p-6 space-y-4">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-red-500 text-xs" />

                @if (!string.IsNullOrWhiteSpace(editFormError))
                {
                    <div class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2">@editFormError</div>
                }

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kupon Kodu</label>
                        <InputText @bind-Value="editModel.Code" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm uppercase focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <ValidationMessage For="@(() => editModel.Code)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">İndirim Tipi</label>
                        <InputSelect @bind-Value="editModel.Type" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="@CouponType.Percentage">Yüzde</option>
                            <option value="@CouponType.FixedAmount">Sabit Tutar</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kapsam</label>
                        <InputSelect @bind-Value="editModel.Scope" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <option value="@CouponScope.OrderTotal">Sipariş</option>
                            <option value="@CouponScope.Product">Ürün</option>
                            <option value="@CouponScope.Category">Kategori</option>
                        </InputSelect>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">İndirim Değeri</label>
                        <InputNumber @bind-Value="editModel.Value" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <ValidationMessage For="@(() => editModel.Value)" class="text-red-500 text-xs mt-1" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Minimum Sipariş Tutarı</label>
                        <InputNumber @bind-Value="editModel.MinOrderAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Maksimum İndirim Tutarı</label>
                        <InputNumber @bind-Value="editModel.MaxDiscountAmount" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Başlangıç Tarihi</label>
                        <InputDate @bind-Value="editModel.StartsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Bitiş Tarihi</label>
                        <InputDate @bind-Value="editModel.EndsAt" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Toplam Kullanım Limiti</label>
                        <InputNumber @bind-Value="editModel.UsageLimit" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />
                        <p class="text-xs text-gray-500 mt-1">Mevcut kullanım: @selectedCouponUsedCount</p>
                    </div>
                    <div class="flex items-center gap-2 pt-7">
                        <InputCheckbox @bind-Value="editModel.IsSingleUsePerUser" />
                        <label class="text-sm text-gray-700">Kullanıcı başı tek kullanım</label>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-3">
                    <button type="button" @onclick="CloseModals" class="px-4 py-2 rounded-lg border border-gray-300 text-sm hover:bg-gray-50">Vazgeç</button>
                    <button type="submit" disabled="@isSaving" class="px-4 py-2 rounded-lg bg-button text-white text-sm hover:bg-button-hover disabled:opacity-50">
                        @if (isSaving)
                        {
                            <i class="fas fa-spinner fa-spin mr-1"></i>
                        }
                        Güncelle
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (showUsageModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[85vh] flex flex-col" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Kupon Kullanım Listesi - @selectedCouponCode</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">E-posta</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kullanım Sayısı</th>
                                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Son Kullanım</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @if (usageSummaryRows.Any())
                            {
                                @foreach (var row in usageSummaryRows)
                                {
                                    <tr>
                                        <td class="px-4 py-3 text-sm text-gray-700">@row.Email</td>
                                        <td class="px-4 py-3 text-sm text-gray-700 font-medium">@row.Count</td>
                                        <td class="px-4 py-3 text-sm text-gray-700">@row.LastUsedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="px-4 py-8 text-center text-gray-500">Kullanım kaydı yok.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@if (showAnalyticsModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[2000] flex items-center justify-center p-4" @onclick="CloseModals">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-4xl max-h-[85vh] flex flex-col" @onclick:stopPropagation>
            <div class="px-6 py-4 border-b border-primary/80 bg-primary flex items-center justify-between">
                <h3 class="text-lg font-bold text-white">Kupon Analizi - @selectedCouponCode</h3>
                <button @onclick="CloseModals" class="p-1.5 rounded-lg hover:bg-white/10 text-white/90">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                        <p class="text-xs text-gray-500">Toplam Kullanım</p>
                        <p class="text-xl font-bold text-gray-800">@analyticsTotalUsage</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                        <p class="text-xs text-gray-500">Benzersiz Kullanıcı</p>
                        <p class="text-xl font-bold text-gray-800">@analyticsUniqueUsers</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                        <p class="text-xs text-gray-500">Son 7 Gün</p>
                        <p class="text-xl font-bold text-gray-800">@analyticsLast7DaysUsage</p>
                    </div>
                </div>

                <div class="border border-gray-100 rounded-xl p-4 bg-white h-[320px]">
                    <canvas id="couponUsageChart" class="w-full h-full"></canvas>
                </div>
            </div>
        </div>
    </div>
}

<div id="loadingOverlay"
     class="fixed inset-0 bg-black/30 z-[9999] flex justify-center items-center backdrop-blur-sm transition-opacity duration-300 @(showLoadingOverlay ? "opacity-100 pointer-events-auto" : "opacity-0 pointer-events-none")">
    <div class="bg-white rounded-2xl p-6 text-center shadow-2xl transform transition-transform duration-300 @(showLoadingOverlay ? "scale-100" : "scale-95")">
        <div class="w-12 h-12 border-4 border-primary border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <div class="text-gray-800 font-semibold">Filtreler uygulanıyor...</div>
    </div>
</div>

@code {
    private CouponListViewModelAdmin model = new();
    private CouponRequestParametersAdmin _lastParams = new();
    private Timer? _debounceTimer;
    private CancellationTokenSource? _cts;

    private bool isLoading = true;
    private bool showLoadingOverlay = false;
    private bool isSaving = false;

    private int activeCouponCount;
    private string searchTerm = "";
    private int? openDropdownId;

    private bool showCreateModal;
    private bool showEditModal;
    private bool showUsageModal;
    private bool showAnalyticsModal;

    private CouponDto? selectedCoupon;
    private int selectedCouponUsedCount;
    private string? editFormError;

    private CouponDtoForCreation createModel = BuildCreateModel();
    private CouponDtoForUpdate editModel = BuildEditModel();

    private List<CouponUsage> selectedCouponUsages = [];
    private List<UsageSummaryRow> usageSummaryRows = [];
    private List<string> analyticsLabels = [];
    private List<int> analyticsData = [];
    private int analyticsTotalUsage;
    private int analyticsUniqueUsers;
    private int analyticsLast7DaysUsage;
    private bool shouldRenderChart;

    private string selectedCouponCode => selectedCoupon?.Code ?? "";

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        model.FilterParams = Navigation.BindFromQuery<CouponRequestParametersAdmin>();
        if (string.IsNullOrWhiteSpace(model.FilterParams.SortBy))
            model.FilterParams.SortBy = "date_desc";

        searchTerm = model.FilterParams.SearchTerm ?? "";

        _cts = new CancellationTokenSource();
        await LoadCoupons(_cts.Token);

        _cts = new CancellationTokenSource();
        activeCouponCount = await Service.CountOfActiveAsync(_cts.Token);

        isLoading = false;
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!shouldRenderChart || !showAnalyticsModal)
            return;

        shouldRenderChart = false;
        await JSRuntime.InvokeVoidAsync("couponAnalytics.renderUsageChart", "couponUsageChart", analyticsLabels, analyticsData);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var newParams = Navigation.BindFromQuery<CouponRequestParametersAdmin>();

        if (_lastParams != null && _lastParams.Equals(newParams))
            return;

        _lastParams = newParams with { };

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        await InvokeAsync(async () =>
        {
            showLoadingOverlay = true;
            StateHasChanged();

            model.FilterParams = newParams;
            if (string.IsNullOrWhiteSpace(model.FilterParams.SortBy))
                model.FilterParams.SortBy = "date_desc";
            searchTerm = model.FilterParams.SearchTerm ?? "";

            await LoadCoupons(token);

            if (token.IsCancellationRequested) return;

            showLoadingOverlay = false;
            StateHasChanged();

            await JSRuntime.InvokeVoidAsync("scrollToElement", "coupons-list-top");
        });
    }

    private async Task LoadCoupons(CancellationToken ct)
    {
        try
        {
            if (model.FilterParams.PageSize == 0) model.FilterParams.PageSize = 10;

            var result = await Service.GetAllAdminAsync(model.FilterParams, ct);
            if (ct.IsCancellationRequested) return;

            var pagination = new Pagination
            {
                CurrentPage = model.FilterParams.PageNumber,
                ItemsPerPage = model.FilterParams.PageSize,
                TotalItems = result.count
            };

            model = new CouponListViewModelAdmin()
            {
                Coupons = result.coupons,
                Pagination = pagination,
                TotalCount = result.count,
                FilterParams = model.FilterParams
            };
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void UpdateUrl()
    {
        var url = model.FilterParams.ToQueryString("/admin/coupons");
        Navigation.NavigateTo(url!);
    }

    private async Task ApplyFilters()
    {
        model.FilterParams = model.FilterParams with { PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task ClearFilters()
    {
        model.FilterParams = new CouponRequestParametersAdmin { SortBy = "date_desc" };
        searchTerm = "";
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandleSortChange(ChangeEventArgs e)
    {
        model.FilterParams = model.FilterParams with { SortBy = e.Value?.ToString(), PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandlePageChange(int page)
    {
        model.FilterParams = model.FilterParams with { PageNumber = page };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private async Task HandlePageSizeChange(int size)
    {
        model.FilterParams = model.FilterParams with { PageSize = size, PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";

        _debounceTimer?.Dispose();
        _debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(() =>
            {
                model.FilterParams = model.FilterParams with { SearchTerm = searchTerm, PageNumber = 1 };
                UpdateUrl();
            });
        }, null, 500, Timeout.Infinite);
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;

        model.FilterParams = model.FilterParams with { PageNumber = 1 };
        UpdateUrl();
        await Task.CompletedTask;
    }

    private string GetIsActiveFilterValue()
    {
        return model.FilterParams.IsActive.HasValue
            ? model.FilterParams.IsActive.Value.ToString().ToLower()
            : "";
    }

    private void OnIsActiveFilterChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        model.FilterParams = model.FilterParams with
        {
            IsActive = string.IsNullOrWhiteSpace(value) ? null : bool.Parse(value)
        };
    }

    private async Task ToggleActive(CouponDto coupon)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm",
            $"{coupon.Code} kuponunu {(coupon.IsActive ? "deaktif" : "aktif")} yapmak istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = coupon.IsActive
            ? await Service.DeactivateAsync(coupon.CouponId)
            : await Service.ActivateAsync(coupon.CouponId);

        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess)
            await ReloadList();
    }

    private async Task DeleteCoupon(CouponDto coupon)
    {
        CloseDropdown(coupon.CouponId);
        var confirmed = await JSRuntime.InvokeAsync<bool>("showConfirm", $"{coupon.Code} kuponunu silmek istediğinize emin misiniz?");
        if (!confirmed) return;

        var result = await Service.DeleteAsync(coupon.CouponId);
        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess)
            await ReloadList();
    }

    private void OpenCreateModal()
    {
        createModel = BuildCreateModel();
        showCreateModal = true;
    }

    private async Task SaveCreate()
    {
        isSaving = true;
        createModel.Code = (createModel.Code ?? string.Empty).ToUpperInvariant();
        var result = await Service.CreateAsync(createModel);
        isSaving = false;

        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess)
        {
            await CloseModals();
            await ReloadList();
        }
    }

    private void OpenEditModal(CouponDto coupon)
    {
        CloseDropdown(coupon.CouponId);
        selectedCoupon = coupon;
        selectedCouponUsedCount = coupon.UsedCount;
        editFormError = null;

        editModel = new CouponDtoForUpdate
        {
            CouponId = coupon.CouponId,
            Code = coupon.Code,
            Scope = coupon.Scope,
            Type = coupon.Type,
            Value = coupon.Value,
            MinOrderAmount = coupon.MinOrderAmount,
            MaxDiscountAmount = coupon.MaxDiscountAmount,
            StartsAt = coupon.StartsAt,
            EndsAt = coupon.EndsAt,
            IsSingleUsePerUser = coupon.IsSingleUsePerUser,
            UsageLimit = coupon.UsageLimit,
            IsActive = coupon.IsActive
        };

        showEditModal = true;
    }

    private async Task SaveEdit()
    {
        editFormError = null;
        if (editModel.UsageLimit < selectedCouponUsedCount)
        {
            editFormError = $"Kullanım limiti mevcut kullanım sayısından düşük olamaz. (Mevcut kullanım: {selectedCouponUsedCount})";
            return;
        }

        isSaving = true;
        editModel.Code = (editModel.Code ?? string.Empty).ToUpperInvariant();
        var result = await Service.UpdateAsync(editModel);
        isSaving = false;

        await JSRuntime.InvokeVoidAsync("showToast", result.Message, result.IsSuccess ? "success" : "error");
        if (result.IsSuccess)
        {
            await CloseModals();
            await ReloadList();
        }
        else
        {
            editFormError = result.Message;
        }
    }

    private async Task OpenUsageModal(CouponDto coupon)
    {
        CloseDropdown(coupon.CouponId);
        selectedCoupon = coupon;

        var usages = await Service.GetCouponUsagesByCouponIdAsync(coupon.CouponId);
        selectedCouponUsages = usages.OrderByDescending(x => x.UsedAt).ToList();
        usageSummaryRows = selectedCouponUsages
            .GroupBy(u => u.User?.Email ?? u.UserId)
            .Select(g => new UsageSummaryRow
            {
                Email = g.Key,
                Count = g.Count(),
                LastUsedAt = g.Max(x => x.UsedAt)
            })
            .OrderByDescending(x => x.Count)
            .ThenByDescending(x => x.LastUsedAt)
            .ToList();

        showUsageModal = true;
    }

    private async Task OpenAnalyticsModal(CouponDto coupon)
    {
        CloseDropdown(coupon.CouponId);
        selectedCoupon = coupon;

        var usages = await Service.GetCouponUsagesByCouponIdAsync(coupon.CouponId);
        selectedCouponUsages = usages.ToList();

        analyticsTotalUsage = selectedCouponUsages.Count;
        analyticsUniqueUsers = selectedCouponUsages.Select(x => x.UserId).Distinct().Count();
        analyticsLast7DaysUsage = selectedCouponUsages.Count(x => x.UsedAt >= DateTime.UtcNow.AddDays(-7));

        var grouped = selectedCouponUsages
            .GroupBy(x => x.UsedAt.Date)
            .ToDictionary(g => g.Key, g => g.Count());

        analyticsLabels = [];
        analyticsData = [];
        for (var i = 13; i >= 0; i--)
        {
            var d = DateTime.UtcNow.Date.AddDays(-i);
            analyticsLabels.Add(d.ToString("dd.MM"));
            analyticsData.Add(grouped.TryGetValue(d, out var n) ? n : 0);
        }

        showAnalyticsModal = true;
        shouldRenderChart = true;
        StateHasChanged();
    }

    private async Task ReloadList()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        await LoadCoupons(_cts.Token);
        StateHasChanged();
    }

    private void ToggleDropdown(int couponId)
    {
        openDropdownId = openDropdownId == couponId ? null : couponId;
    }

    private void CloseDropdown(int couponId)
    {
        if (openDropdownId == couponId)
            openDropdownId = null;
    }

    private async Task CloseModals()
    {
        showCreateModal = false;
        showEditModal = false;
        showUsageModal = false;
        showAnalyticsModal = false;
        selectedCoupon = null;
        selectedCouponUsedCount = 0;
        editFormError = null;
        await JSRuntime.InvokeVoidAsync("couponAnalytics.destroyUsageChart", "couponUsageChart");
    }

    private static CouponDtoForCreation BuildCreateModel() => new()
    {
        Code = string.Empty,
        Scope = CouponScope.OrderTotal,
        Type = CouponType.Percentage,
        Value = 0,
        StartsAt = DateTime.UtcNow,
        EndsAt = DateTime.UtcNow.AddDays(7),
        UsageLimit = 0,
        IsActive = true,
        IsSingleUsePerUser = false
    };

    private static CouponDtoForUpdate BuildEditModel() => new()
    {
        CouponId = 0,
        Code = string.Empty,
        Scope = CouponScope.OrderTotal,
        Type = CouponType.Percentage,
        Value = 0,
        StartsAt = DateTime.UtcNow,
        EndsAt = DateTime.UtcNow.AddDays(7),
        UsageLimit = 0,
        IsActive = true,
        IsSingleUsePerUser = false
    };

    private static string GetCouponScopeText(CouponScope scope) => scope switch
    {
        CouponScope.OrderTotal => "Sipariş",
        CouponScope.Product => "Ürün",
        CouponScope.Category => "Kategori",
        _ => "Diğer"
    };

    private static string GetCouponTypeLabel(CouponDto coupon) => coupon.Type switch
    {
        CouponType.Percentage => $"%{coupon.Value}",
        CouponType.FixedAmount => $"{coupon.Value:N0} TL",
        _ => coupon.Value.ToString("N0")
    };

    private static string GetCouponTypeBadgeClass(CouponType type) => type switch
    {
        CouponType.Percentage => "bg-indigo-50 text-indigo-700 border border-indigo-200",
        CouponType.FixedAmount => "bg-emerald-50 text-emerald-700 border border-emerald-200",
        _ => "bg-gray-50 text-gray-700 border border-gray-200"
    };

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _debounceTimer?.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
        _ = JSRuntime.InvokeVoidAsync("couponAnalytics.destroyUsageChart", "couponUsageChart");
    }

    private sealed class UsageSummaryRow
    {
        public string Email { get; set; } = string.Empty;
        public int Count { get; set; }
        public DateTime LastUsedAt { get; set; }
    }
}
