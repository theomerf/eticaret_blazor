@page "/account"
@using System.Security.Claims
@using Application.DTOs
@using ETicaret.Models
@using System.Text.Json
@inject IAuthService AuthService
@inject IFileService FileService
@inject IJSRuntime JSRuntime
@inject ILogger<Account> _logger

<AccountLayout>
    <div class="space-y-6">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-100/50 p-4 sm:p-6">
            <div class="flex items-center justify-between">
                <h2 class="text-lg sm:text-2xl font-bold bg-gradient-to-r from-purple-600 to-pink-500 bg-clip-text text-transparent flex items-center gap-2 sm:gap-3">
                    <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-xl bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-user text-purple-600 text-sm sm:text-base"></i>
                    </div>
                    <span class="truncate">Kullanıcı Bilgilerim</span>
                </h2>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="flex flex-col items-center justify-center bg-white rounded-2xl shadow-lg border border-gray-100/50 py-16">
                <div class="relative">
                    <div class="w-16 h-16 border-4 border-gray-100 border-t-blue-500 rounded-full animate-spin"></div>
                    <div class="absolute inset-0 w-16 h-16 border-4 border-transparent border-b-cyan-500 rounded-full animate-spin" style="animation-direction: reverse; animation-duration: 1s;"></div>
                </div>
                <p class="text-gray-500 mt-6 font-medium">Bilgileriniz yükleniyor...</p>
            </div>
        }
        else if (model.User != null)
        {
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100/50 p-6">
                <div class="flex flex-col lg:flex-row gap-8">
                    <div class="w-full lg:w-1/3 flex flex-col items-center">
                        <div class="relative group mb-6">
                            <div class="absolute inset-0 bg-primary rounded-full blur-xl opacity-20 group-hover:opacity-30 transition-opacity"></div>
                            <div class="relative w-44 h-44 rounded-full shadow-xl border-4 border-white ring-4 ring-gray-100 transition-all duration-300 group-hover:scale-105 flex items-center justify-center bg-cyan-500 text-white text-6xl font-bold cursor-default">
                                @(model.User.FirstName?.FirstOrDefault().ToString().ToUpper() ?? "U")
                            </div>
                        </div>

                        <h3 class="text-xl font-bold text-gray-800 mb-1">@model.User.FirstName @model.User.LastName</h3>
                        <p class="text-gray-500 text-sm mb-2">@model.User.Email</p>
                        <div class="px-3 py-1 bg-gradient-to-r from-blue-50 to-cyan-50 rounded-full text-xs font-semibold text-primary mb-6">
                            <i class="fas fa-check-circle mr-1"></i> Aktif Üye
                        </div>

                        <div class="w-full space-y-3">
                            <button class="w-full py-3 px-4 bg-button hover:bg-button-hover text-white rounded-xl font-semibold transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5 flex items-center justify-center gap-2" @onclick="() => ShowProfileModal()">
                                <i class="fas fa-edit"></i> Profili Düzenle
                            </button>
                            <button class="w-full py-3 px-4 bg-white border-2 border-gray-200 text-gray-700 rounded-xl font-semibold hover:border-blue-500 hover:bg-blue-50 hover:text-blue-500 transition-all shadow-sm hover:shadow-md transform hover:-translate-y-0.5 flex items-center justify-center gap-2" @onclick="() => ShowPasswordModal()">
                                <i class="fas fa-lock"></i> Şifre Değiştir
                            </button>
                        </div>
                    </div>

                    <!-- Right Side: Details -->
                    <div class="w-full lg:w-2/3">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-gradient-to-br from-blue-50 to-cyan-50/50 p-5 rounded-xl border border-blue-100/50 hover:shadow-md transition-shadow">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                        <i class="fas fa-user text-blue-500 text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Ad Soyad</span>
                                </div>
                                <span class="text-gray-800 font-semibold text-lg">@model.User.FirstName @model.User.LastName</span>
                            </div>

                            <div class="bg-gradient-to-br from-purple-50 to-pink-50/50 p-5 rounded-xl border border-purple-100/50 hover:shadow-md transition-shadow">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                        <i class="fas fa-phone text-purple-500 text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Telefon</span>
                                </div>
                                <span class="text-gray-800 font-semibold text-lg">@model.User.PhoneNumber</span>
                            </div>

                            <div class="bg-gradient-to-br from-emerald-50 to-teal-50/50 p-5 rounded-xl border border-emerald-100/50 hover:shadow-md transition-shadow">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                        <i class="fas fa-envelope text-emerald-500 text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">E-Posta</span>
                                </div>
                                <span class="text-gray-800 font-semibold text-lg break-all">@model.User.Email</span>
                            </div>

                            <div class="bg-gradient-to-br from-amber-50 to-orange-50/50 p-5 rounded-xl border border-amber-100/50 hover:shadow-md transition-shadow">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                        <i class="fas fa-birthday-cake text-amber-500 text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-500 uppercase tracking-wide">Doğum Tarihi</span>
                                </div>
                                <span class="text-gray-800 font-semibold text-lg">@model.User.BirthDate</span>
                            </div>

                            <div class="bg-gradient-to-br from-gray-50 to-slate-50/50 p-5 rounded-xl border border-gray-100/50">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                        <i class="fas fa-calendar-check text-gray-500 text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-wide">Üyelik Tarihi</span>
                                </div>
                                <span class="text-gray-600 font-medium">@model.User.CreatedAt</span>
                            </div>

                            <div class="bg-gradient-to-br from-gray-50 to-slate-50/50 p-5 rounded-xl border border-gray-100/50">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                        <i class="fas fa-clock text-gray-500 text-sm"></i>
                                    </div>
                                    <span class="text-xs font-bold text-gray-400 uppercase tracking-wide">Son Giriş</span>
                                </div>
                                <span class="text-gray-600 font-medium">@model.User.LastLoginDate</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (showProfileModal)
    {
        <div class="fixed inset-0 z-[2000] flex items-end sm:items-center justify-center p-0 sm:p-4" aria-labelledby="modal-title" role="dialog" aria-modal="true">
            <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" @onclick="CloseProfileModal"></div>

            <div class="relative bg-white rounded-t-3xl sm:rounded-3xl text-left shadow-2xl transform transition-all w-full sm:max-w-lg max-h-[90vh] sm:max-h-[85vh] flex flex-col animate-fadeIn">
                <EditForm Model="model.UserDtoForUpdate" OnValidSubmit="HandleEditProfile" style="display: contents;">
                    <DataAnnotationsValidator />
                    <div class="bg-primary px-6 py-5 border-b border-gray-100 flex-shrink-0 rounded-t-3xl sm:rounded-t-3xl">
                        <div class="flex justify-between items-center">
                            <h3 class="text-xl font-bold bg-white bg-clip-text text-transparent flex items-center gap-2" id="modal-title">
                                <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                    <i class="fas fa-edit text-blue-600 text-sm"></i>
                                </div>
                                Profili Düzenle
                            </h3>
                            <button type="button" @onclick="CloseProfileModal" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <div class="bg-white px-4 sm:px-6 py-4 sm:py-6 overflow-y-auto flex-1">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Ad</label>
                                <InputText class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.UserDtoForUpdate.FirstName" />
                                <ValidationMessage For="@(() => model.UserDtoForUpdate.FirstName)" class="text-red-500 text-xs mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Soyad</label>
                                <InputText class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.UserDtoForUpdate.LastName" />
                                <ValidationMessage For="@(() => model.UserDtoForUpdate.LastName)" class="text-red-500 text-xs mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">E-posta</label>
                                <InputText class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.UserDtoForUpdate.Email" />
                                <ValidationMessage For="@(() => model.UserDtoForUpdate.Email)" class="text-red-500 text-xs mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Telefon</label>
                                <InputText class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.UserDtoForUpdate.PhoneNumber" />
                                <ValidationMessage For="@(() => model.UserDtoForUpdate.PhoneNumber)" class="text-red-500 text-xs mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Doğum Tarihi</label>
                                <InputDate class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.UserDtoForUpdate.BirthDate" />
                                <ValidationMessage For="@(() => model.UserDtoForUpdate.BirthDate)" class="text-red-500 text-xs mt-1" />
                            </div>
                        </div>
                    </div>
                    <div class="bg-gray-50 px-4 sm:px-6 py-3 sm:py-4 flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3 border-t border-gray-200 flex-shrink-0">
                        <button type="button" class="px-6 py-2.5 rounded-xl border-2 border-gray-200 bg-white text-gray-700 font-semibold hover:bg-gray-50 hover:border-gray-300 transition-all" @onclick="CloseProfileModal">
                            İptal
                        </button>
                        <button type="submit" disabled="@(JsonSerializer.Serialize(model.UserDtoForUpdate) == _initialProfileJson)" title="@(JsonSerializer.Serialize(model.UserDtoForUpdate) == _initialProfileJson ? "Kaydetmek için değişiklik yapın" : "")" class="px-6 py-2.5 rounded-xl bg-button text-white font-semibold shadow-lg transition-all transform disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none hover:bg-button-hover hover:shadow-xl hover:-translate-y-0.5">
                            Onayla
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (showPasswordModal)
    {
        <div class="fixed inset-0 z-[2000] flex items-end sm:items-center justify-center p-0 sm:p-4" aria-labelledby="modal-title" role="dialog" aria-modal="true">
            <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm transition-opacity" aria-hidden="true" @onclick="ClosePasswordModal"></div>

            <div class="relative bg-white rounded-t-3xl sm:rounded-3xl text-left shadow-2xl transform transition-all w-full sm:max-w-md max-h-[90vh] sm:max-h-[85vh] flex flex-col animate-fadeIn">
                <EditForm Model="@model.ChangePasswordDto" OnValidSubmit="HandleChangePassword" style="display: contents;">
                    <DataAnnotationsValidator />
                    <div class="bg-primary px-6 py-5 border-b border-gray-100 flex-shrink-0 rounded-t-3xl sm:rounded-t-3xl">
                        <div class="flex justify-between items-center">
                            <h3 class="text-xl font-bold bg-white bg-clip-text text-transparent flex items-center gap-2" id="modal-title">
                                <div class="w-8 h-8 rounded-lg bg-white shadow-sm flex items-center justify-center">
                                    <i class="fas fa-lock text-blue-600 text-sm"></i>
                                </div>
                                Şifre Güncelle
                            </h3>
                            <button type="button" @onclick="ClosePasswordModal" class="w-8 h-8 flex items-center justify-center rounded-lg bg-white hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <div class="bg-white px-4 sm:px-6 py-4 sm:py-6 overflow-y-auto flex-1">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Mevcut Şifre</label>
                                <InputText type="password" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.ChangePasswordDto!.Password" />
                                <ValidationMessage For="@(() => model.ChangePasswordDto.Password)" class="text-red-500 text-xs mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Yeni Şifre</label>
                                <InputText type="password" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.ChangePasswordDto!.NewPassword" />
                                <ValidationMessage For="@(() => model.ChangePasswordDto.NewPassword)" class="text-red-500 text-xs mt-1" />
                            </div>

                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Yeni Şifre Tekrar</label>
                                <InputText type="password" class="w-full px-4 py-2.5 border-2 border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" @bind-Value="model.ChangePasswordDto!.ConfirmPassword" />
                                <ValidationMessage For="@(() => model.ChangePasswordDto.ConfirmPassword)" class="text-red-500 text-xs mt-1" />
                            </div>
                        </div>
                    </div>
                    <div class="bg-gray-50 px-4 sm:px-6 py-3 sm:py-4 flex flex-col-reverse sm:flex-row sm:justify-end gap-2 sm:gap-3 border-t border-gray-200 flex-shrink-0">
                        <button type="button" class="px-6 py-2.5 rounded-xl border-2 border-gray-200 bg-white text-gray-700 font-semibold hover:bg-gray-50 hover:border-gray-300 transition-all" @onclick="ClosePasswordModal">
                            İptal
                        </button>
                        <button type="submit" class="px-6 py-2.5 rounded-xl bg-button hover:bg-button-hover text-white font-semibold shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5">
                            Onayla
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</AccountLayout>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private ProfileViewModel model = new();
    private string? userId;

    private bool showPasswordModal = false;
    private bool showProfileModal = false;
    private bool isLoading = true;

    private IBrowserFile? avatarFile;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            }
        }

        if (!string.IsNullOrEmpty(userId))
        {
            model.User = await AuthService.GetOneUserAsync(userId!);
        }
        isLoading = false;
    }

    private async Task HandleChangePassword(EditContext editContext)
    {
        var changePasswordDto = (ChangePasswordDto)editContext.Model;
        var result = await AuthService.ChangePasswordAsync(changePasswordDto);

        if (result.IsSuccess)
        {
            ClosePasswordModal();
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private void ShowPasswordModal()
    {
        model.ChangePasswordDto = new ChangePasswordDto();
        showPasswordModal = true;
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
    }

    private void ClosePasswordModal()
    {
        showPasswordModal = false;
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'auto'");
    }

    private async Task HandleEditProfile(EditContext editContext)
    {
        var userDto = (UserDtoForUpdate)editContext.Model;

        var result = await AuthService.UpdateUserAsync(userDto);
        if (result.IsSuccess)
        {
            model.User = await AuthService.GetOneUserAsync(userId!);

            CloseProfileModal();
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "success");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", result.Message, "error");
        }
    }

    private string _initialProfileJson = string.Empty;

    private void ShowProfileModal()
    {
        model.UserDtoForUpdate = new UserDtoForUpdate
        {
            FirstName = model.User.FirstName,
            LastName = model.User.LastName,
            Email = model.User.Email,
            PhoneNumber = model.User.PhoneNumber,
            BirthDate = model.User.BirthDate
        };
        _initialProfileJson = JsonSerializer.Serialize(model.UserDtoForUpdate);
        showProfileModal = true;
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
    }

    private void CloseProfileModal()
    {
        showProfileModal = false;
        StateHasChanged();
        _ = JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'auto'");
    }
}
