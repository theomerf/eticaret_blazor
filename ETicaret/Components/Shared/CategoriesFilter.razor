@using Application.Queries.RequestParameters
@using ETicaret.Models
@using Application.DTOs
@inject IJSRuntime JSRuntime
@inject ICategoryService CategoryService

<div>
    <div class="p-3 sm:p-4">
        <div class="flex items-center justify-between mb-3 sm:mb-5 pb-2 border-b-2 border-slate-200">
            <h3 class="text-sm sm:text-base font-semibold text-slate-800 m-0 flex items-center gap-2">
                Ana Kategoriler
            </h3>
        </div>
        <div class="grid grid-cols-3 gap-2 sm:gap-3">
            <!-- Tüm Kategoriler -->
            <button type="button"
                    class="main-category-card @(FilterParams.CategoryId == null ? "active cursor-not-allowed" : "")"
                    @onclick="() => SelectMainCategory(null)"
                    disabled="@(FilterParams.CategoryId == null)">
                <div data-tooltip="Tüm Kategoriler"
                     class="tooltip flex flex-col items-center justify-center no-underline text-inherit p-1 sm:p-1.5 h-full text-center gap-1 sm:gap-1.5">
                    <div class="w-8 h-8 bg-gradient-to-br from-slate-50 to-slate-200 rounded-2xl sm:rounded-[20px] flex items-center justify-center relative overflow-hidden transition-all duration-300 mb-1 sm:mb-2 before:content-[''] before:absolute before:inset-0 before:bg-primary before:opacity-0 before:transition-opacity before:duration-300 group-hover:before:opacity-100">
                         <i class="fas fa-th-large text-lg sm:text-xl text-indigo-500 relative z-[1] transition-all duration-300 group-hover:text-white group-hover:scale-110"></i>
                    </div>
                    <span class="text-xs font-semibold tracking-tight leading-tight block w-full truncate">Tüm Ürünler</span>
                </div>
            </button>

            @foreach (var parentCategory in model.Where(c => c.ParentId == null))
            {
                var isMainCategorySelected = FilterParams.CategoryId == parentCategory.CategoryId;
                var hasSelectedSubcategory = model.Any(c => c.ParentId == parentCategory.CategoryId && FilterParams.CategoryId == c.CategoryId);
                var isActive = isMainCategorySelected || hasSelectedSubcategory;

                <button type="button"
                        class="main-category-card @(isActive ? "active cursor-not-allowed" : "")"
                        @onclick="() => SelectMainCategory(parentCategory.CategoryId)"
                        disabled="@(isActive ? "disabled" : null)">
                    <div data-tooltip="@parentCategory.CategoryName"
                         class="tooltip flex flex-col items-center justify-center no-underline text-inherit p-1 sm:p-1.5 h-full text-center gap-1 sm:gap-1.5">
                        <div class="w-8 h-8 bg-gradient-to-br from-slate-50 to-slate-200 rounded-2xl sm:rounded-[20px] flex items-center justify-center relative overflow-hidden transition-all duration-300 mb-1 sm:mb-2 before:content-[''] before:absolute before:inset-0 before:bg-primary before:opacity-0 before:transition-opacity before:duration-300 group-hover:before:opacity-100">
                            <i class="@GetCategoryIcon(parentCategory.CategoryName) text-lg sm:text-xl text-indigo-500 relative z-[1] transition-all duration-300 group-hover:text-white group-hover:scale-110"></i>
                        </div>
                        <span class="text-xs font-semibold tracking-tight leading-tight block w-full truncate">@parentCategory.CategoryName</span>
                    </div>
                </button>
            }
        </div>
    </div>

    <!-- Alt Kategoriler Bölümü -->
    @if (FilterParams.CategoryId != null)
    {
         var selectedParentId = model.FirstOrDefault(c => c.CategoryId == FilterParams.CategoryId)?.ParentId 
                             ?? FilterParams.CategoryId;
         
         var subCategories = model.Where(c => c.ParentId == selectedParentId).ToList();

        @if (subCategories.Any())
        {
            <div class="border-t border-slate-100 bg-slate-50 p-4 sm:p-6 animate-slideDown">
                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 sm:mb-6 pb-3 border-b-2 border-slate-200 gap-3">
                    <h3 class="text-sm sm:text-base font-semibold text-slate-800 m-0 flex items-center gap-2">
                        Alt Kategoriler
                    </h3>
                    <span class="bg-primary text-white px-3 py-1.5 sm:px-4 sm:py-2 rounded-2xl sm:rounded-[20px] text-xs sm:text-sm font-semibold shadow-[0_4px_12px_rgba(102,126,234,0.3)]">
                       @(model.FirstOrDefault(c => c.CategoryId == selectedParentId)?.CategoryName ?? "Seçili Kategori")
                    </span>
                </div>
                <div class="grid grid-cols-3 gap-2 sm:gap-3">
                    @foreach (var childCategory in subCategories)
                    {
                        var isChildActive = FilterParams.CategoryId == childCategory.CategoryId;

                        <button type="button"
                                class="sub-category-card @(isChildActive ? "active cursor-not-allowed" : "")"
                                @onclick="() => SelectSubCategory(childCategory.CategoryId)"
                                disabled="@(isChildActive ? "disabled" : null)">
                            <div data-tooltip="@childCategory.CategoryName"
                                 class="tooltip category-link flex flex-col items-center justify-center no-underline text-inherit p-1 sm:p-1.5 h-full text-center gap-1 sm:gap-1.5">
                                <div class="w-8 h-8 bg-gradient-to-br from-slate-100 to-slate-200 rounded-xl sm:rounded-2xl flex items-center justify-center relative overflow-hidden transition-all duration-300 before:content-[''] before:absolute before:inset-0 before:bg-primary before:opacity-0 before:transition-opacity before:duration-300 group-hover:before:opacity-100">
                                    <i class="@GetSubCategoryIcon(childCategory.CategoryName) text-lg sm:text-xl text-indigo-500 relative z-[1] transition-all duration-300 group-hover:text-white"></i>
                                </div>
                                <div class="flex flex-col items-center gap-0.5 sm:gap-1 min-w-0 w-full">
                                    <span class="block w-full text-xs font-semibold tracking-tight leading-tight mt-1 sm:mt-2 truncate text-center">
                                        @childCategory.CategoryName
                                    </span>
                                </div>
                            </div>
                        </button>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [CascadingParameter(Name = "FilterParams")]
    public ProductRequestParametersAdmin FilterParams { get; set; } = new();

    [CascadingParameter(Name = "OnFilterChange")]
    public Func<Task> OnFilterChange { get; set; } = async () => { };

    private IEnumerable<CategoryDto> model = new List<CategoryDto>();

    protected override async Task OnInitializedAsync()
    {
        model = await CategoryService.GetAllAsync();
    }

    private async Task SelectMainCategory(int? mainCategoryId)
    {
        FilterParams.CategoryId = mainCategoryId;
        // Search term ve diğer filtreleri sıfırlamak ister miyiz? Admin panelinde belki istemeyiz.
        // Genelde sadece PageNumber resetlenir.
        FilterParams.PageNumber = 1;
        await OnFilterChange.Invoke();
    }

    private async Task SelectSubCategory(int subCategoryId)
    {
        FilterParams.CategoryId = subCategoryId;
        FilterParams.PageNumber = 1;
        await OnFilterChange.Invoke();
    }

    private string GetCategoryIcon(string categoryName)
    {
        if (categoryName.Contains("Teknoloji") || categoryName.Contains("Phone")) return "fas fa-mobile-alt";
        else if (categoryName.Contains("Bilgisayar") || categoryName.Contains("Computer")) return "fas fa-laptop";
        else if (categoryName.Contains("Tablet")) return "fas fa-tablet-alt";
        else if (categoryName.Contains("Kamera") || categoryName.Contains("Camera")) return "fas fa-camera";
        else if (categoryName.Contains("TV") || categoryName.Contains("Televizyon")) return "fas fa-tv";
        else if (categoryName.Contains("Oyun") || categoryName.Contains("Game")) return "fas fa-gamepad";
        else if (categoryName.Contains("Ses") || categoryName.Contains("Audio")) return "fas fa-headphones";
        else if (categoryName.Contains("Giyim") || categoryName.Contains("Clothing")) return "fas fa-tshirt";
        else if (categoryName.Contains("Ev") || categoryName.Contains("Home")) return "fas fa-home";
        else if (categoryName.Contains("Kitap") || categoryName.Contains("Sport")) return "fas fa-book";
        else return "fas fa-cube";
    }

    private string GetSubCategoryIcon(string subCategoryName)
    {
        if (subCategoryName.Contains("iPhone") || subCategoryName.Contains("Apple")) return "fab fa-apple";
        else if (subCategoryName.Contains("Samsung")) return "fas fa-mobile-alt";
        else if (subCategoryName.Contains("Laptop")) return "fas fa-laptop";
        else if (subCategoryName.Contains("Desktop")) return "fas fa-desktop";
        else if (subCategoryName.Contains("Gaming")) return "fas fa-gamepad";
        else if (subCategoryName.Contains("Wireless")) return "fas fa-wifi";
        else if (subCategoryName.Contains("Cable")) return "fas fa-plug";
        else return "fas fa-tag";
    }
}