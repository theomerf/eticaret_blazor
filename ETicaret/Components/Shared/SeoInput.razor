@using System.Linq.Expressions

<div class="space-y-2">
    <div class="flex items-center justify-between mb-2">
        <label class="block text-sm font-semibold text-gray-700">
            @Label
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" @bind="overrideEnabled" class="w-4 h-4 text-blue-600 rounded focus:ring-2 focus:ring-blue-500" />
            <span class="text-sm text-gray-600">Manuel Düzenle</span>
        </label>
    </div>

    <div class="relative">
        <div class="@(overrideEnabled ? "hidden" : "block") w-full px-4 py-3 bg-gray-50 border-2 border-dashed border-gray-300 rounded-xl text-gray-500 text-sm">
            @if (string.IsNullOrEmpty(AutoGeneratedValue))
            {
                <span class="italic text-gray-400">@Placeholder (Otomatik oluşturulacak)</span>
            }
            else
            {
                <span>@AutoGeneratedValue</span>
            }
        </div>

        <textarea
            value="@Value"
            @oninput="HandleInput"
            class="@(!overrideEnabled ? "hidden" : "block") w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all resize-none text-sm"
            rows="@Rows"
            placeholder="@Placeholder"
            maxlength="@MaxLength"></textarea>
            
        @if (overrideEnabled && MaxLength > 0)
        {
            <div class="absolute bottom-2 right-2 text-xs text-gray-400 bg-white px-1">
                @(Value?.Length ?? 0) / @MaxLength
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(ValidationErrorMessage))
    {
         <div class="text-red-500 text-sm mt-1">@ValidationErrorMessage</div>
    }
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? AutoGeneratedValue { get; set; }
    [Parameter] public string Label { get; set; } = "SEO Alanı";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public int MaxLength { get; set; } = 0;
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public Expression<Func<string?>>? For { get; set; }

    private bool overrideEnabled = false;
    private string? ValidationErrorMessage = null;
    private string? _lastAutoValue;

    protected override void OnInitialized()
    {
        _lastAutoValue = AutoGeneratedValue;
    }

    protected override void OnParametersSet()
    {
        // If override is NOT enabled, we want to follow AutoGeneratedValue
        if (!overrideEnabled)
        {
            // Case 1: Initial load or empty value -> sync with Auto
            if (string.IsNullOrEmpty(Value))
            {
                 if (Value != AutoGeneratedValue)
                 {
                     Value = AutoGeneratedValue;
                     if (ValueChanged.HasDelegate) 
                     {
                        _ = ValueChanged.InvokeAsync(Value);
                     }
                 }
            }
            // Case 2: Value was following the previous Auto value, so it should follow the new one too.
            else if (Value == _lastAutoValue)
            {
                 if (Value != AutoGeneratedValue)
                 {
                     Value = AutoGeneratedValue;
                     if (ValueChanged.HasDelegate) 
                     {
                         _ = ValueChanged.InvokeAsync(Value);
                     }
                 }
            }
            // Case 3: Value is different from New Auto AND different from Old Auto.
            // This means it was manually set (e.g. loaded from DB with a custom value).
            else if (Value != AutoGeneratedValue)
            {
                overrideEnabled = true;
            }
        }
        
        _lastAutoValue = AutoGeneratedValue;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        overrideEnabled = true;
        var val = e.Value?.ToString();
        if (Value != val)
        {
            Value = val;
            await ValueChanged.InvokeAsync(val);
        }
    }
}
