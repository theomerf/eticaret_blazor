@using System.Security.Claims
@inject IProductService ProductService

<div class="lg:hidden">
    <button @onclick="ToggleSidebar" class="fixed left-0 top-1/2 -translate-y-1/2 z-[1150] bg-white shadow-lg rounded-r-xl p-2 border border-l-0 border-gray-200 text-primary">
        <i class="fas @(isSidebarOpen ? "fa-chevron-left" : "fa-chevron-right")"></i>
    </button>

    @if (isSidebarOpen)
    {
        <div class="fixed inset-0 bg-black/30 backdrop-blur-sm z-[1140]" @onclick="CloseSidebar"></div>
    }
</div>

<aside class="@(isSidebarOpen ? "translate-x-0" : "-translate-x-full") lg:translate-x-0 fixed lg:static top-0 left-0 h-full w-64 bg-white border-r border-gray-100 shadow-[4px_0_24px_-12px_rgba(0,0,0,0.1)] z-[1160] transition-transform duration-300 ease-in-out shrink-0 overflow-hidden flex flex-col">
    <nav class="flex-1 px-3 py-6 space-y-1 overflow-y-auto custom-scrollbar">
        <div class="px-3 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Yönetim
        </div>

        <AdminNavLink Href="/admin" Icon="fa-gauge" Text="Gösterge Paneli" Match="NavLinkMatch.All" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/orders" Icon="fa-cart-shopping" Text="Siparişler" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/products" Icon="fa-box" Text="Ürünler" BadgeText="@productsCount.ToString()" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/categories" Icon="fa-layer-group" Text="Kategoriler" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/coupons" Icon="fa-ticket" Text="Kuponlar" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/campaigns" Icon="fa-tags" Text="Kampanyalar" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/notifications" Icon="fa-bell" Text="Bildirimler" OnClick="CloseSidebar" />
        
        <div class="px-3 mt-6 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Müşteriler & Analiz
        </div>

        <AdminNavLink Href="/admin/users" Icon="fa-users" Text="Kullanıcılar" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/reviews" Icon="fa-star" Text="Değerlendirmeler" OnClick="CloseSidebar" />
        <AdminNavLink Href="/admin/reports" Icon="fa-chart-pie" Text="Raporlar" OnClick="CloseSidebar" />

        <div class="px-3 mt-6 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Sistem
        </div>

        <AdminNavLink Href="/admin/settings" Icon="fa-gear" Text="Ayarlar" OnClick="CloseSidebar" />
    </nav>

    <div class="p-4 border-t border-gray-50 flex-shrink-0">
        <div class="flex items-center gap-x-3 p-2 rounded-xl hover:bg-gray-50 transition-colors">
            <div class="w-9 h-9 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                @(User.FindFirst("first_name")?.Value?.FirstOrDefault().ToString().ToUpper() ?? User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")
            </div>
            <div class="flex flex-col">
                <span class="text-sm font-semibold text-gray-700">@User.FindFirst("first_name")?.Value @User.FindFirst("last_name")?.Value</span>
                <span class="text-xs text-gray-400">@User.FindFirstValue(ClaimTypes.Name)</span>
            </div>
        </div>
    </div>
</aside>

@code {
    [CascadingParameter]
	private Task<AuthenticationState>? AuthStateTask { get; set; }

    private ClaimsPrincipal User = new ClaimsPrincipal();

    private int productsCount;
    private bool isSidebarOpen = false;

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    private void CloseSidebar()
    {
        isSidebarOpen = false;
    }

	protected override async Task OnInitializedAsync()
	{
        productsCount = await ProductService.CountAsync();

		if (AuthStateTask != null)
		{
			var authState = await AuthStateTask;
			User = authState.User;
		}
	}
}
