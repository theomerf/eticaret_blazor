@using System.Security.Claims
<div class="flex flex-col h-full bg-white border-r border-gray-100 shadow-[4px_0_24px_-12px_rgba(0,0,0,0.1)]">
    <nav class="flex-1 px-3 py-6 space-y-1 overflow-y-auto custom-scrollbar">
        <div class="px-3 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Yönetim
        </div>

        <AdminNavLink Href="/admin" Icon="fa-gauge" Text="Gösterge Paneli" Match="NavLinkMatch.All" />
        <AdminNavLink Href="/admin/orders" Icon="fa-cart-shopping" Text="Siparişler" />
        <AdminNavLink Href="/admin/products" Icon="fa-box" Text="Ürünler" />
        <AdminNavLink Href="/admin/categories" Icon="fa-layer-group" Text="Kategoriler" />
        
        <div class="px-3 mt-6 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Müşteriler & Analiz
        </div>

        <AdminNavLink Href="/admin/users" Icon="fa-users" Text="Kullanıcılar" />
        <AdminNavLink Href="/admin/reviews" Icon="fa-star" Text="Değerlendirmeler" />
        <AdminNavLink Href="/admin/reports" Icon="fa-chart-pie" Text="Raporlar" />

        <div class="px-3 mt-6 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
            Sistem
        </div>

        <AdminNavLink Href="/admin/settings" Icon="fa-gear" Text="Ayarlar" />
    </nav>

    <!-- User Profile Summary (Bottom) -->
    <div class="p-4 border-t border-gray-50">
        <div class="flex items-center gap-x-3 p-2 rounded-xl hover:bg-gray-50 cursor-pointer transition-colors">
            <div class="w-9 h-9 rounded-full bg-gray-200 flex items-center justify-center text-gray-500">
                @(User.FindFirst("first_name")?.Value?.FirstOrDefault().ToString().ToUpper() ?? User.Identity?.Name?.FirstOrDefault().ToString().ToUpper() ?? "U")
            </div>
            <div class="flex flex-col">
                <span class="text-sm font-semibold text-gray-700">@User.FindFirst("first_name")?.Value @User.FindFirst("last_name")?.Value</span>
                <span class="text-xs text-gray-400">@User.FindFirstValue(ClaimTypes.Name)</span>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
	private Task<AuthenticationState>? AuthStateTask { get; set; }

    private ClaimsPrincipal User = new ClaimsPrincipal();

	protected override async Task OnInitializedAsync()
	{
		if (AuthStateTask != null)
		{
			var authState = await AuthStateTask;
			User = authState.User;
		}
	}
}