@using Application.DTOs

<div class="cart-glass-card shadow-lg">
    <h4 class="bg-primary text-white p-5 m-0 font-bold text-lg relative overflow-hidden group">
        <span class="relative z-10">Sipariş Özeti</span>
    </h4>
    
    <div class="p-6">
        <div class="space-y-4">
            <div class="flex justify-between items-center text-gray-600 font-medium hover:translate-x-1 transition-transform">
                <span>Ürünler (@Cart.Lines.Sum(l => l.Quantity))</span>
                <span class="text-gray-900 group-hover:text-primary transition-colors">@Cart.ComputeTotalValue().ToString("C")</span>
            </div>

            @if (Cart.Lines.Any())
            {
                <div class="flex justify-between items-center text-gray-600 font-medium hover:translate-x-1 transition-transform">
                    <span>Tahmini KDV</span>
                    <span>@((Cart.ComputeTotalValue() * 0.20m).ToString("C"))</span>
                </div>
                
                <div class="flex justify-between items-center pt-2 border-t border-gray-100 text-green-600 font-bold hover:translate-x-1 transition-transform">
                    <span>Toplam İndirimler</span>
                    <span>-@((Cart.ComputeTotalValue() - Cart.ComputeTotalDiscountValue()).ToString("C"))</span>
                </div>
            }
        </div>

        <div class="mt-6 pt-6 border-t-2 border-blue-500/10 flex justify-between items-center">
            <span class="font-extrabold text-lg text-gray-800">Genel Toplam</span>
            <span class="font-extrabold text-2xl text-primary bg-primary bg-clip-text text-transparent">
                @Cart.ComputeTotalDiscountValue().ToString("C")
            </span>
        </div>

        @if (Cart.Lines.Any())
        {
            <div class="mt-8 space-y-3">
                <a class="cart-main-btn w-full flex items-center justify-center gap-3 group" href="/order/checkout">
                    @if (IsLoading)
                    {
                        <div class="animate-spin h-5 w-5 border-2 border-white border-t-transparent rounded-full font-bold"></div>
                    }
                    else
                    {
                        <span>Ödeme Yap</span>
                        <i class="fa fa-credit-card group-hover:rotate-12 transition-transform"></i>
                    }
                </a>
                
                <a class="cart-sec-btn w-full flex items-center justify-center gap-3 group" href="/products">
                    <span>Alışverişe Devam Et</span>
                    <i class="fa fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>

            <div class="mt-6 p-4 bg-green-500/5 border border-green-500/20 rounded-2xl text-center">
                <div class="flex items-center justify-center gap-2 text-green-700 font-bold text-sm">
                    <i class="fa fa-lock animate-pulse"></i>
                    <span>%100 Güvenli Ödeme</span>
                </div>
            </div>

            <div class="mt-6 border-t border-gray-100 pt-5 text-center">
                <p class="text-gray-400 text-xs font-bold uppercase tracking-widest mb-4">Ödeme Seçenekleri</p>
                <div class="flex justify-center gap-4 text-3xl">
                    <i class="fa-brands fa-cc-visa text-[#1A1F71] filter drop-shadow hover:scale-110 transition-transform cursor-pointer"></i>
                    <i class="fa-brands fa-cc-mastercard text-[#EB001B] filter drop-shadow hover:scale-110 transition-transform cursor-pointer"></i>
                    <i class="fa-brands fa-cc-amex text-[#016FD0] filter drop-shadow hover:scale-110 transition-transform cursor-pointer"></i>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CartDto Cart { get; set; } = default!;

    [Parameter]
    public bool IsLoading { get; set; }
}
