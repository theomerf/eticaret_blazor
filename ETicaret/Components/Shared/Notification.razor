@using ETicaret.Models
@implements IDisposable
@inject ETicaret.Services.INotificationService NotificationService

<div class="notification-container">
    @foreach (var notification in NotificationService.Notifications)
    {
        <div class="custom-alert custom-alert-@GetAlertClass(notification.Type) my-3 shadow-sm @GetAnimationClass(notification) alert-dismissible"
             role="alert">
            <div class="alert-icon">
                <i class="@GetIconClass(notification.Type)"></i>
            </div>
            <div class="alert-content">
                <h6 class="alert-heading mb-1">@GetHeading(notification.Type)</h6>
                <p class="mb-0">@notification.Message</p>
            </div>
            <button type="button" class="btn-close" @onclick="() => CloseNotification(notification.Id)" aria-label="Close"></button>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        NotificationService.OnChange += StateHasChanged;
    }

    private void CloseNotification(Guid id)
    {
        NotificationService.StartClosing(id);
    }

    private string GetAlertClass(NotificationType type)
    {
        return type switch
        {
            NotificationType.Info => "info",
            NotificationType.Success => "success",
            NotificationType.Danger => "danger",
            NotificationType.Warning => "warning",
            _ => "info"
        };
    }

    private string GetIconClass(NotificationType type)
    {
        return type switch
        {
            NotificationType.Info => "fas fa-info-circle",
            NotificationType.Success => "fas fa-check-circle",
            NotificationType.Danger => "fas fa-exclamation-triangle",
            NotificationType.Warning => "fas fa-exclamation-circle",
            _ => "fas fa-info-circle"
        };
    }

    private string GetHeading(NotificationType type)
    {
        return type switch
        {
            NotificationType.Info => "Bilgi",
            NotificationType.Success => "Başarılı",
            NotificationType.Danger => "Hata",
            NotificationType.Warning => "Uyarı",
            _ => "Bilgi"
        };
    }

    private string GetAnimationClass(NotificationModel notification)
    {
        return notification.IsClosing ? "closing" : "";
    }

    public void Dispose()
    {
        NotificationService.OnChange -= StateHasChanged;
    }
}