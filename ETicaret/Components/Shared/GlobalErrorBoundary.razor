@inherits ErrorBoundary
@using Serilog
@using Serilog.Context
@using Microsoft.AspNetCore.Components.Authorization

@inject IHostEnvironment Environment
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    @if (CurrentException is ObjectDisposedException || CurrentException is TaskCanceledException || CurrentException is OperationCanceledException)
    {
        <div class="fixed bottom-4 right-4 bg-yellow-50 text-yellow-800 px-4 py-3 rounded-xl shadow-lg border border-yellow-200 flex items-center gap-3 animate-fade-in-up z-50">
            <i class="fas fa-info-circle text-yellow-600"></i>
            <span class="text-sm font-medium">Bağlantı yenilendi.</span>
            <button @onclick="Recover" class="text-yellow-600 hover:text-yellow-900">
                <i class="fas fa-sync-alt"></i>
            </button>
        </div>
    }
    else
    {
        @* Kritik Hatalar İçin UI *@
        <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
            <div class="max-w-lg w-full bg-white p-8 rounded-3xl shadow-xl text-center border border-gray-100">
                <div class="w-20 h-20 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fa-solid fa-bug text-3xl"></i>
                </div>
                
                <h3 class="text-2xl font-bold text-gray-900 mb-3">Hay aksi! Bir hata oluştu.</h3>
                <p class="text-gray-500 mb-8">
                    İşleminiz sırasında beklenmedik bir sorunla karşılaştık. Teknik ekibimiz durumdan haberdar edildi.
                </p>

                @if (Environment.IsDevelopment())
                {
                    <div class="text-left bg-gray-50 p-4 rounded-xl border border-gray-200 overflow-auto max-h-60 mb-8">
                        <p class="font-bold text-red-600 text-xs mb-2">DEBUG INFO:</p>
                        <p class="text-xs font-mono text-gray-700 break-words">@CurrentException.GetType().Name: @CurrentException.Message</p>
                    </div>
                }

                <div class="flex gap-3 justify-center">
                    <button @onclick="Recover" class="bg-button hover:bg-button-hover text-white px-8 py-3 rounded-xl font-semibold shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5 flex items-center gap-2">
                        <i class="fas fa-rotate-right"></i>
                        Sayfayı Yenile
                    </button>
                    <a href="/" class="px-8 py-3 rounded-xl font-semibold text-gray-600 hover:bg-gray-50 transition-all border border-gray-200 cursor-pointer">
                        Ana Sayfa
                    </a>
                </div>
            </div>
        </div>
    }
}

@code {
    protected override async Task OnErrorAsync(Exception exception)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var exceptionType = exception.GetType().Name;

        var severity = exception switch
        {
            UnauthorizedAccessException => "Warning",
            ArgumentException => "Warning",
            ObjectDisposedException => "Warning",      
            TaskCanceledException => "Warning",        
            OperationCanceledException => "Warning",
            Microsoft.Data.SqlClient.SqlException sqlEx when sqlEx.Message.Contains("iptal edildi") || sqlEx.Message.Contains("cancelled") => "Warning",
            InvalidOperationException => "Error",
            _ => "Critical"
        };

        using (LogContext.PushProperty("UserId", user?.Identity?.Name ?? "Anonymous"))
        using (LogContext.PushProperty("RequestPath", Navigation.Uri))
        using (LogContext.PushProperty("Component", "GlobalErrorBoundary"))
        using (LogContext.PushProperty("Severity", severity))
        {
            var logMessage = "Blazor UI Exception occurred. Type: {ExceptionType}, Path: {Path}";

            if (severity == "Warning")
            {
                Log.Warning(exception, logMessage, exceptionType, Navigation.Uri);
            }
            else
            {
                Log.Error(exception, logMessage, exceptionType, Navigation.Uri);
            }
        }
    }
    
    public new void Recover()
    {
        base.Recover();
    }
}
