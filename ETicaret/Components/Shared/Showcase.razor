@using Application.DTOs
@using System.Globalization

<div class="w-full py-8 text-gray-800">
    <!-- Header -->
    <div class="mb-10 text-center relative px-4">
        <div class="inline-block relative">
            <h3 class="text-2xl md:text-3xl font-bold bg-clip-text text-transparent bg-primary pb-2 relative z-10">
                Vitrindeki Ürünler
            </h3>
            <!-- Dekoratif Çizgi -->
            <div class="absolute bottom-0 left-0 w-full h-1 rounded-full bg-primary opacity-20"></div>
            <div class="absolute bottom-0 left-0 w-1/3 h-1 rounded-full bg-primary animate-expandWidth"></div>
        </div>
        <p class="text-gray-500 mt-4 text-sm md:text-base max-w-2xl mx-auto">
            Mağaza vitrininde müşterilerinize ilk gösterilen seçkin ürünleri buradan yönetebilirsiniz.
        </p>
    </div>

    @if (Products.Any())
    {
        <!-- Grid Layout -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 px-4">
            @foreach (var prd in Products)
            {
                <div class="group relative bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col h-full">
                    
                    <!-- Resim Alanı -->
                    <div class="relative p-6 bg-gray-50/50 flex justify-center items-center group-hover:bg-blue-50/30 transition-colors duration-500 h-[180px]">
                        <div class="relative z-10 w-24 h-24 rounded-full p-1 bg-white shadow-lg ring-4 ring-white/50 group-hover:scale-110 transition-transform duration-500">
                             @if (!string.IsNullOrEmpty(prd.Images?.FirstOrDefault()?.ImageUrl))
                             {
                                <img src="@prd.Images.FirstOrDefault()?.ImageUrl"
                                     class="w-full h-full object-cover rounded-full" 
                                      alt="@prd.ProductName">
                             }
                             else
                             {
                                 <div class="w-full h-full rounded-full bg-gray-100 flex items-center justify-center text-gray-400">
                                     <i class="fas fa-box text-2xl"></i>
                                 </div>
                             }
                             
                             <!-- Status Indicator -->
                             <span class="absolute bottom-1 right-1 w-6 h-6 bg-green-500 border-4 border-white rounded-full flex items-center justify-center shadow-md z-20" title="Vitrinde">
                                 <i class="fas fa-check text-[10px] text-white"></i>
                             </span>
                        </div>
                        
                        <!-- Arkaplan Dekoru -->
                        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>

                    <!-- İçerik -->
                    <div class="p-5 flex-1 flex flex-col items-center text-center">
                        <h6 class="font-bold text-gray-800 line-clamp-2 mb-2 group-hover:text-secondary transition-colors h-[3rem]">
                            @prd.ProductName
                        </h6>
                        
                        <div class="flex items-center justify-center gap-2 mb-4">
                            @if (prd?.DiscountPrice != null && prd?.Price > prd?.DiscountPrice)
                            {
                                <span class="line-through text-gray-400 text-xs font-medium">
                                    @prd?.Price.ToString("C2", new CultureInfo("tr-TR"))
                                </span>
                                <span class="font-bold text-lg text-primary">
                                    @prd?.DiscountPrice?.ToString("C2", new CultureInfo("tr-TR"))
                                </span>
                            }
                            else
                            {
                                <span class="font-bold text-lg text-gray-800">
                                    @prd?.Price.ToString("C2", new CultureInfo("tr-TR"))
                                </span>
                            }
                        </div>

                        <!-- Spacer to push footer down -->
                        <div class="flex-1"></div>
                    </div>

                    <!-- Footer / Actions -->
                    <div class="p-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between gap-3">
                         <!-- Switch Görünümlü Label (Pasif) -->
                        <div class="flex items-center gap-2 px-3 py-1.5 bg-white border border-gray-200 rounded-lg shadow-sm w-full">
                            <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                            <span class="text-xs font-medium text-gray-600">Yayında</span>
                        </div>

                         <a href="/admin/products/update/@prd?.ProductId" 
                            class="flex items-center justify-center gap-2 w-full px-4 py-2 text-sm font-semibold text-white transition-all bg-button hover:bg-button-hover rounded-xl shadow-md hover:shadow-lg active:scale-95">
                             <i class="fas fa-edit text-xs"></i>
                             <span>Düzenle</span>
                         </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-16 px-4 text-center bg-white rounded-3xl mx-4 border border-dashed border-gray-200">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mb-6 text-gray-300">
                <i class="fas fa-store-slash text-4xl"></i>
            </div>
            <h5 class="text-xl font-bold text-gray-700 mb-2">Vitrinde Ürün Yok</h5>
            <p class="text-gray-500 max-w-md mb-8">Markanızın en özel ürünlerini burada sergilemek için ürün eklemeye başlayın.</p>
            
            <a href="/Product/Create" class="inline-flex items-center gap-2 px-8 py-3 bg-button text-white rounded-xl font-semibold shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <i class="fas fa-plus"></i>
                <span>Yeni Ürün Ekle</span>
            </a>
        </div>
    }
</div>


@code {
    [Parameter]
    public IEnumerable<ProductDto> Products { get; set;  } = new List<ProductDto>();
    [Parameter] 
    public bool IsLoading { get; set; } = false;
}
