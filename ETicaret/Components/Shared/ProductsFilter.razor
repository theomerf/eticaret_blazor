@using ETicaret.Models
@using ETicaret.Helpers
@using Application.Queries.RequestParameters
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="filter-sidebar sticky-top" style="top: 20px;">
    <div class="card shadow-lg border-0 filter-main-card">
        <div class="card-header bg-gradient-primary text-white border-0 p-4">
            <h5 class="card-title mb-0 d-flex align-items-center">
                <i class="fas fa-filter me-2"></i>
                Ürün Filtreleri
            </h5>
        </div>

        <div class="accordion accordion-flush" id="filterAccordion">
            <!-- Kategoriler Bölümü -->
            <div class="accordion-item border-0">
                <h2 class="accordion-header" id="headingCategories">
                    <button class="accordion-button fw-semibold py-3" type="button" data-bs-toggle="collapse"
                            data-bs-target="#collapseCategories" aria-expanded="true" aria-controls="collapseCategories">
                        <i class="fas fa-layer-group text-primary me-3"></i>
                        <span>Kategoriler</span>
                        <span class="badge bg-primary ms-auto me-2">12</span>
                    </button>
                </h2>
                <div id="collapseCategories" class="accordion-collapse collapse show"
                     aria-labelledby="headingCategories" data-bs-parent="#filterAccordion">
                    <div class="accordion-body cat-acord">
                        <CategoriesFilter />
                    </div>
                </div>
            </div>

            <!-- Ürün Filtreleri Bölümü -->
            <div class="accordion-item border-0">
                <h2 class="accordion-header" id="headingProductFilterParams">
                    <button class="accordion-button fw-semibold py-3" type="button" data-bs-toggle="collapse"
                            data-bs-target="#collapseProductFilterParams" aria-expanded="true" aria-controls="collapseProductFilterParams">
                        <i class="fas fa-sliders-h text-primary me-3"></i>
                        <span>Ürün Filtreleri</span>
                    </button>
                </h2>
                <div id="collapseProductFilterParams" class="accordion-collapse collapse show"
                     aria-labelledby="headingProductFilterParams" data-bs-parent="#filterAccordion">
                    <div class="accordion-body px-4 pb-4">
                        <form id="filterForm">
                            @if (FilterParams.CategoryId != null)
                            {
                                <input type="hidden" name="CategoryId" id="mainCat" value="@FilterParams.CategoryId" />
                            }

                            <!-- Ürün Ara -->
                            <div class="filter-section mb-4">
                                <label for="searchTerm" class="form-label fw-semibold text-dark mb-3">
                                    <i class="fas fa-search text-primary me-2"></i>Ürün Ara
                                </label>
                                <div class="search-container position-relative">
                                    <input type="text" class="form-control form-control-lg border-2 pe-5 filter-input"
                                           id="searchTerm" @bind="FilterParams.SearchTerm"
                                           @bind:event="oninput" @bind:after="HandleProductSearch"
                                           placeholder="Ürün adı veya açıklama yazın...">
                                    <button @onclick="ClearSearch" class="btn search-clear-btn position-absolute top-50 end-0 translate-middle-y me-2"
                                            type="button" id="clearSearch" style="display: @(string.IsNullOrEmpty(FilterParams.SearchTerm) ? "none" : "block")">
                                        <i class="fas fa-times text-muted"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Fiyat Aralığı -->
                            <div class="filter-section mb-4">
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <label class="form-label fw-semibold text-dark mb-0">
                                        <i class="fas fa-tag text-primary me-2"></i>Fiyat Aralığı
                                    </label>
                                    <div class="price-display bg-light rounded-pill px-3 py-1">
                                        <span id="minPriceDisplay" class="fw-bold text-primary">0</span>
                                        <span class="text-muted mx-1">-</span>
                                        <span id="maxPriceDisplay" class="fw-bold text-primary">100000</span>
                                    </div>
                                </div>
                                <div id="priceRange" class="mb-3"></div>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">₺</span>
                                            <input type="number" class="form-control border-start-0 filter-input" id="minPrice" name="MinPrice"
                                                   placeholder="Min" @bind="FilterParams.MinPrice" @bind:event="oninput" @bind:after="HandlePrice" min="0">
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">₺</span>
                                            <input type="number" class="form-control border-start-0 filter-input" id="maxPrice" name="MaxPrice"
                                                   placeholder="Max" @bind="FilterParams.MaxPrice" @bind:event="oninput" @bind:after="HandlePrice" min="0">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Markalar -->
                            <div class="filter-section mb-4">
                                <label class="form-label fw-semibold text-dark mb-3">
                                    <i class="fas fa-building text-primary me-2"></i>Markalar
                                </label>
                                <div class="brand-search mb-3">
                                    <input type="text" class="form-control form-control-sm" id="brandSearch"
                                           placeholder="Marka ara...">
                                </div>
                                <div class="brand-list custom-scrollbar" style="max-height: 200px; overflow-y: auto;">
                                    <div class="form-check brand-item mb-3">
                                        <input class="form-check-input filter-input" type="radio" name="Brand" id="brandAll"
                                               checked="@(string.IsNullOrEmpty(FilterParams.Brand))"
                                               @onclick="@(() => SelectBrand(null))">
                                        <label class="form-check-label d-flex justify-content-between align-items-center w-100" for="brandAll">
                                            <span class="fw-medium">Tüm Markalar</span>
                                            <span class="badge bg-secondary rounded-pill">Tümü</span>
                                        </label>
                                    </div>
                                    @{
                                        var brands = new[] {
                                                                        new { Name = "Apple", Count = 45 },
                                                                        new { Name = "Samsung", Count = 38 },
                                                                        new { Name = "Sony", Count = 29 },
                                                                        new { Name = "Huawei", Count = 22 },
                                                                        new { Name = "Lenovo", Count = 18 },
                                                                        new { Name = "Dell", Count = 12 },
                                                                        new { Name = "Vestel", Count = 10 }
                                                                        };
                                        foreach (var brand in brands)
                                        {
                                            <div class="form-check brand-item mb-3" data-brand="@brand.Name.ToLower()">
                                                <input class="form-check-input filter-input" type="radio" name="Brand" id="brand@(brand.Name)"
                                                       checked="@(FilterParams.Brand == brand.Name)"
                                                       @onclick="@(() => SelectBrand(brand.Name))">
                                                <label class="form-check-label d-flex justify-content-between align-items-center w-100" for="brand@(brand.Name)">
                                                    <span>@brand.Name</span>
                                                    <span class="badge bg-light text-dark rounded-pill">@brand.Count</span>
                                                </label>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Özel Filtreler -->
                            <div class="filter-section mb-4">
                                <label class="form-label fw-semibold text-dark mb-3">
                                    <i class="fas fa-star text-primary me-2"></i>Özel Filtreler
                                </label>
                                <div class="special-filters">
                                    <div class="form-check form-switch mb-3 p-0">
                                        <div class="custom-switch-card d-flex align-items-center justify-content-between p-3 rounded-3 border">
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-fire text-danger me-3"></i>
                                                <div>
                                                    <div class="fw-medium">En Çok Satanlar</div>
                                                    <small class="text-muted">Popüler ürünler</small>
                                                </div>
                                            </div>
                                            <input class="form-check-input ms-0 filter-input" type="checkbox" id="bestSellers" name="IsShowCase" value="true"
                                                   checked="@(FilterParams.IsShowCase)" @onchange="HandleShowcase">
                                        </div>
                                    </div>
                                    <div class="form-check form-switch mb-3 p-0">
                                        <div class="custom-switch-card d-flex align-items-center justify-content-between p-3 rounded-3 border">
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-percentage text-success me-3"></i>
                                                <div>
                                                    <div class="fw-medium">İndirimli Ürünler</div>
                                                    <small class="text-muted">Özel fiyatlar</small>
                                                </div>
                                            </div>
                                            <input class="form-check-input ms-0 filter-input" type="checkbox" id="discountedItems" name="IsDiscount" value="true"
                                                   checked="@(FilterParams.IsDiscount)" @onchange="HandleDiscount">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="loadingOverlay"
     style="
        display: @(ShowLoadingOverlay ? "flex" : "none");
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.3);
        z-index: 9999;
        justify-content: center;
        align-items: center;
     ">
    <div class="bg-white rounded p-4 text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Yükleniyor...</span>
        </div>
        <div class="mt-2">Filtreler uygulanıyor...</div>
    </div>
</div>

@code {
    [CascadingParameter(Name = "FilterParams")]
    public ProductRequestParameters FilterParams { get; set; } = new();
    [CascadingParameter(Name = "OnFilterChange")]
    public Func<Task> OnFilterChange { get; set; } = async () => { };
    [CascadingParameter(Name = "ShowLoadingOverlay")]
    public bool ShowLoadingOverlay { get; set; }

    private DotNetObjectReference<ProductsFilter>? dotNetHelper;
    private Debouncer Debouncer = new Debouncer(500);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetHelper = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("window.setProductFilterReference", dotNetHelper);
            await JSRuntime.InvokeVoidAsync("initializePriceSlider");
        }
    }

    public void Dispose()
    {
        dotNetHelper?.Dispose();
    }

    private void HandleProductSearch()
    {
        Debouncer.Debounce(() =>
        {
            _ = InvokeAsync(async () =>
            {
                await OnFilterChange.Invoke();
            });
        });
    }

    private async Task ClearSearch()
    {
        FilterParams.SearchTerm = string.Empty;
        await OnFilterChange.Invoke();
    }

    private async Task SelectBrand(string? brandName)
    {
        FilterParams.Brand = brandName;
        await OnFilterChange.Invoke();
    }

    private async Task HandleDiscount(ChangeEventArgs e)
    {
        if (e.Value is bool isChecked)
        {
            FilterParams.IsDiscount = isChecked == true ? true : null;
            await OnFilterChange.Invoke();
        }
    }

    private async Task HandleShowcase(ChangeEventArgs e)
    {
        if (e.Value is bool isChecked)
        {
            FilterParams.IsShowCase = isChecked == true ? true : null;
            await OnFilterChange.Invoke();
        }
    }

    private void HandlePrice()
    {
        Debouncer.Debounce(() =>
        {
            _ = InvokeAsync(async () =>
            {
                await OnFilterChange.Invoke();
            });
        });
    }

    [JSInvokable]
    public void UpdatePriceFromSlider(int? minPrice, int? maxPrice)
    {
        FilterParams.MinPrice = minPrice == 0 ? null : minPrice;
        FilterParams.MaxPrice = maxPrice == 100000 ? null : maxPrice;
        HandlePrice();
        StateHasChanged();
    }

    public bool HasFiltered()
    {
        if (!string.IsNullOrEmpty(FilterParams.SearchTerm) ||
            !(FilterParams.MinPrice == null) ||
            !(FilterParams.MaxPrice == null) ||
            !string.IsNullOrEmpty(FilterParams.Brand) ||
            !(FilterParams.IsShowCase == null) ||
            !(FilterParams.IsDiscount == null) ||
            !(FilterParams.CategoryId == null))
        {
            return true;
        }
        return false;
    }
}
