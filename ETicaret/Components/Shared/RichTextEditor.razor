@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
    <div id="@EditorId" class="bg-white" style="@HeightStyle"></div>
</div>

<style>
    /* Quill Toolbar Styling */
    .ql-toolbar.ql-snow {
        background: linear-gradient(to right, #f9fafb, #ecfeff); /* from-blue-50 to-cyan-50 */
        border: 0;
        border-bottom: 1px solid #e5e7eb; /* border-gray-200 */
        padding: 0.75rem 1rem; /* px-4 py-3 */
    }

    .ql-toolbar.ql-snow button {
        width: 2rem; /* w-8 */
        height: 2rem; /* h-8 */
        border-radius: 0.25rem; /* rounded */
        transition: background-color 0.15s;
    }

    .ql-toolbar.ql-snow button:hover {
        background-color: rgba(255, 255, 255, 0.7);
    }

    .ql-toolbar.ql-snow button.ql-active {
        background-color: white;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); /* shadow-sm */
    }

    .ql-toolbar.ql-snow .ql-stroke {
        stroke: #374151; /* text-gray-700 */
    }

    .ql-toolbar.ql-snow .ql-fill {
        fill: #374151; /* text-gray-700 */
    }

    .ql-toolbar.ql-snow button:hover .ql-stroke,
    .ql-toolbar.ql-snow button.ql-active .ql-stroke {
        stroke: #2563eb; /* text-blue-600 */
    }

    .ql-toolbar.ql-snow button:hover .ql-fill,
    .ql-toolbar.ql-snow button.ql-active .ql-fill {
        fill: #2563eb; /* text-blue-600 */
    }

    /* Quill Editor Content Area */
    .ql-container.ql-snow {
        border: 0;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-size: 1rem;
    }

    .ql-editor {
        padding: 1rem 1.5rem; /* px-6 py-4 */
        min-height: 200px;
        color: #1f2937; /* text-gray-800 */
    }

    .ql-editor.ql-blank::before {
        color: #9ca3af; /* text-gray-400 */
        font-style: italic;
    }

    /* Quill Content Styling */
    .ql-editor h1 {
        font-size: 1.875rem; /* text-3xl */
        font-weight: 700; /* font-bold */
        margin-top: 1rem;
        margin-bottom: 1rem;
    }

    .ql-editor h2 {
        font-size: 1.5rem; /* text-2xl */
        font-weight: 700;
        margin-top: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .ql-editor h3 {
        font-size: 1.25rem; /* text-xl */
        font-weight: 600; /* font-semibold */
        margin-top: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .ql-editor p {
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
        line-height: 1.625; /* leading-relaxed */
    }

    .ql-editor ul,
    .ql-editor ol {
        margin-top: 0.75rem;
        margin-bottom: 0.75rem;
        padding-left: 1.5rem; /* pl-6 */
    }

    .ql-editor a {
        color: #2563eb; /* text-blue-600 */
        text-decoration: underline;
    }
    
    .ql-editor a:hover {
        color: #1d4ed8; /* text-blue-700 */
    }

    .ql-editor strong {
        font-weight: 700;
    }

    .ql-editor em {
        font-style: italic;
    }
</style>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Ürün açıklamasını buraya yazın...";
    [Parameter] public string Height { get; set; } = "300px";

    private string EditorId = $"quill-editor-{Guid.NewGuid()}";
    private DotNetObjectReference<RichTextEditor>? dotNetHelper;
    private IJSObjectReference? quillModule;
    private string HeightStyle => $"height: {Height};";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // 1. Önce Quill'in yüklenmesini bekle
                var quillLoaded = false;
                for (int i = 0; i < 50; i++)
                {
                    quillLoaded = await JSRuntime.InvokeAsync<bool>("eval",
                        "typeof Quill !== 'undefined'");
                    if (quillLoaded) break;
                    await Task.Delay(50);
                }

                if (!quillLoaded)
                {
                    Console.WriteLine("❌ Quill yüklenemedi!");
                    return;
                }

                // 2. Custom script yüklenene kadar bekle
                var scriptLoaded = false;
                for (int i = 0; i < 50; i++)
                {
                    scriptLoaded = await JSRuntime.InvokeAsync<bool>("eval",
                        "typeof initializeQuillEditor !== 'undefined'");
                    if (scriptLoaded) break;
                    await Task.Delay(50);
                }

                if (!scriptLoaded)
                {
                    Console.WriteLine("❌ quill-editor.js yüklenemedi!");
                    return;
                }

                // 3. Initialize
                dotNetHelper = DotNetObjectReference.Create(this);

                quillModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "initializeQuillEditor",
                    EditorId,
                    Placeholder,
                    Value ?? string.Empty,
                    dotNetHelper
                );

                Console.WriteLine("✅ Quill başarıyla initialize edildi!");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Hata: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public async Task OnContentChanged(string htmlContent)
    {
        Value = htmlContent;
        await ValueChanged.InvokeAsync(htmlContent);
    }

    public async ValueTask DisposeAsync()
    {
        if (quillModule != null)
        {
            try
            {
                await quillModule.DisposeAsync();
            }
            catch { }
        }

        dotNetHelper?.Dispose();
    }
}
