                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="User" asp-action="Index" class="dashboard-btn dashboard-btn-outline">Üyeler</a>
                    <a asp-controller="User" asp-action="Create" class="dashboard-btn dashboard-btn-primary">
                        <i class="fas fa-plus"></i>Yeni Ekle
                    </a>
                </div>
            </div>
        </div>

