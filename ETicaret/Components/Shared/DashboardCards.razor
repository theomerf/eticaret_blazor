                        <h5 class="mb-0 dashboard-metric-label">Siparişler</h5>
                        <small class="dashboard-metric-sublabel">Bekleyen Siparişler</small>
                    </div>
                    <div class="dashboard-icon">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
