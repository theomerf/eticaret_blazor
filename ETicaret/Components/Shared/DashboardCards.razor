<div class="dashboard-container">
    <!-- Header -->
    <div class="dashboard-header dashboard-fade-in">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1><i class="fas fa-tachometer-alt me-3"></i>Admin Gösterge Paneli</h1>
                <p>Hoş geldiniz! İşletmenizin genel durumunu buradan takip edebilirsiniz.</p>
            </div>
            <div class="text-end" style="font-size: 14px;">
                <div class="dashboard-weather-widget">
                    <i class="fas fa-sun fa-2x mb-2"></i>
                    <div>24°C</div>
                    <small>Bursa, Türkiye</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="dashboard-stats-grid dashboard-fade-in">
        <!-- Products Card -->
        <div class="dashboard-card">
            <div class="dashboard-card-header text-white p-3" style="background: var(--dashboard-primary);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 dashboard-metric-label">Ürünler</h5>
                        <small class="dashboard-metric-sublabel">Toplam Aktif Ürünler</small>
                    </div>
                    <div class="dashboard-icon">
                        <i class="fas fa-box"></i>
                    </div>
                </div>
                <h2 class="dashboard-metric-value mt-3 mb-0">
                    @ProductsCount
                </h2>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill" style="width: 75%; background: rgba(255,255,255,0.3);"></div>
                </div>
            </div>
            <div class="p-3">
                <div class="dashboard-mini-chart"></div>
                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Product" asp-action="Index" class="dashboard-btn dashboard-btn-outline">Ürünler</a>
                    <a asp-controller="Product" asp-action="Create" class="dashboard-btn dashboard-btn-primary">
                        <i class="fas fa-plus"></i>Yeni Ekle
                    </a>
                </div>
            </div>
        </div>

        <!-- Categories Card -->
        <div class="dashboard-card">
            <div class="dashboard-card-header text-white p-3" style="background: var(--dashboard-secondary);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 dashboard-metric-label">Kategoriler</h5>
                        <small class="dashboard-metric-sublabel">Ürün Kategorileri</small>
                    </div>
                    <div class="dashboard-icon">
                        <i class="fas fa-tags"></i>
                    </div>
                </div>
                <h2 class="dashboard-metric-value mt-3 mb-0">
                    @CategoriesCount
                </h2>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill" style="width: 85%; background: rgba(255,255,255,0.3);"></div>
                </div>
            </div>
            <div class="p-3">
                <div class="dashboard-mini-chart"></div>
                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Category" asp-action="Index" class="dashboard-btn dashboard-btn-outline">Kategoriler</a>
                    <a asp-controller="Product" asp-action="Create" class="dashboard-btn dashboard-btn-primary">
                        <i class="fas fa-plus"></i>Yeni Ekle
                    </a>
                </div>
            </div>
        </div>

        <!-- Users Card -->
        <div class="dashboard-card">
            <div class="dashboard-card-header text-white p-3" style="background: var(--dashboard-success);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 dashboard-metric-label">Üyeler</h5>
                        <small class="dashboard-metric-sublabel">Kayıtlı Üyeler</small>
                    </div>
                    <div class="dashboard-icon">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
                <h2 class="dashboard-metric-value mt-3 mb-0">
                    @UsersCount
