                            </div>
                        </div>
                    </div>
                    <div class="dashboard-activity-item">
                        <div class="d-flex align-items-center">
                            <div class="dashboard-activity-icon" style="background: var(--dashboard-warning);">
                                <i class="fas fa-box text-white"></i>
                            </div>
                            <div>
                                <p class="mb-1 fw-semibold">Stok güncellendi</p>
                                <small class="text-muted">5 ürün stoku düşük - 2 saat önce</small>
