                                <small class="text-muted">Planlı bakım - 3 saat önce</small>
                            </div>
                        </div>
                    </div>
                    <div class="dashboard-activity-item">
                        <div class="d-flex align-items-center">
                            <div class="dashboard-activity-icon" style="background: var(--dashboard-accent);">
                                <i class="fas fa-star text-white"></i>
                            </div>
                            <div>
                                <p class="mb-1 fw-semibold">Yeni değerlendirme</p>
                                <small class="text-muted">5 yıldız - 4 saat önce</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Access and Notifications -->
