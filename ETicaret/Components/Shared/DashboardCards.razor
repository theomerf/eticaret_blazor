                        <h5 class="mb-0 dashboard-metric-label">Yorumlar</h5>
                        <small class="dashboard-metric-sublabel">Kullanıcı Yorumları</small>
                    </div>
                    <div class="dashboard-icon">
                        <i class="fas fa-star"></i>
                    </div>
                </div>
                <h2 class="dashboard-metric-value mt-3 mb-0">2,341</h2>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill" style="width: 78%; background: rgba(255,255,255,0.3);"></div>
                </div>
            </div>
            <div class="p-3">
                <div class="dashboard-mini-chart"></div>
                <div class="d-flex justify-content-center mt-3">
                    <a href="#" class="dashboard-btn dashboard-btn-primary w-100">
                        <i class="fas fa-comments"></i>Yorumları Yönet
                    </a>
                </div>
            </div>
        </div>

        <!-- Notifications Card -->
        <div class="dashboard-card">
            <div class="dashboard-card-header text-white p-3" style="background: var(--dashboard-danger);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 dashboard-metric-label">Bildirimler</h5>
                        <small class="dashboard-metric-sublabel">Aktif Bildirimler</small>
                    </div>
                    <div class="dashboard-icon">
                        <i class="fas fa-bell"></i>
                    </div>
                </div>
                <h2 class="dashboard-metric-value mt-3 mb-0">23</h2>
                <div class="dashboard-progress-bar">
                    <div class="dashboard-progress-fill" style="width: 45%; background: rgba(255,255,255,0.3);"></div>
                </div>
            </div>
            <div class="p-3">
                <div class="dashboard-mini-chart"></div>
                <div class="d-flex justify-content-center mt-3">
