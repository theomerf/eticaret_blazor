@using ETicaret.Components.Layout

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(AdminLayout)">
                <Authorizing>
                    <p>Yetkilendirme kontrol ediliyor...</p>
                </Authorizing>
                <NotAuthorized>
                    <p>Bu sayfaya erişim yetkiniz yok.</p>
                    <a href="/Account/Login">Giriş Yap</a>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(AdminLayout)">
                <p>Sayfa bulunamadı.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>