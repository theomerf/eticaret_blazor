<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <base href="~/" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NHCXQEGG0W"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-NHCXQEGG0W');
    </script>
    <meta name="robots" content="@(ViewData["Robots"] ?? "index, follow")" />
    <link rel="canonical" href="@ViewData["Canonical"]" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@ViewData["OgTitle"]" />
    <meta property="og:description" content="@ViewData["OgDescription"]" />
    <meta property="og:url" content="@ViewData["Canonical"]" />
    <meta property="og:image" content="@ViewData["OgImage"]" />
    <title>Sipariş Kapıda - @ViewData["Title"]</title>
    <link rel="stylesheet" asp-append-version="true" href="~/css/site.css">
    <link rel="stylesheet" asp-append-version="true" href="~/css/impersonation.css">
    <link rel="stylesheet" asp-append-version="true" href="~/lib/font-awesome/css/all.min.css">
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" asp-append-version="true" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
</head>

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var isImpersonating = User.FindFirst("IsImpersonating")?.Value == "true";
}

<body class="flex flex-col min-h-screen @(isImpersonating ? "is-impersonating" : "")">
    @{
        if (isImpersonating)
        {
            var userName = User.FindFirst("first_name")?.Value + " " + User.FindFirst("last_name")?.Value;
            var antiforgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;

            <div class="impersonation-banner bg-gradient-to-r from-amber-500 to-orange-500 text-white px-4 py-2.5 flex items-center justify-between z-[9999] shadow-md">
                <div class="flex items-center gap-2 text-sm font-medium">
                    <i class="fas fa-user-secret text-lg"></i>
                    <span>
                        <strong>@userName</strong> olarak görüntülüyorsunuz
                    </span>
                </div>
                <form method="post" action="/account/stop-impersonation" class="m-0">
                    <input type="hidden" name="__RequestVerificationToken" value="@antiforgeryToken" />
                    <button type="submit" class="bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white px-4 py-1.5 rounded-lg text-sm font-semibold transition-colors flex items-center gap-1.5 border-none cursor-pointer">
                        <i class="fas fa-arrow-right-from-bracket"></i>
                        Oturumu Sonlandır
                    </button>
                </form>
            </div>
        }
    }
    <header>    
        <partial name="_Navbar" />
        @RenderSection("Header", false)
    </header>
    <div class="mx-auto px-2 sm:px-4 lg:px-6 xl:px-8 max-w-[1440px] w-full flex-grow">
        <main role="main" class="lg:mt-4" id="main-content">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5"> 
        <partial name="_Footer" />
        @RenderSection("Footer", false)
    </footer>

    <div id="toastContainer" class="toast-container"></div>

    <div id="confirmModal" class="fixed inset-0 hidden items-center justify-center bg-black/50 z-[9999]">
        <div class="bg-white rounded-2xl shadow-xl w-[90%] max-w-sm p-6 scale-95 opacity-0 transition-all duration-200">
            <h3 id="confirmTitle" class="text-lg font-bold mb-2">Onay</h3>
            <p id="confirmMessage" class="text-gray-700 mb-6"></p>

            <div class="flex justify-end gap-3">
                <button id="confirmCancel"
                        class="px-4 py-2 rounded-lg border border-gray-300 hover:bg-gray-100">
                    Vazgeç
                </button>

                <button id="confirmOk"
                        class="px-4 py-2 rounded-lg bg-button text-white hover:bg-button-hover">
                    Evet
                </button>
            </div>
        </div>
    </div>  

    <script asp-append-version="true" src="~/js/site.js"></script>
    <script asp-append-version="true" src="~/js/navbar.js"></script>
    <script asp-append-version="true" src="~/js/categories-menu.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (ViewData["UseBlazor"] as bool? == true)
    {
        <script src="~/_framework/blazor.server.js"></script>
    }
    <script>
        window.toastContent = '@Html.Raw(TempData["toastContent"] ?? "")';
        window.toastType = '@Html.Raw(TempData["toastType"] ?? "")';
        if (window.toastContent && window.toastType) {
            showToast(window.toastContent, window.toastType);
        }
        window.isAuthenticated = '@User.Identity?.IsAuthenticated' === 'True';
    </script>
</body>
    
</html>
