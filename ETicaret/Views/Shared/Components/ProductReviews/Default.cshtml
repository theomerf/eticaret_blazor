@model ProductReviewsViewModel

<!-- Yorum İstatistikleri -->
@await Component.InvokeAsync("RatingStars", new { userReviewsDto = Model?.UserReviews, Mode = "ratings" })
<div data-new-review-count="@Model?.UserReviews?.Count() ?? 0"></div>
<div data-new-average-rating="@(Model?.UserReviews?.Any() == true ? Model.UserReviews.Average(r => r.Rating) : 0)"></div>

<!-- Yorum Listesi -->
<div class="max-h-[400px] md:max-h-[600px] overflow-y-auto pr-2">
    <div class="flex flex-col gap-4 mt-6">
        @foreach (var review in Model?.UserReviews ?? Enumerable.Empty<UserReviewDto>())
        {
            <div class="pd-comment flex flex-col sm:flex-row gap-4 p-4 sm:p-6 bg-gradient-to-br from-white to-gray-50 rounded-2xl shadow-sm border border-indigo-500/10 transition-all duration-300 relative overflow-hidden group hover:shadow-md">
                <div class="flex sm:flex-col items-center sm:items-start justify-between sm:justify-start gap-3 sm:w-32 lg:w-40 border-b sm:border-b-0 sm:border-r border-indigo-100 pb-3 sm:pb-0 sm:pr-4 shrink-0">
                    <div class="flex items-center gap-2 sm:flex-col sm:items-start">
                        <div class="w-10 h-10 sm:w-12 sm:h-12 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 font-bold text-lg shrink-0">
                            @review.ReviewerName.Substring(0,1).ToUpper()
                        </div>
                        <strong class="text-xs sm:text-sm font-bold text-gray-800 break-words line-clamp-2 text-center sm:text-left">@review.ReviewerName</strong>
                    </div>
                    <span class="text-[10px] sm:text-xs text-gray-400 font-medium bg-gray-100 px-2 py-1 rounded whitespace-nowrap">@review.ReviewDate</span>
                </div>

                <div class="flex-1 flex flex-col min-w-0">
                    <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-2">
                        <div class="flex-1 min-w-0">
                            <h5 class="text-sm sm:text-base font-bold text-gray-800 leading-tight break-words">@review.ReviewTitle</h5>
                        </div>
                        <div class="flex gap-0.5 text-amber-400 text-xs sm:text-sm bg-amber-50 px-2 py-1 rounded-lg shrink-0">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= review.Rating)
                                {
                                    <i class="fas fa-star"></i>
                                }
                                else
                                {
                                    <i class="far fa-star text-gray-300"></i>
                                }
                            }
                        </div>
                    </div>
                    
                    <div class="text-gray-600 text-sm leading-relaxed mb-3 bg-gray-50 p-3 sm:p-4 rounded-xl border border-gray-100">
                        <p class="m-0 italic break-words">@review.ReviewText</p>
                    </div>

                    @if (review.ReviewPictureUrl != null && review.ReviewPictureUrl.Any())
                    {
                        <div class="flex gap-2 flex-wrap mb-3">
                            <img src="@review.ReviewPictureUrl" alt="Kullanıcı Fotoğrafı" class="pd-comment-photo w-12 h-12 md:w-16 md:h-16 object-cover rounded-xl cursor-pointer transition-all duration-300 border-2 border-white shadow-sm hover:scale-105 hover:shadow-md hover:border-blue-500 shrink-0" onclick="openPhotoModal('@review.ReviewPictureUrl')">
                        </div>
                    }
                    
                    <div class="flex items-center gap-3 mt-auto pt-2 border-t border-gray-100">
                        <span class="text-gray-400 text-[10px] sm:text-xs font-medium">Bu yorum faydalı mı?</span>
                        <button class="flex items-center gap-1 text-gray-500 hover:text-green-600 transition-colors text-xs font-semibold px-2 py-1 hover:bg-green-50 rounded"><i class="far fa-thumbs-up"></i> <span>(1)</span></button>
                        <button class="flex items-center gap-1 text-gray-500 hover:text-red-500 transition-colors text-xs font-semibold px-2 py-1 hover:bg-red-50 rounded"><i class="far fa-thumbs-down"></i> <span>(0)</span></button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="mt-8 bg-gradient-to-br from-white to-gray-50 rounded-2xl shadow-sm border border-indigo-500/10 p-6 sm:p-8">
        <h4 class="text-xl font-black text-gray-800 mb-6 flex items-center gap-3">
            <span class="w-1 h-8 bg-primary rounded-full"></span>
            Yorum Yazın
        </h4>
        
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 rounded-lg hidden" asp-validation-summary="All"></div>
        
        <form id="reviewForm" class="space-y-6" enctype="multipart/form-data">
            <input type="hidden" asp-for="UserReviewForCreation.ProductId" value="@Model?.ProductId"/>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                <div class="md:col-span-8 space-y-2">
                    <label asp-for="UserReviewForCreation.ReviewTitle" class="block font-bold text-gray-700 text-sm ml-1">Başlık</label>
                    <input asp-for="UserReviewForCreation.ReviewTitle" type="text" 
                           class="w-full py-3 px-5 border border-gray-200 rounded-2xl transition-all duration-300 text-sm font-medium bg-white/80 focus:bg-white focus:border-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-500/10 placeholder:text-gray-400" 
                           placeholder="Yorumunuzu özetleyen kısa bir başlık...">
                    <span asp-validation-for="UserReviewForCreation.ReviewTitle" class="text-red-500 text-xs ml-1"></span>
                </div>

                <div class="md:col-span-4 space-y-2">
                    <label class="block font-bold text-gray-700 text-sm ml-1">Puanınız</label>
                    <div class="bg-white/80 border border-gray-200 rounded-2xl px-4 py-2.5 flex items-center justify-between group hover:border-blue-400 transition-colors duration-300">
                        <div class="flex items-center gap-1.5" id="starRatingContainer" onmouseleave="resetVisualRating()">
                            @for(int i=1; i<=5; i++)
                            {
                                <button type="button" class="star-rating-btn text-2xl text-gray-300 hover:text-amber-400 transition-all duration-200 focus:outline-none hover:scale-110"
                                        data-value="@i" 
                                        onclick="setReviewRating(@i)"
                                        onmouseenter="hoverReviewRating(@i)">
                                    <i class="fas fa-star"></i>
                                </button>
                            }
                        </div>
                        <span class="text-sm font-bold text-cyan-500 bg-indigo-50 px-2.5 py-1 rounded-lg min-w-[30px] text-center" id="ratingDisplay">-</span>
                    </div>
                    <input type="hidden" asp-for="UserReviewForCreation.Rating" id="hiddenRatingInput" value="0" />
                </div>

                <div class="md:col-span-12 space-y-2">
                    <label asp-for="UserReviewForCreation.ReviewText" class="block font-bold text-gray-700 text-sm ml-1">Yorumunuz</label>
                    <textarea asp-for="UserReviewForCreation.ReviewText" 
                              class="w-full py-4 px-5 border border-gray-200 rounded-2xl transition-all duration-300 text-sm font-medium bg-white/80 focus:bg-white focus:border-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-500/10 placeholder:text-gray-400 min-h-[120px] max-h-[300px] resize-none overflow-y-auto scrollbar-thin scrollbar-thumb-gray-300 scrollbar-track-transparent hover:scrollbar-thumb-gray-400" 
                              rows="4" 
                              placeholder="Ürün hakkındaki deneyimlerinizi ve düşüncelerinizi detaylıca paylaşın..."></textarea>
                    <span asp-validation-for="UserReviewForCreation.ReviewText" class="text-red-500 text-xs ml-1"></span>
                </div>

                <div class="md:col-span-12 flex items-center gap-4">
                    <label class="w-14 h-14 flex items-center justify-center bg-white border-2 border-dashed border-gray-300 rounded-2xl cursor-pointer hover:border-blue-500 hover:bg-indigo-50 hover:text-blue-600 text-gray-400 transition-all duration-300 group relative active:scale-95 shadow-sm"
                           title="Fotoğraf Ekle">
                        <i class="fas fa-camera text-xl group-hover:scale-110 transition-transform duration-300"></i>
                        <input name="file" type="file" class="hidden" id="reviewImageInput" accept="image/*" onchange="handleReviewImageSelect(this)" />
                        <div id="imageUploadIndicator" class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-emerald-500 rounded-full border-2 border-white shadow-sm hidden items-center justify-center">
                            <i class="fas fa-check text-[8px] text-white"></i>
                        </div>
                    </label>

                    <button type="button" class="review-submit-btn w-fit bg-button text-white border-none py-3.5 px-8 rounded-2xl cursor-pointer transition-all duration-300 hover:shadow-[0_10px_25px_rgba(79,70,229,0.4)] text-sm font-bold tracking-wide hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-3">
                        <span>Yorumu Gönder</span>
                        <i class="fas fa-paper-plane text-indigo-200"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>


}