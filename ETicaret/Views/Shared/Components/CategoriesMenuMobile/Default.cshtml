@using Application.DTOs
@model IEnumerable<CategoryDto>

<div class="space-y-3">
    <a asp-controller="Products" asp-action="Index" 
       class="flex items-center p-3 rounded-xl bg-blue-50 text-blue-700 font-semibold no-underline active:scale-95 transition-transform">
        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center mr-3 text-blue-600">
            <i class="fa-solid fa-globe"></i>
        </div>
        <span>Tüm Ürünler</span>
    </a>

    @foreach (var category in Model.Where(c => c.ParentId == null))
    {
        var subcategories = Model.Where(c => c.ParentId == category.CategoryId).ToList();
        
        <div class="border border-gray-100 rounded-2xl overflow-hidden shadow-sm bg-white">
            <details class="group">
                <summary class="flex items-center justify-between p-3 cursor-pointer list-none bg-white md:hover:bg-gray-50 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg
                            @(category.CategoryName.Contains("Telefon") ? "bg-purple-100 text-purple-600" :
                              category.CategoryName.Contains("Bilgisayar") ? "bg-blue-100 text-blue-600" :
                              category.CategoryName.Contains("Giyim") ? "bg-pink-100 text-pink-600" :
                              "bg-gray-100 text-gray-600")">
                            
                            @if (category.CategoryName.Contains("Telefon")) { <i class="fa-solid fa-mobile-alt"></i> }
                            else if (category.CategoryName.Contains("Bilgisayar")) { <i class="fa-solid fa-laptop"></i> }
                            else if (category.CategoryName.Contains("Giyim")) { <i class="fa-solid fa-shirt"></i> }
                            else if (category.CategoryName.Contains("Kitap")) { <i class="fa-solid fa-book"></i> }
                            else if (category.CategoryName.Contains("Ev")) { <i class="fa-solid fa-couch"></i> }
                            else { <i class="fa-solid fa-box"></i> }
                        </div>
                        <span class="font-medium text-gray-800">@category.CategoryName</span>
                    </div>
                    
                    @if (subcategories.Any())
                    {
                        <span class="transition-transform duration-300 group-open:rotate-180 w-8 h-8 flex items-center justify-center rounded-full bg-gray-50 text-gray-400">
                            <i class="fa-solid fa-chevron-down text-sm"></i>
                        </span>
                    }
                </summary>
                
                @if (subcategories.Any())
                {
                    <div class="bg-gray-50 p-2 space-y-1 border-t border-gray-100">
                        <a asp-controller="Products" 
                           asp-action="Index" 
                           asp-route-categoryId="@category.CategoryId"
                           class="flex items-center p-2 rounded-lg text-sm text-blue-600 font-medium hover:bg-blue-50 no-underline mb-2">
                            <span>@category.CategoryName Ürünlerini Gör</span>
                            <i class="fa-solid fa-arrow-right ml-2 text-xs"></i>
                        </a>

                        @foreach (var sub in subcategories)
                        {
                            <a asp-controller="Products" 
                               asp-action="Index" 
                               asp-route-categoryId="@sub.CategoryId"
                               class="flex items-center p-2.5 rounded-lg text-gray-600 hover:bg-white hover:text-blue-600 hover:shadow-sm transition-all no-underline bg-white/50 border border-transparent hover:border-gray-100">
                                <span class="w-1.5 h-1.5 bg-gray-300 rounded-full mr-3 group-hover:bg-blue-500 transition-colors"></span>
                                <span>@sub.CategoryName</span>
                            </a>
                        }
                    </div>
                }
            </details>
        </div>
    }
</div>
