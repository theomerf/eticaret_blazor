@using System.Security.Claims
@model ProductDto

@{
    var favouriteIds = ViewBag.FavouriteIds as List<int>;

    var cart = Context.RequestServices.GetRequiredService<Cart>();
    var isInCart = cart?.Lines?.Any(l => l.ProductId == Model?.ProductId) ?? false;
}

<div class="my-1 sm:my-2 md:my-3 px-0.5 sm:px-2.5 [perspective:1000px]">
    <div class="product-card animate-[fadeInUp_0.6s_cubic-bezier(0.175,0.885,0.32,1.275)] group flex flex-col"
         data-cursor-id="@Model.ProductId"
         data-cursor-price="@(Model.DiscountPrice ?? Model.ActualPrice)"
         data-cursor-rating="@Model.AverageRating"
         data-cursor-review-count="@Model.ReviewCount">
        <div class="flex flex-col">
            <a asp-action="Get" asp-controller="Products" asp-route-slug="@Model?.Slug"
                class="no-underline relative z-[2] flex flex-col">
                @if (Model?.Discount > 0)
                {
                    <div
                        class="absolute top-1.5 left-1.5 sm:top-5 sm:left-5 bg-gradient-to-br from-red-500 to-red-400 text-white rounded-lg sm:rounded-3xl px-1.5 py-0.5 sm:px-4 sm:py-2 text-[0.5rem] sm:text-xs font-bold shadow-sm z-[3] flex items-center uppercase animate-pulse">
                        <span
                            class="[text-shadow:0_1px_2px_rgba(0,0,0,0.2)] mr-0.5">%@Model?.Discount</span>
                        <span class="hidden sm:inline">İndirim</span>
                    </div>
                }
 
                <div
                    class="relative h-[120px] sm:h-[240px] md:h-[260px] bg-gradient-to-br from-white via-slate-50 to-slate-100 overflow-hidden rounded-t-lg sm:rounded-t-2xl after:absolute after:bottom-0 after:left-0 after:right-0 after:h-5 sm:after:h-7 after:bg-gradient-to-t after:from-white/80 after:to-transparent after:z-[1]">
                    <img src="@Model?.Images?.First().ImageUrl"
                        class="w-full h-full object-contain p-2 sm:p-5 transition-all duration-[600ms] [transition-timing-function:cubic-bezier(0.25,0.46,0.45,0.94)] [filter:drop-shadow(0_8px_16px_rgba(0,0,0,0.1))] group-hover:scale-110 group-hover:[transform:scale(1.1)_rotateY(5deg)] group-hover:[filter:drop-shadow(0_12px_24px_rgba(0,0,0,0.15))]"
                        alt="@Model?.ProductName" loading="lazy">
                </div>
 
                <div
                    class="px-2 pt-2 pb-1 sm:px-6 sm:pt-4 sm:pb-3 md:px-6 md:pt-5 md:pb-4 text-center flex flex-col relative z-[2] transition-transform duration-300 group-hover:-translate-y-0.5">
                    <div class="h-[3.5rem] sm:h-[5rem] md:h-[5.5rem] flex flex-col">
                        <h5
                            class="text-[0.7rem] leading-tight sm:text-lg font-bold m-0 overflow-hidden text-ellipsis [-webkit-line-clamp:2] [-webkit-box-orient:vertical] [display:-webkit-box] text-slate-800 sm:leading-[1.4] tracking-tight [text-shadow:0_1px_2px_rgba(0,0,0,0.05)]">
                            @Model?.ProductName
                        </h5>
                        <div
                            class="text-[0.6rem] sm:text-base text-amber-400 mt-0.5 [filter:drop-shadow(0_2px_4px_rgba(251,191,36,0.2))]">
                            @await Component.InvokeAsync("RatingStars", new { productDto = Model, Mode = "starsForCard" })
                        </div>
                    </div>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-0.5 sm:gap-3 mt-auto">
                        @if (Model?.DiscountPrice != null && Model?.ActualPrice > Model?.DiscountPrice)
                        {
                            <span class="line-through text-slate-400 text-[0.6rem] sm:text-base font-medium">
                                @Model?.ActualPrice.ToString("C2", new CultureInfo("tr-TR"))
                            </span>
 
                            <span
                                class="font-extrabold text-xs sm:text-xl md:text-2xl bg-primary bg-clip-text text-transparent [text-shadow:0_2px_4px_rgba(59,12,163,0.1)] tracking-tight">
                                @Model?.DiscountPrice?.ToString("C2", new CultureInfo("tr-TR"))
                            </span>
                        }
                        else if (Model?.DiscountPrice == null)
                        {
                            <span
                                class="font-extrabold text-xs sm:text-xl md:text-2xl bg-primary bg-clip-text text-transparent [text-shadow:0_2px_4px_rgba(59,12,163,0.1)] tracking-tight">
                                @Model?.ActualPrice.ToString("C2", new CultureInfo("tr-TR"))
                            </span>
                        }
                    </div>
                </div>
            </a>
        </div>

        <div
            class="absolute top-2 right-2 sm:top-5 sm:right-5 flex flex-col gap-1 sm:gap-3 z-[4] opacity-[0%] translate-x-5 scale-75 transition-all duration-[400ms] [transition-timing-function:cubic-bezier(0.68,-0.55,0.265,1.55)] group-hover:opacity-100 group-hover:translate-x-0 group-hover:scale-100">
            @if (User.Identity != null && User.Identity.IsAuthenticated && Context.User.FindFirstValue(ClaimTypes.NameIdentifier) != null)
            {
                if (favouriteIds != null && Model != null && favouriteIds.Contains(Model.ProductId))
                {
                    <button type="button"
                        class="remove-from-favs-btn w-7 h-7 sm:w-11 sm:h-11 rounded-full bg-gradient-to-br from-red-50 to-red-100 flex items-center justify-center border-none shadow-[0_8px_16px_rgba(0,0,0,0.1),inset_0_1px_0_rgba(255,255,255,0.8)] text-red-500 transition-all duration-300 [transition-timing-function:cubic-bezier(0.175,0.885,0.32,1.275)] cursor-pointer backdrop-blur-[10px] border border-white/30 lg:hover:scale-110 lg:hover:rotate-[5deg] hover:shadow-[0_12px_24px_rgba(239,68,68,0.2)]"
                        data-product-id="@Model?.ProductId" title="Favorilerden Kaldır"
                        id="remove-from-favs-btn">
                        <i class="fas fa-heart text-xs sm:text-lg"></i>
                    </button>
                }
                else
                {
                    <button type="button"
                        class="add-to-favs-btn w-7 h-7 sm:w-11 sm:h-11 rounded-full bg-gradient-to-br from-white to-slate-50 flex items-center justify-center border-none shadow-[0_8px_16px_rgba(0,0,0,0.1),inset_0_1px_0_rgba(255,255,255,0.8)] text-slate-500 transition-all duration-300 [transition-timing-function:cubic-bezier(0.175,0.885,0.32,1.275)] cursor-pointer backdrop-blur-[10px] border border-white/30 lg:hover:scale-110 lg:hover:rotate-[5deg] hover:shadow-[0_12px_24px_rgba(0,0,0,0.15)] hover:bg-gradient-to-br hover:from-red-50 hover:to-red-100 hover:text-red-500"
                        data-product-id="@Model?.ProductId" title="Favorilere Ekle">
                        <i class="far fa-heart text-xs sm:text-lg"></i>
                    </button>
                }
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                    class="w-7 h-7 sm:w-11 sm:h-11 rounded-full bg-gradient-to-br from-white to-slate-50 flex items-center justify-center border-none shadow-[0_8px_16px_rgba(0,0,0,0.1),inset_0_1px_0_rgba(255,255,255,0.8)] text-slate-500 transition-all duration-300 [transition-timing-function:cubic-bezier(0.175,0.885,0.32,1.275)] cursor-pointer backdrop-blur-[10px] border border-white/30 hover:scale-110 hover:rotate-[5deg] hover:shadow-[0_12px_24px_rgba(0,0,0,0.15)] hover:bg-gradient-to-br hover:from-red-50 hover:to-red-100 hover:text-red-500 no-underline"
                    data-product-id="@Model?.ProductId" title="Favorilere Ekle">
                    <i class="far fa-heart text-xs sm:text-lg"></i>
                </a>
            }
        </div>

        <div class="cart-action flex justify-center px-2 pb-2 sm:px-4 sm:pb-4 relative z-[2] transition-all duration-300">
            @{
                if (isInCart)
                {
                    <button type="button"
                        class="remove-from-cart-btn w-[90%] px-2 py-2 sm:px-4 sm:py-3 border-none rounded-xl bg-gradient-to-br from-red-500 via-red-600 to-red-700 text-white font-bold text-[0.6rem] sm:text-base flex items-center justify-center gap-1 sm:gap-2.5 transition-all duration-[400ms] [transition-timing-function:cubic-bezier(0.175,0.885,0.32,1.275)] shadow-[0_10px_25px_rgba(239,68,68,0.3),inset_0_1px_0_rgba(255,255,255,0.2)] uppercase tracking-wide cursor-pointer relative overflow-hidden before:content-[''] before:absolute before:top-0 before:-left-full before:w-full before:h-full before:bg-gradient-to-r before:from-transparent before:via-white/20 before:to-transparent before:transition-[left] before:duration-500 before:ease-out hover:before:left-full hover:bg-gradient-to-br hover:from-red-600 hover:via-red-700 hover:to-red-800 hover:shadow-[0_15px_35px_rgba(239,68,68,0.4),inset_0_1px_0_rgba(255,255,255,0.3)] lg:hover:-translate-y-1 hover:scale-[1.02] [&.processing]:opacity-60 [&.processing]:pointer-events-none [&.processing]:animate-[processing_1.5s_infinite]"
                        data-product-id="@Model?.ProductId">
                        <span class="hidden sm:inline mr-1 sm:mr-2 [text-shadow:0_1px_2px_rgba(0,0,0,0.1)]">Sepetten
                            Çıkar</span>
                        <span class="sm:hidden mr-0.5 [text-shadow:0_1px_2px_rgba(0,0,0,0.1)]">Çıkar</span>
                        <span
                            class="inline-flex items-center transition-transform duration-300 group-hover:scale-110 group-hover:rotate-[5deg]">
                            <i class="fas fa-trash-alt text-xs sm:text-lg [filter:drop-shadow(0_1px_2px_rgba(0,0,0,0.1))]"></i>
                        </span>
                    </button>
                }
                else
                {
                    <button type="button"
                        class="add-to-cart-btn w-[90%] px-2 py-2 sm:px-4 sm:py-3 border-none rounded-xl bg-button text-white font-bold text-[0.6rem] sm:text-base flex items-center justify-center gap-1 sm:gap-2.5 transition-all duration-[400ms] [transition-timing-function:cubic-bezier(0.175,0.885,0.32,1.275)] shadow-[0_10px_25px_rgba(59,130,246,0.3),inset_0_1px_0_rgba(255,255,255,0.2)] uppercase tracking-wide cursor-pointer relative overflow-hidden before:content-[''] before:absolute before:top-0 before:-left-full before:w-full before:h-full before:bg-gradient-to-r before:from-transparent before:via-white/20 before:to-transparent before:transition-[left] before:duration-500 before:ease-out hover:before:left-full hover:bg-button-hover hover:shadow-[0_15px_35px_rgba(59,130,246,0.4),inset_0_1px_0_rgba(255,255,255,0.3)] lg:hover:-translate-y-1 hover:scale-[1.02] [&.processing]:opacity-60 [&.processing]:pointer-events-none [&.processing]:animate-[processing_1.5s_infinite]"
                        data-product-id="@Model?.ProductId">
                        <span class="hidden sm:inline mr-1 sm:mr-2 [text-shadow:0_1px_2px_rgba(0,0,0,0.1)]">Sepete Ekle</span>
                        <span class="sm:hidden mr-0.5 [text-shadow:0_1px_2px_rgba(0,0,0,0.1)]">Ekle</span>
                        <span
                            class="inline-flex items-center transition-transform duration-300 group-hover:scale-110 group-hover:rotate-[5deg]">
                            <i class="fas fa-cart-plus text-xs sm:text-lg [filter:drop-shadow(0_1px_2px_rgba(0,0,0,0.1))]"></i>
                        </span>
                    </button>
                }
            }
        </div>
    </div>
</div>