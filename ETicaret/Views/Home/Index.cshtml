@section Scripts {
	<script src="~/js/product-card.js" asp-append-version="true"></script>
	<script src="~/js/index.js" asp-append-version="true"></script>
}

@{
	ViewData["Title"] = "Ana Sayfa";
}

<!-- Duyurular -->
<section class="relative rounded-lg overflow-hidden shadow-md h-[300px] sm:h-[400px] lg:h-[550px] group">
	<div id="heroCarousel" class="relative h-full overflow-hidden">
		<div id="carouselWrapper" class="flex h-full transition-transform duration-700 ease-in-out">
			<div class="carousel-item-custom min-w-full h-full relative">
				<img src="~/images/a1.png" class="w-full h-full object-cover" alt="Kampanya">
				<div
					class="absolute bottom-0 left-0 w-full p-4 sm:p-8 lg:p-12 bg-gradient-to-t from-black/80 to-transparent text-white z-10 opacity-[0%] translate-y-4 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
					<h2 class="text-lg sm:text-xl lg:text-2xl font-bold mb-2 sm:mb-4 transform transition-all duration-700 translate-y-0 opacity-100">
						Büyük Yaz İndirimleri</h2>
					<a asp-controller="Products" asp-action="Index"
						class="index-carousel-discover-button transform transition-all duration-700 delay-200 translate-y-0 opacity-100">Hemen
						Keşfet</a>
				</div>
			</div>

			<div class="carousel-item-custom min-w-full h-full relative">
				<img src="~/images/a2.png" class="w-full h-full object-cover" alt="Yeni Gelenler">
				<div
					class="absolute bottom-0 left-0 w-full p-4 sm:p-8 lg:p-12 bg-gradient-to-t from-black/80 to-transparent text-white z-10 opacity-[0%] translate-y-4 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
					<h2 class="text-lg sm:text-xl lg:text-2xl font-bold mb-2 sm:mb-4 transform transition-all duration-700 translate-y-0 opacity-100">
						Yeni Sezon Koleksiyonu</h2>
					<a asp-controller="Products" asp-action="Index"
						class="index-carousel-discover-button transform transition-all duration-700 delay-200 translate-y-0 opacity-100">Alışverişe
						Başla</a>
				</div>
			</div>

			<div class="carousel-item-custom min-w-full h-full relative">
				<img src="~/images/a3.png" class="w-full h-full object-cover" alt="Fırsat">
				<div
					class="absolute bottom-0 left-0 w-full p-4 sm:p-8 lg:p-12 bg-gradient-to-t from-black/80 to-transparent text-white z-10 opacity-[0%] translate-y-4 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
					<h2 class="text-lg sm:text-xl lg:text-2xl font-bold mb-2 sm:mb-4 transform transition-all duration-700 translate-y-0 opacity-100">
						Süper Teknoloji Fırsatları</h2>
					<a asp-controller="Products" asp-action="Index"
						class="index-carousel-discover-button transform transition-all duration-700 delay-200 translate-y-0 opacity-100">İncele</a>
				</div>
			</div>
		</div>

		<div class="absolute bottom-4 sm:bottom-8 left-1/2 -translate-x-1/2 flex gap-2 sm:gap-3 z-20">
			<button class="carousel-indicator w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/40 hover:bg-white/80 transition-all duration-300"
				data-slide="0"></button>
			<button class="carousel-indicator w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/40 hover:bg-white/80 transition-all duration-300"
				data-slide="1"></button>
			<button class="carousel-indicator w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/40 hover:bg-white/80 transition-all duration-300"
				data-slide="2"></button>
		</div>

		<button id="prevBtn"
			class="absolute left-2 sm:left-4 lg:left-6 top-1/2 -translate-y-1/2 w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 rounded-full bg-white/30 hover:bg-primary text-white flex items-center justify-center opacity-[0%] group-hover:opacity-100 transition-all duration-300 z-20 backdrop-blur-2xl border border-white/20">
			<i class="fas fa-chevron-left text-sm sm:text-lg lg:text-xl"></i>
		</button>
		<button id="nextBtn"
			class="absolute right-2 sm:right-4 lg:right-6 top-1/2 -translate-y-1/2 w-10 h-10 sm:w-12 sm:h-12 lg:w-14 lg:h-14 rounded-full bg-white/30 hover:bg-primary text-white flex items-center justify-center opacity-[0%] group-hover:opacity-100 transition-all duration-300 z-20 backdrop-blur-2xl border border-white/20">
			<i class="fas fa-chevron-right text-sm sm:text-lg lg:text-xl"></i>
		</button>
	</div>
</section>

<!-- Vitrin Ürünleri -->
<section class="p-4 sm:p-8 lg:p-16 rounded-lg shadow-md border border-gray-200 bg-white mt-10 sm:mt-16 lg:mt-20">
	<div class="flex flex-col md:flex-row lg:justify-between md:items-center mb-4 gap-3 md:gap-4">
		<div class="flex flex-col items-center">
			<h1 class="index-section-title">
				Öne Çıkan Ürünler
			</h1>
			<h2 class="index-section-subtitle">En çok tercih edilen ürünler</h2>
		</div>
		<div class="flex justify-center lg:justify-start items-center gap-1.5 sm:gap-2 flex-wrap">
			<button href="#" class="index-section-nav-button active" disabled>
				Tümü
			</button>
			<button href="#" class="index-section-nav-button">
				Yeni Gelenler
			</button>
			<button href="#" class="index-section-nav-button">
				En Çok Satanlar
			</button>
			<button href="#" class="index-section-nav-button">
				İndirimli
			</button>
		</div>
	</div>
	<div class="grid grid-cols-2 lg:grid-cols-5 xl:grid-cols-5 gap-2 sm:gap-4 lg:gap-8 xl:gap-10">
		@await Component.InvokeAsync("Showcase")
	</div>
	<div class="flex justify-center mt-4 sm:mt-5">
		<a asp-controller="Products" asp-action="Index" class="inline-block index-section-nav-button bg-primary text-white hover:-translate-y-1 py-2 sm:py-3 px-4 sm:px-8">
			Tüm Ürünleri Görüntüle
			<i class="fas fa-long-arrow-alt-right ms-2"></i>
		</a>
	</div>
</section>

<!-- Popüler Kategoriler -->
<section class="mt-10 sm:mt-16 lg:mt-20">
	<div class="text-center mb-4 sm:mb-5">
		<h2 class="index-section-title">Popüler Kategoriler</h2>
		<p class="index-section-subtitle">En çok tercih edilen ürün kategorileri</p>
	</div>
	<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
		<a class="text-decoration-none" asp-controller="Products" asp-action="Index" asp-route-categoryId="1">
			<div class="index-category-card group">
				<div class="index-category-icon">
					<i class="fas fa-mobile-alt"></i>
				</div>
				<h4 class="text-gray-800 font-semibold text-lg mb-1">Teknoloji</h4>
				<p class="text-gray-500 text-sm">782 ürün</p>
				<div class="index-category-arrow">
					<i class="fas fa-chevron-right"></i>
				</div>
			</div>
		</a>

		<a class="text-decoration-none" asp-controller="Products" asp-action="Index" asp-route-categoryId="2">
			<div class="index-category-card group">
				<div class="index-category-icon">
					<i class="fas fa-tshirt"></i>
				</div>
				<h4 class="text-gray-800 font-semibold text-lg mb-1">Giyim</h4>
				<p class="text-gray-500 text-sm">349 ürün</p>
				<div class="index-category-arrow">
					<i class="fas fa-chevron-right"></i>
				</div>
			</div>
		</a>

		<a class="text-decoration-none" asp-controller="Products" asp-action="Index" asp-route-categoryId="3">
			<div class="index-category-card group">
				<div class="index-category-icon">
					<i class="fas fa-home"></i>
				</div>
				<h4 class="text-gray-800 font-semibold text-lg mb-1">Ev Aletleri</h4>
				<p class="text-gray-500 text-sm">215 ürün</p>
				<div class="index-category-arrow">
					<i class="fas fa-chevron-right"></i>
				</div>
			</div>
		</a>

		<a class="text-decoration-none" asp-controller="Products" asp-action="Index" asp-route-categoryId="5">
			<div class="index-category-card group">
				<div class="index-category-icon">
					<i class="fa-solid fa-book"></i>
				</div>
				<h4 class="text-gray-800 font-semibold text-lg mb-1">Kitap</h4>
				<p class="text-gray-500 text-sm">564 ürün</p>
				<div class="index-category-arrow">
					<i class="fas fa-chevron-right"></i>
				</div>
			</div>
		</a>
	</div>
</section>

<!-- Kampanya Bannerları -->
<section class="mt-10 sm:mt-16 lg:mt-20">
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-8 lg:gap-12 xl:gap-16">
		<div class="index-banner-card">
			<img src="~/images/a1.jpeg" alt="Kampanya 1" class="index-banner-img">
			<div class="index-banner-content">
				<span class="index-banner-badge" style="background-color: var(--secondary-color)">Sınırlı Süre</span>
				<h3 class="font-bold text-xl sm:text-2xl lg:text-3xl mb-2">Yaz İndirimleri</h3>
				<p class="mb-3 sm:mb-4 opacity-90 text-sm sm:text-base">%40'a varan indirimler</p>
				<a href="#" class="index-banner-button">
					Keşfet
					<i class="fas fa-arrow-right ms-2"></i>
				</a>
			</div>
		</div>

		<div class="index-banner-card">
			<img src="~/images/a1.jpeg" alt="Kampanya 1" class="index-banner-img">
			<div class="index-banner-content">
				<span class="index-banner-badge" style="background-color: var(--secondary-color)">Yeni Trend</span>
				<h3 class="font-bold text-xl sm:text-2xl lg:text-3xl mb-2">Yeni Gelenler</h3>
				<p class="mb-3 sm:mb-4 opacity-90 text-sm sm:text-base">En yeni ürünleri keşfedin</p>
				<a href="#" class="index-banner-button">
					Keşfet
					<i class="fas fa-arrow-right ms-2"></i>
				</a>
			</div>
		</div>
	</div>
</section>

<!-- İndirim Kampanyası -->
<section class="mt-10 sm:mt-16 lg:mt-20 bg-primary relative overflow-hidden rounded-lg p-3 sm:p-4 lg:p-5 shadow-md">
	<div class="relative z-[2] text-center text-white px-3 sm:px-6 lg:px-8 py-3 sm:py-4">
		<span
			class="inline-block bg-white/20 text-white px-2 sm:px-3 py-1.5 sm:py-2 rounded-3xl text-xs sm:text-sm font-semibold mb-3 sm:mb-4 lg:mb-6 uppercase">Sınırlı
			Süre</span>
		<h2 class="text-2xl sm:text-3xl lg:text-4xl xl:text-5xl font-extrabold mb-3 sm:mb-4">Büyük Yaz Kampanyası!</h2>
		<p class="text-sm sm:text-base lg:text-lg xl:text-xl opacity-90 max-w-[700px] mx-auto">Seçili ürünlerde %30'a varan indirimler ve 300₺ üzeri
			alışverişlerde ücretsiz
			kargo fırsatını kaçırmayın.</p>
		<div class="flex justify-center gap-2 sm:gap-3 my-4 sm:my-6 lg:my-8">
			<div class="flex flex-col bg-white/20 rounded-lg p-2 sm:p-3 lg:p-4 min-w-[60px] sm:min-w-[75px] lg:min-w-[90px] text-center shadow-md">
				<span class="black text-xl sm:text-2xl lg:text-3xl font-semibold mb-1 sm:mb-2" id="days">00</span>
				<span class="text-xs sm:text-sm uppercase opacity-80">Gün</span>
			</div>
			<div class="flex flex-col bg-white/20 rounded-lg p-2 sm:p-3 lg:p-4 min-w-[60px] sm:min-w-[75px] lg:min-w-[90px] text-center shadow-md">
				<span class="black text-xl sm:text-2xl lg:text-3xl font-semibold mb-1 sm:mb-2" id="hours">00</span>
				<span class="text-xs sm:text-sm uppercase opacity-80">Saat</span>
			</div>
			<div class="flex flex-col bg-white/20 rounded-lg p-2 sm:p-3 lg:p-4 min-w-[60px] sm:min-w-[75px] lg:min-w-[90px] text-center shadow-md">
				<span class="black text-xl sm:text-2xl lg:text-3xl font-semibold mb-1 sm:mb-2" id="minutes">00</span>
				<span class="text-xs sm:text-sm uppercase opacity-80">Dakika</span>
			</div>
			<div class="flex flex-col bg-white/20 rounded-lg p-2 sm:p-3 lg:p-4 min-w-[60px] sm:min-w-[75px] lg:min-w-[90px] text-center shadow-md">
				<span class="black text-xl sm:text-2xl lg:text-3xl font-semibold mb-1 sm:mb-2" id="seconds">00</span>
				<span class="text-xs sm:text-sm uppercase opacity-80">Saniye</span>
			</div>
		</div>
		<a asp-controller="Products" asp-action="Index"
			class="bg-white inline-block px-3 sm:px-4 py-2 sm:py-3 text-sm sm:text-base lg:text-lg shadow-sm rounded-3xl font-semibold transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
			style="color: var(--secondary-color);">
			Hemen Alışveriş Yap
			<i class="fas fa-shopping-cart ms-2"></i>
		</a>
	</div>
</section>

<!-- Özellikler -->
<section class="p-3 sm:p-4 lg:p-5 rounded-lg shadow-md border border-gray-200 bg-white mt-10 sm:mt-16 lg:mt-20">
	<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-0">
		<div class="flex items-start gap-3 sm:gap-4 p-3 sm:p-4 lg:p-6 transition-all ease-out duration-300 group">
			<div class="index-feature-icon">
				<i class="fas fa-truck"></i>
			</div>
			<div class="flex flex-col flex-1">
				<h4 class="font-semibold text-lg mb-1">Hızlı Teslimat</h4>
				<p class="text-gray-500 text-sm">24 saat içinde kargo</p>
			</div>
		</div>

		<div class="flex items-start gap-3 sm:gap-4 p-3 sm:p-4 lg:p-6 transition-all ease-out duration-300 group">
			<div class="index-feature-icon">
				<i class="fas fa-undo"></i>
			</div>
			<div class="flex flex-col flex-1">
				<h4 class="font-semibold text-lg mb-1">Kolay İade</h4>
				<p class="text-gray-500 text-sm">14 gün içinde ücretsiz iade</p>
			</div>
		</div>

		<div class="flex items-start gap-3 sm:gap-4 p-3 sm:p-4 lg:p-6 transition-all ease-out duration-300 group">
			<div class="index-feature-icon">
				<i class="fas fa-lock"></i>
			</div>
			<div class="flex flex-col flex-1">
				<h4 class="font-semibold text-lg mb-1">Güvenli Ödeme</h4>
				<p class="text-gray-500 text-sm">SSL sertifikalı güvenli işlem</p>
			</div>
		</div>

		<div class="flex items-start gap-3 sm:gap-4 p-3 sm:p-4 lg:p-6 transition-all ease-out duration-300 group">
			<div class="index-feature-icon">
				<i class="fas fa-headset"></i>
			</div>
			<div class="flex flex-col flex-1">
				<h4 class="font-semibold text-lg mb-1">7/24 Destek</h4>
				<p class="text-gray-500 text-sm">Her zaman yanınızdayız</p>
			</div>
		</div>
	</div>
</section>