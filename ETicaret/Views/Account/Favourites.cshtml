@model List<ProductDto>

@{
    ViewData["Title"] = "Favori Ürünlerim";
}

@section Scripts {
    <script asp-append-version="true" src="~/js/product-card.js"></script>
}

<div class="fav-page">
    <h2 class="page-title">Favori Ürünlerim</h2>
    
    @if (Model == null || !Model.Any())
    {
        <div class="fav-empty">
            <div class="fav-empty-icon">
                <i class="fa fa-heart-broken"></i>
            </div>
            <h4 class="text-slate-800 font-bold text-2xl mb-2">Henüz favori ürününüz bulunmuyor</h4>
            <p class="text-slate-500 max-w-md mx-auto mb-8">Beğendiğiniz ürünleri favorilerinize ekleyerek daha sonra kolayca ulaşabilirsiniz.</p>
            <a asp-controller="Products" asp-action="Index" class="fav-btn-shop">
                <i class="fa fa-shopping-bag"></i> Alışverişe Başla
            </a>
        </div>
    }
    else
    {
        <div class="fav-wrapper">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (ProductDto prd in Model)
                {
                    <div class="product-wrapper">
                        <partial name="_ProductCard" model="@prd" />
                    </div>
                }
            </div>
        </div>
    }
</div>
