@model ETicaret.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Alışverişi Tamamla";
}

@section Styles {
    <style>
        .custom-glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }
        .smooth-shadow {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }
        .option-radio:checked + div {
            border-color: #2575fc;
            background-color: #eff6ff;
        }
        .option-radio:checked + div .radio-indicator {
            border-color: #2575fc;
            background-color: #2575fc;
        }
    </style>
}

<div>
    <div class="container mx-auto px-4 selection:bg-primary/20">
        <form asp-action="Checkout" asp-controller="Order" method="post" id="checkoutForm">
            <div class="flex flex-col lg:flex-row gap-8 relative">

                <!-- LEFT SIDE: Forms & Options -->
                <div class="w-full lg:w-2/3 space-y-6">
                    
                    <!-- 1. Address Selection -->
                    <div class="bg-white rounded-2xl p-6 lg:p-8 smooth-shadow border border-gray-100">
                        <div class="flex items-center justify-between mb-6">
                            <h2 class="text-xl font-bold text-gray-800 flex items-center gap-3">
                                <span class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-primary">
                                    <i class="fas fa-map-marker-alt"></i>
                                </span>
                                Teslimat Adresi
                            </h2>
                        </div>

                        @if (Model.Addresses != null && Model.Addresses.Any())
                        {
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                @foreach (var address in Model.Addresses)
                                {
                                    var isFirst = Model.Addresses.First() == address;
                                    <label class="relative cursor-pointer group">
                                        <input type="radio" name="AddressId" value="@address.AddressId" 
                                               class="peer sr-only" @(isFirst ? "checked" : "") required>
                                        <div class="p-5 rounded-xl border-2 @(isFirst ? "border-primary bg-blue-50/30" : "border-gray-100 hover:border-gray-300 bg-white hover:bg-gray-50") peer-checked:border-primary peer-checked:bg-blue-50/30 transition-all h-full">
                                            <div class="flex justify-between items-start mb-2">
                                                <span class="font-bold text-gray-800">@address.Title</span>
                                                <span class="w-5 h-5 rounded-full border-2 @(isFirst ? "border-primary bg-primary" : "border-gray-300") peer-checked:border-primary peer-checked:bg-primary flex items-center justify-center text-white text-xs transition-all">
                                                    <i class="fas fa-check"></i>
                                                </span>
                                            </div>
                                            <p class="text-sm text-gray-600 leading-relaxed mb-3">
                                                @address.AddressLine<br>
                                                @address.District / @address.City<br>
                                                @if (!string.IsNullOrEmpty(address.PostalCode))
                                                {
                                                    <text>@address.PostalCode</text>
                                                }
                                            </p>
                                            @if (address.IsDefault)
                                            {
                                                <span class="text-xs font-semibold text-primary bg-primary/10 px-2 py-1 rounded">Varsayılan</span>
                                            }
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-8">
                                <p class="text-gray-500 mb-4">Kayıtlı adresiniz bulunmamaktadır.</p>
                                <a href="/Account/Addresses" class="text-primary hover:text-blue-700 font-semibold">
                                    + Yeni Adres Ekle
                                </a>
                            </div>
                        }
                    </div>

                    <!-- 2. Payment Method -->
                    <div class="bg-white rounded-2xl p-6 lg:p-8 smooth-shadow border border-gray-100">
                        <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-3">
                             <span class="w-10 h-10 rounded-full bg-purple-50 flex items-center justify-center text-primary">
                                <i class="fas fa-wallet"></i>
                            </span>
                            Ödeme Yöntemi
                        </h2>

                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <label class="cursor-pointer">
                                <input type="radio" name="PaymentMethod" value="CreditCard" class="peer sr-only" checked required>
                                <div class="flex flex-col items-center justify-center p-4 rounded-xl border-2 border-gray-100 bg-white hover:bg-gray-50 peer-checked:border-primary peer-checked:bg-blue-50/10 transition-all h-24">
                                    <i class="fas fa-credit-card text-2xl mb-2 text-gray-600 peer-checked:text-primary"></i>
                                    <span class="text-sm font-semibold text-gray-700 peer-checked:text-primary">Banka/Kredi Kartı</span>
                                </div>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="PaymentMethod" value="BankTransfer" class="peer sr-only">
                                <div class="flex flex-col items-center justify-center p-4 rounded-xl border-2 border-gray-100 bg-white hover:bg-gray-50 peer-checked:border-primary peer-checked:bg-blue-50/10 transition-all h-24">
                                    <i class="fas fa-university text-2xl mb-2 text-gray-600 peer-checked:text-primary"></i>
                                    <span class="text-sm font-semibold text-gray-700 peer-checked:text-primary">Havale/EFT</span>
                                </div>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="PaymentMethod" value="CashOnDelivery" class="peer sr-only">
                                <div class="flex flex-col items-center justify-center p-4 rounded-xl border-2 border-gray-100 bg-white hover:bg-gray-50 peer-checked:border-primary peer-checked:bg-blue-50/10 transition-all h-24">
                                    <i class="fas fa-hand-holding-usd text-2xl mb-2 text-gray-600 peer-checked:text-primary"></i>
                                    <span class="text-sm font-semibold text-gray-700 peer-checked:text-primary">Kapıda Ödeme</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- 3. Shipping Method -->
                    <div class="bg-white rounded-2xl p-6 lg:p-8 smooth-shadow border border-gray-100">
                        <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-3">
                            <span class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center text-primary">
                                <i class="fas fa-truck"></i>
                            </span>
                            Kargo Seçenekleri
                        </h2>

                        <div class="space-y-3">
                            <label class="cursor-pointer">
                                <input type="radio" name="ShippingMethod" value="Standard" class="peer sr-only" checked required>
                                <div class="flex items-center justify-between p-4 rounded-xl border-2 border-gray-100 bg-white hover:bg-gray-50 peer-checked:border-primary peer-checked:bg-blue-50/10 transition-all">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 rounded-full bg-blue-50 flex items-center justify-center text-primary">
                                            <i class="fas fa-shipping-fast text-lg"></i>
                                        </div>
                                        <div>
                                            <div class="font-bold text-gray-800">Standart Kargo</div>
                                            <div class="text-sm text-gray-500">3-5 iş günü</div>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <div class="font-bold text-gray-800" id="standardShippingCost">29.99 ₺</div>
                                        <div class="text-xs text-green-600">500₺ üzeri ücretsiz</div>
                                    </div>
                                </div>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="ShippingMethod" value="Express" class="peer sr-only">
                                <div class="flex items-center justify-between p-4 rounded-xl border-2 border-gray-100 bg-white hover:bg-gray-50 peer-checked:border-primary peer-checked:bg-blue-50/10 transition-all">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 rounded-full bg-purple-50 flex items-center justify-center text-primary">
                                            <i class="fas fa-bolt text-lg"></i>
                                        </div>
                                        <div>
                                            <div class="font-bold text-gray-800">Hızlı Kargo</div>
                                            <div class="text-sm text-gray-500">1-2 iş günü</div>
                                        </div>
                                    </div>
                                    <div class="font-bold text-gray-800">49.99 ₺</div>
                                </div>
                            </label>

                            <label class="cursor-pointer">
                                <input type="radio" name="ShippingMethod" value="HandlingOnly" class="peer sr-only">
                                <div class="flex items-center justify-between p-4 rounded-xl border-2 border-gray-100 bg-white hover:bg-gray-50 peer-checked:border-primary peer-checked:bg-blue-50/10 transition-all">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 rounded-full bg-orange-50 flex items-center justify-center text-primary">
                                            <i class="fas fa-store text-lg"></i>
                                        </div>
                                        <div>
                                            <div class="font-bold text-gray-800">Mağazadan Teslim</div>
                                            <div class="text-sm text-gray-500">Aynı gün</div>
                                        </div>
                                    </div>
                                    <div class="font-bold text-green-600">Ücretsiz</div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- 4. Coupon Code -->
                    <div class="bg-white rounded-2xl p-6 lg:p-8 smooth-shadow border border-gray-100">
                        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-3">
                            <span class="w-10 h-10 rounded-full bg-yellow-50 flex items-center justify-center text-primary">
                                <i class="fas fa-tag"></i>
                            </span>
                            İndirim Kuponu
                        </h2>
                        <div class="flex gap-2">
                            <input type="text" name="CouponCode" id="couponCode" 
                                   class="flex-1 px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-primary focus:outline-none transition-colors" 
                                   placeholder="Kupon kodunuzu girin">
                            <button type="button" onclick="applyCoupon()" 
                                    class="px-6 py-3 bg-primary hover:bg-secondary text-white font-semibold rounded-xl transition-colors">
                                Uygula
                            </button>
                        </div>
                        <div id="couponMessage" class="mt-2 text-sm"></div>
                    </div>
                </div>

                <!-- RIGHT SIDE: Order Summary (Sticky) -->
                <div class="w-full lg:w-1/3">
                    <div class="bg-white rounded-2xl p-6 lg:p-8 smooth-shadow border border-gray-100 lg:sticky lg:top-24">
                        <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center gap-2">
                            <i class="fas fa-shopping-cart text-primary"></i>
                            Sipariş Özeti
                        </h3>

                        <!-- Cart Items -->
                        <div class="space-y-3 mb-6 max-h-64 overflow-y-auto">
                            @if (Model.Cart?.Lines != null && Model.Cart.Lines.Any())
                            {
                                @foreach (var line in Model.Cart.Lines)
                                {
                                    <div class="flex gap-3 p-3 bg-gray-50 rounded-xl">
                                        <div class="w-16 h-16 bg-white rounded-lg flex items-center justify-center overflow-hidden shrink-0">
                                            @if (!string.IsNullOrEmpty(line.ImageUrl))
                                            {
                                                <img src="@line.ImageUrl" alt="@line.ProductName" class="w-full h-full object-contain">
                                            }
                                            else
                                            {
                                                <i class="fas fa-image text-gray-300 text-2xl"></i>
                                            }
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <h4 class="text-sm font-bold text-gray-800 truncate">@line.ProductName</h4>
                                            <div class="flex justify-between items-center text-sm mt-1">
                                                <span class="text-gray-400">@line.Quantity x @(line.DiscountPrice ?? line.ActualPrice).ToString("N2")₺</span>
                                                <span class="font-bold text-gray-800">@((line.Quantity * (line.DiscountPrice ?? line.ActualPrice)).ToString("N2"))₺</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Calculations -->
                        <div class="space-y-3 pt-6 border-t border-gray-100 text-sm">
                            <div class="flex justify-between text-gray-600">
                                <span>Ara Toplam</span>
                                <span class="font-medium" id="subtotal">@(Model.Cart?.ComputeTotalValue().ToString("N2") ?? "0.00")₺</span>
                            </div>
                            <div class="flex justify-between text-gray-600">
                                <span>Kargo</span>
                                <span class="font-medium" id="shippingCost">29.99₺</span>
                            </div>
                            <div class="flex justify-between text-gray-600">
                                <span>KDV (%18)</span>
                                <span class="font-medium" id="taxAmount">0.00₺</span>
                            </div>
                            <div class="flex justify-between text-primary font-semibold" id="discountRow" style="display: none;">
                                <span>İndirim</span>
                                <span id="discountAmount">-0.00₺</span>
                            </div>
                        </div>

                        <div class="pt-6 mt-6 border-t-2 border-dashed border-gray-100">
                            <div class="flex justify-between items-end">
                                <span class="text-gray-500 font-medium">Toplam Tutar</span>
                                <span class="text-3xl font-bold text-gray-800" id="totalAmount">
                                    @(Model.Cart?.ComputeTotalValue().ToString("N2") ?? "0.00")<span class="text-lg align-top">₺</span>
                                </span>
                            </div>
                        </div>

                        <!-- Gift Wrap -->
                        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border-2 border-dashed border-blue-200 rounded-2xl p-5 mt-6 relative overflow-hidden group">
                            <div class="absolute right-[-20px] top-[-20px] w-24 h-24 bg-primary/10 rounded-full blur-2xl transition-all group-hover:bg-primary/20"></div>
                            <div class="flex items-start gap-4 relative z-10">
                                <div class="p-3 rounded-full bg-white shadow-sm text-primary">
                                    <i class="fas fa-gift text-lg"></i>
                                </div>
                                <div class="flex-1">
                                    <h4 class="font-bold text-gray-800 text-sm">Hediye Paketi</h4>
                                    <p class="text-xs text-gray-500 mt-1 mb-3">Özel hediye paketi (+19.90₺)</p>
                                    <label class="inline-flex items-center cursor-pointer">
                                        <input type="checkbox" name="GiftWrap" value="true" class="sr-only peer">
                                        <div class="relative w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                        <span class="ms-3 text-xs font-medium text-gray-700 peer-checked:text-primary transition-colors">Evet, ekle</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="space-y-4 mt-6">
                            <button type="submit" class="w-full bg-primary hover:bg-secondary text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/30 active:scale-[0.98] transition-all duration-200 flex items-center justify-center gap-3">
                                <span>Siparişi Güvenle Tamamla</span>
                                <i class="fas fa-chevron-right text-sm"></i>
                            </button>
                            
                            <div class="flex items-center justify-center gap-4 text-gray-400 opacity-60 grayscale hover:grayscale-0 transition-all duration-300">
                                <i class="fab fa-cc-visa text-2xl"></i>
                                <i class="fab fa-cc-mastercard text-2xl"></i>
                                <i class="fab fa-cc-amex text-2xl"></i>
                                <div class="flex items-center gap-1 text-[10px] font-bold border border-gray-300 rounded px-1">
                                    <i class="fas fa-lock"></i> SSL
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function applyCoupon() {
            const code = document.getElementById('couponCode').value;
            const messageEl = document.getElementById('couponMessage');
            
            if (!code) {
                messageEl.className = 'mt-2 text-sm text-red-600';
                messageEl.textContent = 'Lütfen bir kupon kodu girin.';
                return;
            }

            // AJAX call to validate coupon
            fetch('/api/orders/validate-coupon', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    couponCode: code,
                    orderAmount: parseFloat(document.getElementById('subtotal').textContent.replace('₺', '').replace(',', ''))
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    messageEl.className = 'mt-2 text-sm text-green-600';
                    messageEl.textContent = data.message;
                    document.getElementById('discountRow').style.display = 'flex';
                    document.getElementById('discountAmount').textContent = `-${data.discountAmount.toFixed(2)}₺`;
                    updateTotal();
                } else {
                    messageEl.className = 'mt-2 text-sm text-red-600';
                    messageEl.textContent = data.message;
                }
            })
            .catch(error => {
                messageEl.className = 'mt-2 text-sm text-red-600';
                messageEl.textContent = 'Kupon doğrulanırken bir hata oluştu.';
            });
        }

        function updateTotal() {
            const subtotal = parseFloat(document.getElementById('subtotal').textContent.replace('₺', '').replace(',', ''));
            const shipping = parseFloat(document.getElementById('shippingCost').textContent.replace('₺', '').replace(',', '').replace('Ücretsiz', '0'));
            const discount = parseFloat(document.getElementById('discountAmount').textContent.replace('₺', '').replace(',', '').replace('-', '')) || 0;
            
            const netAmount = subtotal - discount + shipping;
            const tax = netAmount * 0.18;
            const total = netAmount + tax;

            document.getElementById('taxAmount').textContent = tax.toFixed(2) + '₺';
            document.getElementById('totalAmount').innerHTML = total.toFixed(2) + '<span class="text-lg align-top">₺</span>';
        }

        // Update shipping cost on method change
        document.querySelectorAll('input[name="ShippingMethod"]').forEach(radio => {
            radio.addEventListener('change', function() {
                const shippingCostEl = document.getElementById('shippingCost');
                const subtotal = parseFloat(document.getElementById('subtotal').textContent.replace('₺', '').replace(',', ''));
                
                if (this.value === 'Standard') {
                    if (subtotal >= 500) {
                        shippingCostEl.textContent = 'Ücretsiz';
                        shippingCostEl.className = 'font-medium text-green-600';
                    } else {
                        shippingCostEl.textContent = '29.99₺';
                        shippingCostEl.className = 'font-medium';
                    }
                } else if (this.value === 'Express') {
                    shippingCostEl.textContent = '49.99₺';
                    shippingCostEl.className = 'font-medium';
                } else if (this.value === 'HandlingOnly') {
                    shippingCostEl.textContent = 'Ücretsiz';
                    shippingCostEl.className = 'font-medium text-green-600';
                }
                
                updateTotal();
            });
        });

        // Initial calculation
        updateTotal();
    </script>
}