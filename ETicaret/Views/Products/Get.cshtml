	<h3 class="text-2xl font-black text-secondary mt-6">Benzer Ürünler</h3>
	<div class="grid grid-cols-5 gap-4 mt-4">
		@foreach (var product in Model?.RelatedProducts?.Take(5) ?? Enumerable.Empty<ProductDto>())
		{
			<partial name="_ProductCardSmall" model="product" />
		}
	</div>
</div>

