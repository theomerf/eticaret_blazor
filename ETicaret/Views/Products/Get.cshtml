@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@inject UserManager<User> UserManager
@model ProductDetailViewModel

@{
	ViewData["Title"] = Model?.Product.ProductName;
    var favouriteIds = ViewBag.FavouriteIds as List<int>;
}

@section Scripts {
	<script src="/js/product-detail.js" asp-append-version="true"></script>
	<script src="/js/product-card.js" asp-append-version="true"></script>
}

<!-- Masaüstü Görünüm -->
<div class="hidden lg:block">
	<nav aria-label="breadcrumb" class="mb-6 w-fit">
		<ol class="flex items-center gap-2 text-sm font-medium bg-white px-6 py-4 rounded-2xl shadow-sm border border-gray-100">
			<li><a href="/" class="text-gray-500 hover:text-blue-600 transition-colors duration-300">Ana Sayfa</a></li>
			<li class="text-gray-300">/</li>
			<li><a href="/kategori" class="text-gray-500 hover:text-blue-600 transition-colors duration-300">Kategoriler</a></li>
			<li class="text-gray-300">/</li>
			<li class="text-gray-800 font-semibold truncate max-w-[150px] lg:max-w-none">@Model?.Product.ProductName</li>
		</ol>
	</nav>

	<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
		<div class="relative hidden lg:flex flex-col gap-4">
			<div class="relative rounded-3xl overflow-hidden bg-gray-100 aspect-square flex items-center justify-center shadow-lg group">
				<img src="@Model?.Product.Images?.First().ImageUrl" class="pd-main-image w-full h-full object-cover transition-transform duration-500 ease-out relative cursor-pointer" alt="@Model?.Product.ProductName" />
				
                @if (User.Identity != null && User.Identity.IsAuthenticated && Context.User.FindFirstValue(ClaimTypes.NameIdentifier) != null)
                {
                    if (favouriteIds != null && Model?.Product != null && favouriteIds.Contains(Model.Product.ProductId))
                    {
                         <button type="button" class="remove-from-favs-btn absolute top-5 right-5 bg-white/95 backdrop-blur-lg text-red-500 w-12 h-12 rounded-full flex items-center justify-center cursor-pointer transition-all duration-300 z-30 shadow-md border border-white/30 hover:bg-gradient-to-br hover:from-pink-400 hover:to-rose-500 hover:text-white hover:scale-110 hover:rotate-6 hover:shadow-lg"
                            data-product-id="@Model?.Product.ProductId" title="Favorilerden Kaldır">
					        <i class="fas fa-heart text-xl"></i>
				        </button>
                    }
                    else
                    {
                        <button type="button" class="add-to-favs-btn absolute top-5 right-5 bg-white/95 backdrop-blur-lg text-gray-600 w-12 h-12 rounded-full flex items-center justify-center cursor-pointer transition-all duration-300 z-30 shadow-md border border-white/30 hover:bg-gradient-to-br hover:from-red-50 hover:to-red-100 hover:text-red-500 hover:scale-110 hover:rotate-6 hover:shadow-lg"
                            data-product-id="@Model?.Product.ProductId" title="Favorilere Ekle">
					        <i class="far fa-heart text-xl"></i>
				        </button>
                    }
                }
                else
                {
                     <a href="/account/login" class="absolute top-5 right-5 bg-white/95 backdrop-blur-lg text-gray-600 w-12 h-12 rounded-full flex items-center justify-center cursor-pointer transition-all duration-300 z-30 shadow-md border border-white/30 hover:bg-gradient-to-br hover:from-red-50 hover:to-red-100 hover:text-red-500 hover:scale-110 hover:rotate-6 hover:shadow-lg">
					    <i class="far fa-heart text-xl"></i>
				    </a>
                }

				@if (Model?.Product.Images?.Count() > 1) 
				{
					<button id="prev-image-btn" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/30 hover:primary text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 backdrop-blur-md border border-white/20 hover:scale-110 cursor-pointer">
						<i class="fas fa-chevron-left text-lg"></i>
					</button>
					<button id="next-image-btn" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-white/30 hover:bg-primary text-white flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 z-20 backdrop-blur-md border border-white/20 hover:scale-110 cursor-pointer">
						<i class="fas fa-chevron-right text-lg"></i>
					</button>
				}
			</div>
			<div class="flex gap-4 overflow-x-auto pt-4 pb-2 scrollbar-hide">
				@{ var isFirst = true; }
				@foreach (var image in Model?.Product.Images ?? Enumerable.Empty<ProductImage>()) {
					<img src="@image.ImageUrl" class="pd-thumbnail w-20 h-20 object-cover rounded-xl cursor-pointer transition-all duration-300 border-2 opacity-70 bg-gray-100 flex-shrink-0 hover:opacity-100 hover:-translate-y-1 hover:shadow-md @(isFirst ? "border-blue-600 opacity-100 shadow-[0_0_0_4px_rgba(0,102,255,0.2)] active" : "border-transparent")" alt="Thumbnail" />
					isFirst = false;
				}
			</div>
		</div>

		<div class="flex flex-col">
			<div class="hidden lg:block">
				<div class="flex justify-between items-center p-4 bg-gray-50 rounded-2xl">
					<span class="text-emerald-500 font-semibold flex items-center gap-2 bg-emerald-50 px-3 py-1.5 rounded-lg">
						<i class="fas fa-check-circle"></i> Stokta
					</span>
				</div>

				<h1 class="text-secondary text-3xl md:text-4xl lg:text-5xl font-black leading-tight tracking-tight py-2">@Model?.Product.ProductName</h1>

				<div class="flex items-center gap-4 pb-6 mt-3 lg:mt-4">
					<div class="flex gap-1 text-amber-400 text-lg">
						@await Component.InvokeAsync("RatingStars", new { averageRating = Model?.Product.AverageRating, Mode = "stars" })
					</div>
					<span class="text-gray-500 text-sm font-medium">
						@Model?.Product.AverageRating
						(@Model?.Product.ReviewCount Değerlendirme)
					</span>
				</div>

				<div class="flex items-center gap-5 mb-8 p-6 bg-white rounded-2xl shadow-md border border-gray-100">
					@if (@Model?.Product.Discount > 0)
					{
						<span class="line-through text-gray-400 text-base font-medium bg-white/70 px-4 py-2 rounded-xl">@Model?.Product.ActualPrice.ToString("C2", new CultureInfo("tr-TR"))</span>
						<span class="text-3xl font-black bg-primary bg-clip-text text-transparent">@Model?.Product.DiscountPrice?.ToString("C2", new CultureInfo("tr-TR"))</span>
						<span class="bg-gradient-to-br from-red-500 to-red-400 text-white px-4 py-2 rounded-full text-xs font-extrabold backdrop-blur-sm tracking-wide shadow-lg animate-pulse">%@Model?.Product.Discount İNDİRİM</span>
					}
					else 
					{
						<span class="text-3xl font-black bg-primary bg-clip-text text-transparent">@Model?.Product.ActualPrice.ToString("C2", new CultureInfo("tr-TR"))</span>
					}
				</div>
			</div>

			<div class="bg-white p-5 lg:p-8 mb-6 lg:mb-8 rounded-2xl shadow-md border border-gray-100">
				<div class="mb-5 lg:mb-6">
					<label class="block font-bold text-gray-800 mb-3 lg:mb-4 uppercase tracking-wide text-xs lg:text-sm">Renk Seçimi:</label>
					<div class="flex gap-3 lg:gap-4 flex-wrap">
						<div class="pd-color-option w-8 h-8 lg:w-10 lg:h-10 rounded-full cursor-pointer relative transition-all duration-300 shadow-md border-[2px] lg:border-[3px] border-white hover:scale-110 hover:shadow-lg active" style="background-color: #000000;" title="Siyah"></div>
						<div class="pd-color-option w-8 h-8 lg:w-10 lg:h-10 rounded-full cursor-pointer relative transition-all duration-300 shadow-md border-[2px] lg:border-[3px] border-white hover:scale-110 hover:shadow-lg" style="background-color: #FFFFFF; border: 1px solid #ddd;" title="Beyaz"></div>
						<div class="pd-color-option w-8 h-8 lg:w-10 lg:h-10 rounded-full cursor-pointer relative transition-all duration-300 shadow-md border-[2px] lg:border-[3px] border-white hover:scale-110 hover:shadow-lg" style="background-color: #FF0000;" title="Kırmızı"></div>
						<div class="pd-color-option w-8 h-8 lg:w-10 lg:h-10 rounded-full cursor-pointer relative transition-all duration-300 shadow-md border-[2px] lg:border-[3px] border-white hover:scale-110 hover:shadow-lg" style="background-color: #0000FF;" title="Mavi"></div>
					</div>
				</div>

				<div>
					<label class="block font-bold text-gray-800 mb-3 lg:mb-4 uppercase tracking-wide text-xs lg:text-sm">Beden:</label>
					<div class="flex flex-wrap gap-2 lg:gap-3">
						<div class="pd-size-option min-w-[40px] h-[40px] lg:min-w-[50px] lg:h-[50px] flex items-center justify-center border-2 border-gray-200 rounded-lg cursor-pointer text-sm lg:text-base font-bold transition-all duration-300 bg-white text-gray-600 hover:border-blue-500 hover:text-blue-500 hover:-translate-y-0.5 hover:shadow-md">S</div>
						<div class="pd-size-option min-w-[40px] h-[40px] lg:min-w-[50px] lg:h-[50px] flex items-center justify-center border-2 border-gray-200 rounded-lg cursor-pointer text-sm lg:text-base font-bold transition-all duration-300 bg-white text-gray-600 hover:border-blue-500 hover:text-blue-500 hover:-translate-y-0.5 hover:shadow-md active">M</div>
						<div class="pd-size-option min-w-[40px] h-[40px] lg:min-w-[50px] lg:h-[50px] flex items-center justify-center border-2 border-gray-200 rounded-lg cursor-pointer text-sm lg:text-base font-bold transition-all duration-300 bg-white text-gray-600 hover:border-blue-500 hover:text-blue-500 hover:-translate-y-0.5 hover:shadow-md">L</div>
						<div class="pd-size-option min-w-[40px] h-[40px] lg:min-w-[50px] lg:h-[50px] flex items-center justify-center border-2 border-gray-200 rounded-lg cursor-not-allowed pointer-events-none text-sm lg:text-base font-bold bg-gray-100 text-gray-400 opacity-60 relative after:content-[''] after:absolute after:top-1/2 after:left-[10%] after:right-[10%] after:border-t-2 after:border-gray-400 after:-rotate-45 sold-out">XL</div>
					</div>
				</div>
			</div>

			<div class="flex flex-col gap-5 lg:gap-8 items-center mb-6 lg:mb-8">
				<div class="flex items-center h-[40px] lg:h-[50px] max-w-[120px] lg:max-w-[140px] border-2 border-indigo-500/20 rounded-full overflow-hidden bg-white shadow-lg transition-all duration-300 relative hover:-translate-y-0.5 hover:shadow-xl">
					<button type="button" class="pd-quantity-btn w-[40px] lg:w-[60px] h-full bg-gradient-to-br from-gray-50 to-gray-200 border-none text-gray-600 text-base lg:text-xl font-bold flex items-center justify-center cursor-pointer transition-all duration-300 relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-button before:opacity-0 before:transition-opacity before:duration-300 hover:before:opacity-100 hover:text-white hover:scale-105" onclick="changeQuantity(-1)"><i class="fas fa-minus relative z-10"></i></button>
					<input type="number" id="productQuantity" name="quantity" class="flex-1 h-full border-none text-center text-lg lg:text-xl font-extrabold text-gray-800 bg-white focus:outline-none" value="1" min="1" max="10" readonly>
					<button type="button" class="pd-quantity-btn w-[40px] lg:w-[60px] h-full bg-gradient-to-br from-gray-50 to-gray-200 border-none text-gray-600 text-base lg:text-xl font-bold flex items-center justify-center cursor-pointer transition-all duration-300 relative overflow-hidden before:content-[''] before:absolute before:inset-0 before:bg-button before:opacity-0 before:transition-opacity before:duration-300 hover:before:opacity-100 hover:text-white hover:scale-105" onclick="changeQuantity(1)"><i class="fas fa-plus relative z-10"></i></button>
				</div>

				<div class="flex gap-3 lg:gap-4 w-full">
					<button type="button" class="pd-add-cart-btn flex-1 h-12 lg:h-16 border-none text-sm lg:text-base font-extrabold rounded-full transition-all duration-300 flex items-center px-4 lg:px-6 justify-center gap-2 lg:gap-3 uppercase tracking-wide relative overflow-hidden cursor-pointer shadow-lg bg-button text-white hover:-translate-y-1 hover:bg-button-hover hover:shadow-xl" data-product-id="@Model?.Product.ProductId" data-in-cart="false">
						<span class="btn-content flex items-center justify-center gap-2 lg:gap-3">
							<i class="fas fa-shopping-cart text-base lg:text-lg"></i> <span class="btn-text">Sepete Ekle</span>
						</span>
						<span class="btn-loading hidden items-center justify-center gap-2 lg:gap-3">
							<span class="w-4 h-4 lg:w-5 lg:h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
							<span class="btn-text">Ekleniyor...</span>
						</span>
						<span class="btn-remove hidden items-center justify-center gap-2 lg:gap-3">
							<i class="fas fa-trash text-base lg:text-lg"></i> <span class="btn-text">Sepetten Kaldır</span>
						</span>
						<span class="btn-remove-loading hidden items-center justify-center gap-2 lg:gap-3">
							<span class="w-4 h-4 lg:w-5 lg:h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
							<span class="btn-text">Kaldırılıyor...</span>
						</span>
					</button>
					<button class="flex-1 h-12 lg:h-16 border-none text-sm lg:text-base font-extrabold rounded-full transition-all duration-300 flex items-center px-4 lg:px-6 justify-center gap-2 lg:gap-3 uppercase tracking-wide relative overflow-hidden cursor-pointer shadow-lg bg-gradient-to-br from-teal-400 to-teal-500 text-white hover:-translate-y-1 hover:shadow-xl hover:from-teal-500 hover:to-teal-600">Hemen Satın Al</button>
				</div>
			</div>

			<div class="grid grid-cols-3 gap-2 lg:gap-4">
				<div class="flex flex-col lg:flex-row items-center justify-center lg:justify-start text-center lg:text-left gap-2 lg:gap-4 bg-white p-2 lg:p-5 rounded-2xl text-[10px] lg:text-sm text-gray-600 transition-all duration-300 shadow-sm border border-gray-100 font-semibold hover:-translate-y-1 hover:shadow-md hover:border-blue-500">
					<i class="fas fa-truck text-lg lg:text-2xl text-secondary"></i>
					<span>Hızlı Teslimat</span>
				</div>
				<div class="flex flex-col lg:flex-row items-center justify-center lg:justify-start text-center lg:text-left gap-2 lg:gap-4 bg-white p-2 lg:p-5 rounded-2xl text-[10px] lg:text-sm text-gray-600 transition-all duration-300 shadow-sm border border-gray-100 font-semibold hover:-translate-y-1 hover:shadow-md hover:border-blue-500">
					<i class="fas fa-undo text-lg lg:text-2xl text-secondary"></i>
					<span>15 Gün İade</span>
				</div>
				<div class="flex flex-col lg:flex-row items-center justify-center lg:justify-start text-center lg:text-left gap-2 lg:gap-4 bg-white p-2 lg:p-5 rounded-2xl text-[10px] lg:text-sm text-gray-600 transition-all duration-300 shadow-sm border border-gray-100 font-semibold hover:-translate-y-1 hover:shadow-md hover:border-blue-500">
					<i class="fas fa-shield-alt text-lg lg:text-2xl text-secondary"></i>
					<span>Güvenli Ödeme</span>
				</div>
			</div>

			<div class="flex items-center gap-3 lg:gap-4 p-4 lg:p-6 bg-gray-50 rounded-2xl border-t border-gray-100 mt-6 lg:mt-8">
				<span class="font-bold text-gray-800 text-sm lg:text-base">Paylaş:</span>
				<a href="#" class="bg-white w-9 h-9 lg:w-12 lg:h-12 flex items-center justify-center rounded-full text-gray-500 transition-all duration-300 cursor-pointer shadow-sm border border-gray-100 hover:bg-gradient-to-br hover:bg-blue-600 hover:border-blue-600 hover:text-white hover:-translate-y-1 hover:scale-110 hover:shadow-md"><i class="fab fa-facebook-f text-sm lg:text-base"></i></a>
				<a href="#" class="bg-white w-9 h-9 lg:w-12 lg:h-12 flex items-center justify-center rounded-full text-gray-500 transition-all duration-300 cursor-pointer shadow-sm border border-gray-100 hover:bg-gradient-to-br hover:bg-sky-500 hover:border-sky-500 hover:text-white hover:-translate-y-1 hover:scale-110 hover:shadow-md"><i class="fab fa-twitter text-sm lg:text-base"></i></a>
				<a href="#" class="bg-white w-9 h-9 lg:w-12 lg:h-12 flex items-center justify-center rounded-full text-gray-500 transition-all duration-300 cursor-pointer shadow-sm border border-gray-100 hover:bg-gradient-to-br hover:bg-red-600 hover:border-red-600 hover:text-white hover:-translate-y-1 hover:scale-110 hover:shadow-md"><i class="fab fa-pinterest text-sm lg:text-base"></i></a>
				<a href="#" class="bg-white w-9 h-9 lg:w-12 lg:h-12 flex items-center justify-center rounded-full text-gray-500 transition-all duration-300 cursor-pointer shadow-sm border border-gray-100 hover:bg-gradient-to-br hover:from-green-500 hover:to-green-600 hover:text-white hover:-translate-y-1 hover:scale-110 hover:shadow-md"><i class="fab fa-whatsapp text-sm lg:text-base"></i></a>
			</div>
		</div>
	</div>

	<!-- Ürün Sekmeleri -->
	<div class="bg-white rounded-3xl shadow-lg overflow-hidden border border-gray-100 mt-6 lg:mt-10">
		<ul class="flex overflow-x-auto bg-gray-50 border-b border-gray-200 px-2 lg:px-8 scrollbar-hide justify-between lg:justify-start" id="productTabs">
			<li role="presentation" class="shrink-0 lg:shrink">
				<button class="pd-tab-btn text-gray-500 border-none bg-transparent transition-all duration-300 py-3 px-3 lg:py-5 lg:px-8 font-bold relative whitespace-nowrap uppercase tracking-wide text-[10px] sm:text-xs lg:text-sm cursor-pointer hover:text-secondary active" data-tab-target="#description">ÜRÜN DETAYLARI</button>
			</li>
			<li role="presentation" class="shrink-0 lg:shrink">
				<button class="pd-tab-btn text-gray-500 border-none bg-transparent transition-all duration-300 py-3 px-3 lg:py-5 lg:px-8 font-bold relative whitespace-nowrap uppercase tracking-wide text-[10px] sm:text-xs lg:text-sm cursor-pointer hover:text-secondary" data-tab-target="#specs">TEKNİK ÖZELLİKLER</button>
			</li>
			<li role="presentation" class="shrink-0 lg:shrink">
				<button class="pd-tab-btn text-gray-500 border-none bg-transparent transition-all duration-300 py-3 px-3 lg:py-5 lg:px-8 font-bold relative whitespace-nowrap uppercase tracking-wide text-[10px] sm:text-xs lg:text-sm cursor-pointer hover:text-secondary" id="reviewsTab" data-tab-target="#reviews">YORUMLAR (@Model?.Product.ReviewCount)</button>
			</li>
			<li role="presentation" class="shrink-0 lg:shrink">
				<button class="pd-tab-btn text-gray-500 border-none bg-transparent transition-all duration-300 py-3 px-3 lg:py-5 lg:px-8 font-bold relative whitespace-nowrap uppercase tracking-wide text-[10px] sm:text-xs lg:text-sm cursor-pointer hover:text-secondary" data-tab-target="#shipping">KARGO VE İADE</button>
			</li>
		</ul>

		<div class="tab-content bg-white p-5 lg:p-10" id="productTabContent">
			<div class="tab-pane block opacity-100 transition-opacity duration-300" id="description" role="tabpanel">
				<div class="leading-relaxed text-gray-600 text-base">
					<p class="mb-4">@Model?.Product.Summary</p>
					<p class="mb-4">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed euismod, urna eu tincidunt consectetur, nisi nunc pretium nunc, eget tincidunt nisl nunc eget nisl. Sed euismod, urna eu tincidunt consectetur, nisi nunc pretium nunc, eget tincidunt nisl nunc eget nisl.</p>
					<ul class="mt-6 space-y-3 pl-6">
						<li class="flex items-center gap-2 text-gray-600 font-medium"><span class="text-emerald-500 font-bold">✓</span> Yüksek kaliteli malzeme</li>
						<li class="flex items-center gap-2 text-gray-600 font-medium"><span class="text-emerald-500 font-bold">✓</span> Dayanıklı ve uzun ömürlü</li>
						<li class="flex items-center gap-2 text-gray-600 font-medium"><span class="text-emerald-500 font-bold">✓</span> Şık ve modern tasarım</li>
						<li class="flex items-center gap-2 text-gray-600 font-medium"><span class="text-emerald-500 font-bold">✓</span> Kolay temizleme</li>
					</ul>
				</div>
			</div>

			<div class="tab-pane hidden opacity-0 transition-opacity duration-300" id="specs" role="tabpanel">
				<div class="w-full rounded-2xl overflow-hidden shadow-sm">
					<div class="flex">
						<div class="flex-1 py-5 px-6 font-bold text-gray-800 bg-blue-500/5 border-r border-gray-100">Renk</div>
						<div class="flex-[2] py-5 px-6 text-gray-600 font-medium">Siyah, Beyaz, Kırmızı, Mavi</div>
					</div>
					<div class="flex bg-gray-50">
						<div class="flex-1 py-5 px-6 font-bold text-gray-800 bg-blue-500/5 border-r border-gray-100">Malzeme</div>
						<div class="flex-[2] py-5 px-6 text-gray-600 font-medium">%100 Pamuk</div>
					</div>
					<div class="flex">
						<div class="flex-1 py-5 px-6 font-bold text-gray-800 bg-blue-500/5 border-r border-gray-100">Beden</div>
						<div class="flex-[2] py-5 px-6 text-gray-600 font-medium">S, M, L, XL</div>
					</div>
					<div class="flex bg-gray-50">
						<div class="flex-1 py-5 px-6 font-bold text-gray-800 bg-blue-500/5 border-r border-gray-100">Ağırlık</div>
						<div class="flex-[2] py-5 px-6 text-gray-600 font-medium">250g</div>
					</div>
					<div class="flex">
						<div class="flex-1 py-5 px-6 font-bold text-gray-800 bg-blue-500/5 border-r border-gray-100">Üretim Yeri</div>
						<div class="flex-[2] py-5 px-6 text-gray-600 font-medium">Türkiye</div>
					</div>
					<div class="flex bg-gray-50">
						<div class="flex-1 py-5 px-6 font-bold text-gray-800 bg-blue-500/5 border-r border-gray-100">Garanti</div>
						<div class="flex-[2] py-5 px-6 text-gray-600 font-medium">2 Yıl</div>
					</div>
				</div>
			</div>

			<div class="tab-pane hidden opacity-0 transition-opacity duration-300" id="reviews" role="tabpanel">
				@await Component.InvokeAsync("ProductReviews", new { productId = Model?.Product.ProductId })
			</div>

			<div class="tab-pane hidden opacity-0 transition-opacity duration-300" id="shipping" role="tabpanel">
				<div>
					<h4 class="text-gray-800 mb-5 text-xl font-bold relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-[50px] after:h-[3px] after:bg-primary after:rounded-sm">Kargo Bilgileri</h4>
					<p class="mb-5 text-gray-600 leading-relaxed text-base">Siparişleriniz, ödeme onayından sonraki ilk iş günü içinde hazırlanıp kargoya verilmektedir.</p>
					<ul class="pl-6 mb-8 space-y-3">
						<li class="text-gray-600 relative pl-2 before:content-['✓'] before:absolute before:-left-5 before:text-emerald-500 before:font-bold">Standart teslimat süresi: 1-3 iş günü</li>
						<li class="text-gray-600 relative pl-2 before:content-['✓'] before:absolute before:-left-5 before:text-emerald-500 before:font-bold">Hızlı teslimat seçeneği: Aynı gün teslimat (saat 14:00'a kadar verilen siparişler için)</li>
						<li class="text-gray-600 relative pl-2 before:content-['✓'] before:absolute before:-left-5 before:text-emerald-500 before:font-bold">100 TL ve üzeri alışverişlerde kargo ücretsizdir</li>
					</ul>

					<h4 class="text-gray-800 mb-5 text-xl font-bold relative pb-3 after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-[50px] after:h-[3px] after:bg-primary after:rounded-sm">İade Koşulları</h4>
					<p class="mb-5 text-gray-600 leading-relaxed text-base">Ürünü teslim aldığınız tarihten itibaren 15 gün içinde iade edebilirsiniz.</p>
					<ul class="pl-6 mb-8 space-y-3">
						<li class="text-gray-600 relative pl-2 before:content-['✓'] before:absolute before:-left-5 before:text-emerald-500 before:font-bold">Ürün kullanılmamış ve orijinal ambalajında olmalıdır</li>
						<li class="text-gray-600 relative pl-2 before:content-['✓'] before:absolute before:-left-5 before:text-emerald-500 before:font-bold">İade edeceğiniz ürünün yanında fatura ve irsaliye bulunmalıdır</li>
						<li class="text-gray-600 relative pl-2 before:content-['✓'] before:absolute before:-left-5 before:text-emerald-500 before:font-bold">İade kargo bedeli müşteriye aittir</li>
					</ul>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Mobil Görünüm -->
<partial name="_GetMobile" model="Model" />

<!-- Benzer Ürünler -->
