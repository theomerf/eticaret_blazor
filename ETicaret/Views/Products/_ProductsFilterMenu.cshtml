<div class="lg:sticky lg:top-5 lg:max-h-[calc(100vh-40px)] lg:h-auto lg:flex lg:flex-col">
    <div class="filter-main-card lg:flex lg:flex-col lg:max-h-[calc(100vh-40px)] lg:overflow-hidden bg-white rounded-3xl shadow-[0_10px_30px_rgba(0,0,0,0.05)] border border-gray-100">
        <div class="bg-primary text-white border-0 p-4 sm:p-5 rounded-t-2xl sm:rounded-t-[20px] flex-shrink-0">
            <h5 class="m-0 flex items-center text-base sm:text-lg font-semibold">
                <i class="fas fa-filter mr-2 sm:mr-3"></i>
                Ürün Filtreleri
            </h5>
        </div>

        <div id="filterAccordion" class="lg:flex-1 lg:overflow-y-auto lg:scrollbar-thin lg:scrollbar-thumb-gray-300 lg:scrollbar-track-gray-100">
            <!-- Kategoriler Bölümü -->
            <div class="border-0">
                <h2 id="headingCategories">
                    <button class="custom-accordion-button @(ViewBag.InitialCollapseCategories == true ? "collapsed" : "")" type="button" 
                            onclick="toggleAccordion('collapseCategories', this)">
                        <span class="flex items-center flex-1">
                            <i class="fas fa-layer-group text-blue-600 mr-2 sm:mr-3 text-sm sm:text-base"></i>
                            <span class="text-sm sm:text-base">Kategoriler</span>
                        </span>
                        <i class="fas fa-chevron-down transition-transform duration-300 text-xs sm:text-sm"></i>
                    </button>
                </h2>
                <div id="collapseCategories" class="custom-accordion-collapse show">
                    <div class="p-1">
                        @await Component.InvokeAsync("CategoriesFilter")
                    </div>
                </div>
            </div>

            <!-- Ürün Filtreleri Bölümü -->
            <div class="border-0">
                <h2 id="headingProductFilters">
                    <button class="custom-accordion-button @(ViewBag.InitialCollapseProductFilters == true ? "collapsed" : "")" type="button"
                            onclick="toggleAccordion('collapseProductFilters', this)">
                        <span class="flex items-center flex-1">
                            <i class="fas fa-sliders-h text-blue-600 mr-2 sm:mr-3 text-sm sm:text-base"></i>
                            <span class="text-sm sm:text-base">Ürün Filtreleri</span>
                        </span>
                        <i class="fas fa-chevron-down transition-transform duration-300 text-xs sm:text-sm"></i>
                    </button>
                </h2>
                <div id="collapseProductFilters" class="custom-accordion-collapse show">
                    <div class="p-3 sm:p-4">
                        <form id="filterForm">
                            <!-- Ürün Ara -->
                            <div class="filter-section">
                                <label for="searchTerm" class="block text-sm sm:text-base font-semibold text-gray-800 mb-2 sm:mb-3">
                                    <i class="fas fa-search text-blue-600 mr-2"></i>Ürün Ara
                                </label>
                                <div class="relative">
                                    <input type="text" class="filter-input w-full px-3 py-2.5 sm:px-4 sm:py-3 text-sm sm:text-base border-2 border-gray-200 rounded-2xl sm:rounded-[15px] pr-10 sm:pr-12 focus:outline-none"
                                           id="searchTerm" name="SearchTerm"
                                           placeholder="Ürün adı veya açıklama yazın..."
                                           value="@Context.Request.Query["searchTerm"]">
                                    <button class="absolute top-1/2 right-0 -translate-y-1/2 mr-2 sm:mr-3 border-none bg-transparent z-10 text-gray-400 hover:text-gray-600 transition-colors"
                                            type="button" id="clearSearch" style="display: none;">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- Fiyat Aralığı -->
                            <div class="filter-section">
                                <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-2 sm:mb-3 gap-2">
                                    <label class="block text-sm sm:text-base font-semibold text-gray-800 m-0">
                                        <i class="fas fa-tag text-blue-600 mr-2"></i>Fiyat Aralığı
                                    </label>
                                    <div class="bg-gray-100 rounded-full px-3 py-1 text-xs sm:text-sm border border-gray-200">
                                        <span id="minPriceDisplay" class="font-bold text-blue-600">0</span>
                                        <span class="text-gray-500 mx-1">-</span>
                                        <span id="maxPriceDisplay" class="font-bold text-blue-600">100000</span>
                                    </div>
                                </div>
                                <div id="priceRange" class="mb-3 sm:mb-4 h-2.5 px-2"></div>
                                <div class="grid grid-cols-2 gap-2">
                                    <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500/20">
                                        <span class="bg-gray-100 border-r border-gray-200 px-2 sm:px-3 py-2 text-sm sm:text-base text-gray-600">₺</span>
                                        <input type="number" class="filter-input flex-1 px-2 sm:px-3 py-2 text-sm sm:text-base border-0 focus:ring-0 focus:outline-none" id="minPrice" name="MinPrice"
                                               placeholder="Min" value="@Context.Request.Query["minPrice"]" min="0">
                                    </div>
                                    <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden focus-within:ring-2 focus-within:ring-blue-500/20">
                                        <span class="bg-gray-100 border-r border-gray-200 px-2 sm:px-3 py-2 text-sm sm:text-base text-gray-600">₺</span>
                                        <input type="number" class="filter-input flex-1 px-2 sm:px-3 py-2 text-sm sm:text-base border-0 focus:ring-0 focus:outline-none" id="maxPrice" name="MaxPrice"
                                               placeholder="Max" value="@Context.Request.Query["maxPrice"]" min="0">
                                    </div>
                                </div>
                            </div>

                            <!-- Markalar -->
                            <div class="filter-section">
                                <label class="block text-sm sm:text-base font-semibold text-gray-800 mb-2 sm:mb-3">
                                    <i class="fas fa-building text-blue-600 mr-2"></i>Markalar
                                </label>
                                <div class="mb-2 sm:mb-3">
                                    <input type="text" class="w-full px-3 py-2 text-sm border border-gray-200 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none" id="brandSearch"
                                           placeholder="Marka ara...">
                                </div>
                                <div class="max-h-[180px] sm:max-h-[200px] overflow-y-auto pr-2 [&::-webkit-scrollbar]:w-1.5 [&::-webkit-scrollbar-track]:bg-gray-100 [&::-webkit-scrollbar-track]:rounded-full [&::-webkit-scrollbar-thumb]:bg-gray-300 [&::-webkit-scrollbar-thumb]:rounded-full [&::-webkit-scrollbar-thumb:hover]:bg-gray-400">
                                    <div class="flex items-center mb-2 sm:mb-3 hover:bg-blue-500/5 rounded-lg p-1 sm:p-2 pl-1 transition-colors">
                                        <input class="filter-input w-4 h-4 rounded-md border-2 border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer" type="radio" name="Brand" id="brandAll" value=""
                                               @(string.IsNullOrEmpty(Context.Request.Query["brand"]) ? "checked" : "")>
                                        <label class="flex justify-between items-center w-full ml-2 sm:ml-3 cursor-pointer text-sm sm:text-base" for="brandAll">
                                            <span class="font-medium text-gray-700">Tüm Markalar</span>
                                            <span class="bg-gray-400 text-white text-xs p-1 sm:p-2 rounded-full">Tümü</span>
                                        </label>
                                    </div>
                                    @{
                                        var brands = new[] {
                                                                        new { Name = "Apple", Count = 45 },
                                                                        new { Name = "Samsung", Count = 38 },
                                                                        new { Name = "Sony", Count = 29 },
                                                                        new { Name = "Huawei", Count = 22 },
                                                                        new { Name = "Lenovo", Count = 18 },
                                                                        new { Name = "Sony", Count = 15 },
                                                                        new { Name = "Dell", Count = 12 },
                                                                        new { Name = "Vestel", Count = 10 }
                                                                        };
                                        foreach (var brand in brands)
                                        {
                                            <div class="flex items-center mb-2 sm:mb-3 hover:bg-blue-500/5 rounded-lg p-1 sm:p-2 transition-colors" data-brand="@brand.Name.ToLower()">
                                                <input class="filter-input w-4 h-4 rounded-md border-2 border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer" type="radio" name="Brand" id="brand@(brand.Name)" value="@brand.Name"
                                                       @(Context.Request.Query["brand"] == brand.Name ? "checked" : "")>
                                                <label class="flex justify-between items-center w-full ml-2 sm:ml-3 cursor-pointer text-sm sm:text-base" for="brand@(brand.Name)">
                                                    <span class="text-gray-700">@brand.Name</span>
                                                    <span class="bg-gray-200 text-gray-700 text-xs px-2 py-0.5 rounded-full">@brand.Count</span>
                                                </label>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Özel Filtreler -->
                            <div class="filter-section">
                                <label class="block text-sm sm:text-base font-semibold text-gray-800 mb-2 sm:mb-3">
                                    <i class="fas fa-star text-blue-600 mr-2"></i>Özel Filtreler
                                </label>
                                <div>
                                    <div class="mb-2 sm:mb-3 p-0">
                                        <div class="custom-switch-card">
                                            <div class="flex items-center justify-between">
                                                <div class="flex items-center flex-1">
                                                    <i class="fas fa-fire text-red-500 mr-2 sm:mr-3 text-base sm:text-lg"></i>
                                                    <div>
                                                        <div class="font-medium text-sm sm:text-base text-gray-800">En Çok Satanlar</div>
                                                        <small class="text-xs text-gray-500">Popüler ürünler</small>
                                                    </div>
                                                </div>
                                                <input class="filter-input ml-0 w-12 h-6 rounded-full border-2 border-gray-300 bg-gray-200 checked:bg-blue-600 checked:border-blue-600 appearance-none cursor-pointer relative transition-colors before:content-[''] before:absolute before:w-5 before:h-5 before:rounded-full before:bg-white before:top-0 before:left-0 before:transition-transform checked:before:translate-x-6" 
                                                       type="checkbox" id="bestSellers" name="IsShowCase" value="true"
                                                       @(Context.Request.Query["isShowCase"] == "true" ? "checked" : "")>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mb-2 sm:mb-3 p-0">
                                        <div class="custom-switch-card">
                                            <div class="flex items-center justify-between">
                                                <div class="flex items-center flex-1">
                                                    <i class="fas fa-percentage text-green-500 mr-2 sm:mr-3 text-base sm:text-lg"></i>
                                                    <div>
                                                        <div class="font-medium text-sm sm:text-base text-gray-800">İndirimli Ürünler</div>
                                                        <small class="text-xs text-gray-500">Özel fiyatlar</small>
                                                    </div>
                                                </div>
                                                <input class="filter-input ml-0 w-12 h-6 rounded-full border-2 border-gray-300 bg-gray-200 checked:bg-blue-600 checked:border-blue-600 appearance-none cursor-pointer relative transition-colors before:content-[''] before:absolute before:w-5 before:h-5 before:rounded-full before:bg-white before:top-0 before:left-0 before:transition-transform checked:before:translate-x-6" 
                                                       type="checkbox" id="discountedItems" name="IsDiscount" value="true"
                                                       @(Context.Request.Query["isDiscount"] == "true" ? "checked" : "")>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
        
        <!-- Filtreleri Uygula Butonu - Desktop -->
        <div class="hidden lg:block p-4 border-t border-gray-200 bg-white rounded-b-2xl flex-shrink-0">
            <button type="button" 
                    id="applyFiltersBtn"
                    class="w-full bg-primary hover:bg-primary-dark text-white py-3 px-6 rounded-xl font-semibold transition-all duration-300 shadow-[0_8px_25px_rgba(102,126,234,0.3)] hover:-translate-y-0.5 hover:shadow-[0_12px_30px_rgba(102,126,234,0.4)] flex items-center justify-center gap-2">
                <i class="fas fa-check"></i>
                Filtreleri Uygula
            </button>
        </div>
    </div>
</div>
