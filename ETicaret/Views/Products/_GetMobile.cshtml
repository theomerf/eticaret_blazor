@model ProductDetailViewModel
@using System.Security.Claims

<div class="lg:hidden bg-white min-h-screen relative font-sans">
	<div class="relative w-full aspect-square bg-gray-100 group">
		<div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide w-full h-full relative z-10">
			@foreach (var image in Model?.Product.Images ?? Enumerable.Empty<ProductImage>()) {
				<img src="@image.ImageUrl" class="snap-center shrink-0 w-full h-full object-cover" alt="Product Image" />
			}
		</div>
		<div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-20 pointer-events-none">
			@for(int i=0; i < Math.Min(Model?.Product.Images?.Count ?? 0, 5); i++) {
				<div class="w-1.5 h-1.5 rounded-full bg-white/70 shadow-sm backdrop-blur-sm"></div>
			}
		</div>
        <div class="absolute top-4 right-4 z-20">
             @if (User.Identity != null && User.Identity.IsAuthenticated && Context.User.FindFirstValue(ClaimTypes.NameIdentifier) != null)
             {
                 var favouriteIds = ViewBag.FavouriteIds as List<int>;
                 if (favouriteIds != null && Model?.Product != null && favouriteIds.Contains(Model.Product.ProductId))
                 {
                      <button type="button" class="remove-from-favs-btn bg-white/80 backdrop-blur-md p-2 rounded-full shadow-sm text-red-500 w-10 h-10 flex items-center justify-center border border-white/30"
                         data-product-id="@Model?.Product.ProductId" title="Favorilerden Kaldır">
                         <i class="fas fa-heart text-lg"></i>
                     </button>
                 }
                 else
                 {
                     <button type="button" class="add-to-favs-btn bg-white/80 backdrop-blur-md p-2 rounded-full shadow-sm text-gray-500 w-10 h-10 flex items-center justify-center border border-white/30"
                         data-product-id="@Model?.Product.ProductId" title="Favorilere Ekle">
                         <i class="far fa-heart text-lg"></i>
                     </button>
                 }
             }
             else
             {
                  <a href="/login" class="bg-white/80 backdrop-blur-md p-2 rounded-full shadow-sm text-gray-500 w-10 h-10 flex items-center justify-center border border-white/30">
                     <i class="far fa-heart text-lg"></i>
                 </a>
             }
        </div>
	</div>

	<div class="px-6 py-6">
		<h1 class="text-2xl font-black text-gray-800 leading-tight mb-3 text-center tracking-tight">@Model?.Product.ProductName</h1>
		
		<div class="flex justify-center items-center gap-2 mb-8">
			<div class="flex text-amber-400 text-sm">
				@for (int i = 1; i <= 5; i++)
				{
					if (i <= Math.Round(Model?.Product.AverageRating ?? 0)) { <i class="fas fa-star"></i> }
					else { <i class="far fa-star text-gray-200"></i> }
				}
			</div>
			<span class="text-xs text-gray-500 font-bold bg-gray-100 px-2 py-0.5 rounded-md">@Model?.Product.AverageRating (@Model?.Product.ReviewCount)</span>
		</div>

		<div class="grid grid-cols-3 gap-3 mb-6 px-2">
			<div class="flex flex-col items-center justify-center p-3 bg-gray-50/80 rounded-2xl text-center border border-gray-100 shadow-sm">
				<i class="fas fa-truck text-indigo-500 text-lg mb-1.5"></i>
				<span class="text-[10px] font-bold text-gray-600 leading-tight">Hızlı<br>Teslimat</span>
			</div>
			<div class="flex flex-col items-center justify-center p-3 bg-gray-50/80 rounded-2xl text-center border border-gray-100 shadow-sm">
				 <i class="fas fa-undo text-indigo-500 text-lg mb-1.5"></i>
				<span class="text-[10px] font-bold text-gray-600 leading-tight">15 Gün<br>İade</span>
			</div>
			<div class="flex flex-col items-center justify-center p-3 bg-gray-50/80 rounded-2xl text-center border border-gray-100 shadow-sm">
				 <i class="fas fa-shield-alt text-indigo-500 text-lg mb-1.5"></i>
				<span class="text-[10px] font-bold text-gray-600 leading-tight">Güvenli<br>Ödeme</span>
			</div>
		</div>

		<div class="flex justify-center gap-3 mb-6">
			<button class="w-9 h-9 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center text-xs transition-transform active:scale-90"><i class="fab fa-facebook-f"></i></button>
			<button class="w-9 h-9 rounded-full bg-sky-50 text-sky-500 flex items-center justify-center text-xs transition-transform active:scale-90"><i class="fab fa-twitter"></i></button>
			<button class="w-9 h-9 rounded-full bg-green-50 text-green-600 flex items-center justify-center text-xs transition-transform active:scale-90"><i class="fab fa-whatsapp"></i></button>
			<button class="w-9 h-9 rounded-full bg-red-50 text-red-500 flex items-center justify-center text-xs transition-transform active:scale-90"><i class="fab fa-pinterest"></i></button>
		</div>

		<div class="w-full h-px bg-gray-100 mb-8"></div>

		<div class="mb-8 flex flex-col items-center">
			<label class="text-xs font-bold text-gray-400 mb-4 uppercase tracking-wider">Renk Seçimi</label>
			<div class="flex gap-4">
				<div class="pd-color-option w-10 h-10 rounded-full cursor-pointer relative shadow-sm border-[3px] border-white ring-1 ring-gray-200 active transition-transform active:scale-95" style="background-color: #000000;"></div>
				<div class="pd-color-option w-10 h-10 rounded-full cursor-pointer relative shadow-sm border-[3px] border-white ring-1 ring-gray-200 transition-transform active:scale-95" style="background-color: #FFFFFF;"></div>
				<div class="pd-color-option w-10 h-10 rounded-full cursor-pointer relative shadow-sm border-[3px] border-white ring-1 ring-gray-200 transition-transform active:scale-95" style="background-color: #FF0000;"></div>
				<div class="pd-color-option w-10 h-10 rounded-full cursor-pointer relative shadow-sm border-[3px] border-white ring-1 ring-gray-200 transition-transform active:scale-95" style="background-color: #0000FF;"></div>
			</div>
		</div>

		<div class="mb-10 flex flex-col items-center">
			<label class="text-xs font-bold text-gray-400 mb-4 uppercase tracking-wider">Beden Seçimi</label>
			<div class="flex gap-3">
				<div class="pd-size-option w-12 h-12 flex items-center justify-center border border-gray-200 rounded-xl cursor-pointer text-sm font-bold bg-white text-gray-700 shadow-sm transition-all active:bg-gray-50 active:scale-95">S</div>
				<div class="pd-size-option w-12 h-12 flex items-center justify-center border border-gray-200 rounded-xl cursor-pointer text-sm font-bold bg-white text-gray-700 shadow-sm transition-all active:bg-gray-50 active:scale-95 active">M</div>
				<div class="pd-size-option w-12 h-12 flex items-center justify-center border border-gray-200 rounded-xl cursor-pointer text-sm font-bold bg-white text-gray-700 shadow-sm transition-all active:bg-gray-50 active:scale-95">L</div>
				<div class="pd-size-option w-12 h-12 flex items-center justify-center border border-gray-100 rounded-xl text-sm font-bold bg-gray-50 text-gray-300 relative overflow-hidden">
                    <span class="absolute w-full h-[1px] bg-gray-300 rotate-45"></span>
                    XL
                </div>
			</div>
		</div>

		<!-- Ürün Sekmeleri -->
		<div class="space-y-4">
			<div class="border border-gray-100 rounded-2xl overflow-hidden bg-gray-50/50">
				<button onclick="toggleAccordion(this)" class="w-full flex justify-between items-center p-5 font-bold text-gray-800 text-sm active:bg-gray-100 transition-colors">
					ÜRÜN ÖZELLİKLERİ
					<i class="fas fa-chevron-down text-gray-400 text-xs transition-transform duration-300"></i>
				</button>
				<div class="hidden px-5 pb-5 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-4">
					<p class="mb-3">@Model?.Product.Summary</p>
                    <ul class="space-y-2">
						<li class="flex items-center gap-2"><i class="fas fa-check text-emerald-500 text-xs"></i> Yüksek Kalite</li>
						<li class="flex items-center gap-2"><i class="fas fa-check text-emerald-500 text-xs"></i> Dayanıklı Kumaş</li>
					</ul>
				</div>
			</div>

			 <div class="border border-gray-100 rounded-2xl overflow-hidden bg-gray-50/50">
				<button onclick="toggleAccordion(this)" class="w-full flex justify-between items-center p-5 font-bold text-gray-800 text-sm active:bg-gray-100 transition-colors">
					YORUMLAR (@Model?.Product.ReviewCount)
					<i class="fas fa-chevron-down text-gray-400 text-xs transition-transform duration-300"></i>
				</button>
				<div class="hidden bg-white border-t border-gray-100">
                     <div class="-my-4 transform scale-[0.95] origin-top">
					    @await Component.InvokeAsync("ProductReviews", new { productId = Model?.Product.ProductId })
                     </div>
				</div>
			</div>

			 <div class="border border-gray-100 rounded-2xl overflow-hidden bg-gray-50/50">
				<button onclick="toggleAccordion(this)" class="w-full flex justify-between items-center p-5 font-bold text-gray-800 text-sm active:bg-gray-100 transition-colors">
					TEKNİK ÖZELLİKLER
					<i class="fas fa-chevron-down text-gray-400 text-xs transition-transform duration-300"></i>
				</button>
				<div class="hidden bg-white px-5 pb-5 text-sm text-gray-600 border-t border-gray-100 pt-4">
                     <div class="flex justify-between py-2 border-b border-dashed border-gray-100"><span>Malzeme</span> <span class="font-bold text-gray-800">%100 Pamuk</span></div>
                     <div class="flex justify-between py-2 border-b border-dashed border-gray-100"><span>Üretim</span> <span class="font-bold text-gray-800">Türkiye</span></div>
                     <div class="flex justify-between py-2 pt-3"><span>Garanti</span> <span class="font-bold text-gray-800">2 Yıl</span></div>
				</div>
			</div>
			
			 <div class="border border-gray-100 rounded-2xl overflow-hidden bg-gray-50/50">
				<button onclick="toggleAccordion(this)" class="w-full flex justify-between items-center p-5 font-bold text-gray-800 text-sm active:bg-gray-100 transition-colors">
					İADE KOŞULLARI
					<i class="fas fa-chevron-down text-gray-400 text-xs transition-transform duration-300"></i>
				</button>
				<div class="hidden px-5 pb-5 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-4">
					<p>Ürünü teslim aldığınız tarihten itibaren 15 gün içinde ücretsiz iade edebilirsiniz. Ürün kullanılmamış ve paketi hasar görmemiş olmalıdır.</p>
				</div>
			</div>
		</div>
	</div>

	<div class="lg:hidden mt-8 mb-4 px-4">
		<h3 class="text-xl font-black text-gray-800 mb-5 px-2 tracking-tight">Benzer Ürünler</h3>
		<div class="grid grid-cols-2 gap-3">
			@foreach (var product in Model?.RelatedProducts.Take(4) ?? Enumerable.Empty<ProductDto>())
			{
				<partial name="_ProductCardSmall" model="product" />
			}
		</div>
	</div>

</div>

<div class="lg:hidden fixed bottom-0 left-0 w-full bg-primary shadow-[0_-5px_20px_rgba(0,0,0,0.05)] p-4 z-50 flex items-center gap-4 safe-area-bottom">
	<div class="flex flex-col min-w-[35%] shrink-0">
        @if(@Model?.Product.Discount > 0) {
            <div class="flex items-center gap-2 mb-0.5">
		        <span class="text-sm text-gray-700 font-bold line-through decoration-gray-300">@Model?.Product.ActualPrice.ToString("C2", new CultureInfo("tr-TR"))</span>
                <span class="text-[10px] font-bold text-red-600 bg-red-50 px-1.5 py-0.5 rounded border border-red-100 flex items-center shadow-md">
                    <i class="fas fa-arrow-down text-[8px] mr-0.5"></i>%@Model?.Product.Discount
                </span>
            </div>
		    <span class="text-2xl font-black text-gray-900 tracking-tight leading-none">@Model?.Product.DiscountPrice?.ToString("C2", new CultureInfo("tr-TR"))</span>
        } else {
             <span class="text-2xl font-black text-gray-900 tracking-tight leading-none">@Model?.Product.ActualPrice.ToString("C2", new CultureInfo("tr-TR"))</span>
        }
	</div>
	<div class="flex-1 flex gap-2 h-12">
		 <button type="button" class="pd-add-cart-btn flex-1 bg-button text-white rounded-xl font-bold text-sm shadow-md active:scale-95 transition-all flex items-center justify-center gap-2 overflow-hidden relative" data-product-id="@Model?.Product.ProductId" data-in-cart="false">
             <span class="btn-content flex items-center justify-center gap-2">
                 <i class="fas fa-shopping-bag"></i> <span class="btn-text">Sepete Ekle</span>
             </span>
             <span class="btn-loading hidden items-center justify-center gap-2">
                 <span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
             </span>
             <span class="btn-remove hidden items-center justify-center gap-2">
                 <i class="fas fa-trash"></i> <span class="btn-text">Kaldır</span>
             </span>
             <span class="btn-remove-loading hidden items-center justify-center gap-2">
			    <span class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></span>
            </span>
         </button>
		 <button class="flex-1 bg-white text-gray-900 rounded-xl font-bold text-sm shadow-md active:scale-95 transition-all flex items-center justify-center hover:bg-indigo-700">
             Satın Al
         </button>
	</div>
</div>
